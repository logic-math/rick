package cmd

import (
	"bufio"
	"fmt"
	"os"
	"os/exec"
	"path/filepath"
	"strings"

	"github.com/spf13/cobra"
	"github.com/sunquan/rick/internal/config"
	"github.com/sunquan/rick/internal/git"
	"github.com/sunquan/rick/internal/workspace"
)

func NewLearningCmd() *cobra.Command {
	var jobID string

	learningCmd := &cobra.Command{
		Use:   "learning [job_id]",
		Short: "Perform knowledge accumulation and learning for a completed job",
		Long:  `Perform knowledge accumulation and learning for a completed job. Analyzes execution results and generates learning documentation.`,
		Args:  cobra.MaximumNArgs(1),
		RunE: func(cmd *cobra.Command, args []string) error {
			if GetVerbose() {
				fmt.Println("[INFO] Starting learning phase...")
			}

			if GetDryRun() {
				fmt.Println("[DRY-RUN] Would perform learning")
				return nil
			}

			// Get job ID from args, local flag, or global flag
			if len(args) > 0 {
				jobID = args[0]
			} else if jobID == "" {
				jobID = GetJobID()
			}

			if jobID == "" {
				return fmt.Errorf("job ID is required. Usage: rick learning [job_id] or rick learning --job job_id")
			}

			// Validate job ID format
			if err := validateJobID(jobID); err != nil {
				return err
			}

			if GetVerbose() {
				fmt.Printf("[INFO] Performing learning for job: %s\n", jobID)
			}

			// Execute learning workflow
			if err := executeLearningWorkflow(jobID); err != nil {
				return err
			}

			fmt.Printf("Learning phase for job %s completed!\n", jobID)
			return nil
		},
	}

	learningCmd.Flags().StringVar(&jobID, "job", "", "Job ID to perform learning on")

	return learningCmd
}

// executeLearningWorkflow executes the complete learning workflow
func executeLearningWorkflow(jobID string) error {
	// Step 1: Load configuration and workspace
	cfg, err := config.LoadConfig()
	if err != nil {
		return fmt.Errorf("failed to load config: %w", err)
	}

	_, err = workspace.New()
	if err != nil {
		return fmt.Errorf("failed to create workspace: %w", err)
	}

	rickDir, err := workspace.GetRickDir()
	if err != nil {
		return fmt.Errorf("failed to get rick directory: %w", err)
	}

	if GetVerbose() {
		fmt.Printf("[INFO] Using workspace: %s\n", rickDir)
	}

	// Step 2: Validate job directory structure
	jobDir := filepath.Join(rickDir, "jobs", jobID)
	doingDir := filepath.Join(jobDir, "doing")
	learningDir := filepath.Join(jobDir, "learning")

	if _, err := os.Stat(jobDir); os.IsNotExist(err) {
		return fmt.Errorf("job directory not found: %s", jobDir)
	}

	if _, err := os.Stat(doingDir); os.IsNotExist(err) {
		return fmt.Errorf("doing directory not found: %s (job may not have been executed)", doingDir)
	}

	// Create learning directory if it doesn't exist
	if err := os.MkdirAll(learningDir, 0755); err != nil {
		return fmt.Errorf("failed to create learning directory: %w", err)
	}

	if GetVerbose() {
		fmt.Printf("[INFO] Job directory: %s\n", jobDir)
		fmt.Printf("[INFO] Doing directory: %s\n", doingDir)
		fmt.Printf("[INFO] Learning directory: %s\n", learningDir)
	}

	// Step 3: 读取 debug.md 和 Git 变更（包含 diff）
	fmt.Println("\n=== Step 1: 收集执行信息 ===")
	executionData, err := collectExecutionData(jobID, doingDir)
	if err != nil {
		return fmt.Errorf("failed to collect execution data: %w", err)
	}

	if GetVerbose() {
		fmt.Printf("[INFO] Collected %d commits with diffs\n", len(executionData.Commits))
	}

	// Step 4: 对话式确定更新内容
	fmt.Println("\n=== Step 2: 分析和对话 ===")
	updates, err := dialogWithHuman(cfg, executionData)
	if err != nil {
		return fmt.Errorf("failed to complete dialog: %w", err)
	}

	// Step 5: 生成到 learning/ 目录
	fmt.Println("\n=== Step 3: 生成 Learning 文件 ===")
	if err := generateLearningFiles(learningDir, updates); err != nil {
		return fmt.Errorf("failed to generate learning files: %w", err)
	}

	fmt.Printf("\n✅ Learning 文件已生成到: %s\n", learningDir)
	fmt.Println("请审核以下文件：")
	fmt.Println("  - learning/OKR.md")
	fmt.Println("  - learning/SPEC.md")
	fmt.Println("  - learning/wiki/")
	fmt.Println("  - learning/skills/")

	// Step 6: 人类审核
	fmt.Println("\n=== Step 4: 人类审核 ===")
	if !promptForApproval() {
		fmt.Println("❌ 用户取消了合并操作")
		return nil
	}

	// Step 7: 调用 merge skill 合并到全局
	fmt.Println("\n=== Step 5: 合并到全局目录 ===")
	if err := mergeToGlobal(learningDir, rickDir); err != nil {
		return fmt.Errorf("failed to merge to global: %w", err)
	}

	// Step 8: Commit
	if GetVerbose() {
		fmt.Println("[INFO] Committing learning results...")
	}

	if err := commitLearningResults(jobID); err != nil {
		fmt.Printf("[WARN] Failed to commit learning results: %v\n", err)
	}

	fmt.Println("\n✅ Learning 阶段完成！")
	return nil
}

// ExecutionData represents collected execution data
type ExecutionData struct {
	JobID        string
	DebugContent string
	Commits      []CommitWithDiff
	ExecutionLog string
}

// CommitWithDiff represents a commit with its diff
type CommitWithDiff struct {
	Hash    string
	Message string
	Author  string
	Date    string
	Diff    string
}

// collectExecutionData collects debug.md and git changes with diff
func collectExecutionData(jobID string, doingDir string) (*ExecutionData, error) {
	data := &ExecutionData{
		JobID: jobID,
	}

	// 1. 读取 debug.md
	debugPath := filepath.Join(doingDir, "debug.md")
	if content, err := os.ReadFile(debugPath); err == nil {
		data.DebugContent = string(content)
		fmt.Printf("✅ 读取 debug.md (%d 字节)\n", len(content))
	} else {
		fmt.Println("⚠️  未找到 debug.md")
	}

	// 2. 读取 execution log
	logPath := filepath.Join(doingDir, "execution.log")
	if content, err := os.ReadFile(logPath); err == nil {
		data.ExecutionLog = string(content)
		fmt.Printf("✅ 读取 execution.log (%d 字节)\n", len(content))
	}

	// 3. 获取本 Job 的所有 commit（通过 grep jobID）
	cwd, err := os.Getwd()
	if err != nil {
		return nil, fmt.Errorf("failed to get current directory: %w", err)
	}

	gm := git.New(cwd)
	commits, err := gm.GetCommitsByGrep(jobID, 50)
	if err != nil {
		fmt.Printf("⚠️  无法获取 Git commits: %v\n", err)
		return data, nil
	}

	fmt.Printf("✅ 找到 %d 个相关 commits\n", len(commits))

	// 4. 对每个 commit 获取 diff
	for _, commit := range commits {
		diff, err := gm.GetDiff(commit.Hash)
		if err != nil {
			fmt.Printf("⚠️  无法获取 commit %s 的 diff: %v\n", commit.Hash[:7], err)
			continue
		}

		data.Commits = append(data.Commits, CommitWithDiff{
			Hash:    commit.Hash,
			Message: commit.Message,
			Author:  commit.Author,
			Date:    commit.Date.Format("2006-01-02 15:04:05"),
			Diff:    diff,
		})
	}

	fmt.Printf("✅ 成功获取 %d 个 commits 的 diff\n", len(data.Commits))
	return data, nil
}

// LearningUpdates represents the updates to be made
type LearningUpdates struct {
	OKR    string
	SPEC   string
	Wiki   map[string]string // filename -> content
	Skills map[string]string // filename -> content
}

// dialogWithHuman conducts dialog with human to determine updates
func dialogWithHuman(cfg *config.Config, data *ExecutionData) (*LearningUpdates, error) {
	updates := &LearningUpdates{
		Wiki:   make(map[string]string),
		Skills: make(map[string]string),
	}

	// 显示执行摘要
	fmt.Println("\n执行摘要：")
	fmt.Println("===========================================")
	if data.DebugContent != "" {
		fmt.Printf("Debug 记录：%d 字节\n", len(data.DebugContent))
	}
	fmt.Printf("Git Commits：%d 个\n", len(data.Commits))
	for i, commit := range data.Commits {
		fmt.Printf("  %d. %s (%s)\n", i+1, commit.Message, commit.Hash[:7])
	}
	fmt.Println("===========================================")

	// 可选：调用 Claude 进行分析（如果失败则跳过）
	fmt.Println("\n提示：你可以查看 doing/debug.md 和 git log 了解详细信息")
	fmt.Print("是否需要 Claude 分析？(y/n，默认 n): ")
	reader := bufio.NewReader(os.Stdin)
	needAnalysis, _ := reader.ReadString('\n')
	if strings.TrimSpace(strings.ToLower(needAnalysis)) == "y" {
		analysisPrompt := buildAnalysisPrompt(data)
		fmt.Println("\n正在分析执行结果...")
		analysis, err := callClaudeForAnalysis(cfg, analysisPrompt)
		if err != nil {
			fmt.Printf("⚠️  Claude 分析失败: %v\n", err)
			fmt.Println("继续进行手动对话...")
		} else {
			fmt.Println("\n分析完成！")
			fmt.Println("===========================================")
			fmt.Println(analysis)
			fmt.Println("===========================================")
		}
	}

	// 对话式确定 OKR 更新
	fmt.Println("\n--- OKR 更新 ---")
	fmt.Println("这个 Job 对项目长期目标有什么影响？")
	fmt.Print("请输入 OKR 更新内容（留空跳过）：")
	okrInput, _ := reader.ReadString('\n')
	updates.OKR = strings.TrimSpace(okrInput)

	// 对话式确定 SPEC 更新
	fmt.Println("\n--- SPEC 更新 ---")
	fmt.Println("是否需要调整开发规范？")
	fmt.Print("请输入 SPEC 更新内容（留空跳过）：")
	specInput, _ := reader.ReadString('\n')
	updates.SPEC = strings.TrimSpace(specInput)

	// 对话式确定 Wiki 更新
	fmt.Println("\n--- Wiki 更新 ---")
	fmt.Println("是否有新的系统运行原理需要记录？")
	fmt.Print("需要创建 Wiki 文档吗？(y/n): ")
	wikiChoice, _ := reader.ReadString('\n')
	if strings.TrimSpace(strings.ToLower(wikiChoice)) == "y" {
		fmt.Print("Wiki 文件名（如 authentication.md）: ")
		wikiName, _ := reader.ReadString('\n')
		wikiName = strings.TrimSpace(wikiName)

		fmt.Println("请输入 Wiki 内容（输入 EOF 结束）:")
		var wikiContent strings.Builder
		for {
			line, _ := reader.ReadString('\n')
			if strings.TrimSpace(line) == "EOF" {
				break
			}
			wikiContent.WriteString(line)
		}
		updates.Wiki[wikiName] = wikiContent.String()
	}

	// 对话式确定 Skills 提取
	fmt.Println("\n--- Skills 沉淀 ---")
	fmt.Println("是否有可复用的技能需要提取？")
	fmt.Print("需要创建 Skill 文档吗？(y/n): ")
	skillChoice, _ := reader.ReadString('\n')
	if strings.TrimSpace(strings.ToLower(skillChoice)) == "y" {
		fmt.Print("Skill 文件名（如 oauth2_integration.md）: ")
		skillName, _ := reader.ReadString('\n')
		skillName = strings.TrimSpace(skillName)

		fmt.Println("请输入 Skill 内容（输入 EOF 结束）:")
		var skillContent strings.Builder
		for {
			line, _ := reader.ReadString('\n')
			if strings.TrimSpace(line) == "EOF" {
				break
			}
			skillContent.WriteString(line)
		}
		updates.Skills[skillName] = skillContent.String()
	}

	return updates, nil
}

// buildAnalysisPrompt builds the analysis prompt from execution data
func buildAnalysisPrompt(data *ExecutionData) string {
	var prompt strings.Builder

	prompt.WriteString("# Learning Analysis for Job: " + data.JobID + "\n\n")

	// Debug 记录
	if data.DebugContent != "" {
		prompt.WriteString("## Debug 记录\n\n")
		prompt.WriteString(data.DebugContent)
		prompt.WriteString("\n\n")
	}

	// Git 变更
	if len(data.Commits) > 0 {
		prompt.WriteString("## Git 变更历史\n\n")
		for i, commit := range data.Commits {
			prompt.WriteString(fmt.Sprintf("### Commit %d: %s\n", i+1, commit.Message))
			prompt.WriteString(fmt.Sprintf("- Hash: %s\n", commit.Hash[:7]))
			prompt.WriteString(fmt.Sprintf("- Author: %s\n", commit.Author))
			prompt.WriteString(fmt.Sprintf("- Date: %s\n\n", commit.Date))
			prompt.WriteString("```diff\n")
			// 限制 diff 长度
			if len(commit.Diff) > 5000 {
				prompt.WriteString(commit.Diff[:5000])
				prompt.WriteString("\n... (truncated)\n")
			} else {
				prompt.WriteString(commit.Diff)
			}
			prompt.WriteString("\n```\n\n")
		}
	}

	prompt.WriteString("## 分析任务\n\n")
	prompt.WriteString("请基于以上信息，分析：\n")
	prompt.WriteString("1. 本 Job 实现了什么功能？\n")
	prompt.WriteString("2. 遇到了哪些问题？如何解决的？\n")
	prompt.WriteString("3. 有哪些技术亮点或创新？\n")
	prompt.WriteString("4. 对 OKR 的影响是什么？\n")
	prompt.WriteString("5. 是否需要更新开发规范？\n")
	prompt.WriteString("6. 有哪些知识值得记录到 Wiki？\n")
	prompt.WriteString("7. 有哪些可复用的技能？\n")

	return prompt.String()
}

// callClaudeForAnalysis calls Claude for initial analysis
func callClaudeForAnalysis(cfg *config.Config, prompt string) (string, error) {
	claudePath := cfg.ClaudeCodePath
	if claudePath == "" {
		claudePath = "claude"
	}

	// 使用非交互式模式
	cmd := exec.Command(claudePath, "--dangerously-skip-permissions")
	stdin, err := cmd.StdinPipe()
	if err != nil {
		return "", fmt.Errorf("failed to create stdin pipe: %w", err)
	}

	var stdout, stderr strings.Builder
	cmd.Stdout = &stdout
	cmd.Stderr = &stderr

	if err := cmd.Start(); err != nil {
		return "", fmt.Errorf("failed to start Claude: %w", err)
	}

	if _, err := stdin.Write([]byte(prompt)); err != nil {
		stdin.Close()
		return "", fmt.Errorf("failed to write prompt: %w", err)
	}
	stdin.Close()

	if err := cmd.Wait(); err != nil {
		return stdout.String() + "\n" + stderr.String(), fmt.Errorf("Claude execution failed: %w", err)
	}

	return stdout.String(), nil
}

// generateLearningFiles generates files to learning/ directory
func generateLearningFiles(learningDir string, updates *LearningUpdates) error {
	// 生成 OKR.md
	if updates.OKR != "" {
		okrPath := filepath.Join(learningDir, "OKR.md")
		content := "# OKR 更新\n\n" + updates.OKR + "\n"
		if err := os.WriteFile(okrPath, []byte(content), 0644); err != nil {
			return fmt.Errorf("failed to write OKR.md: %w", err)
		}
		fmt.Println("✅ 生成 OKR.md")
	}

	// 生成 SPEC.md
	if updates.SPEC != "" {
		specPath := filepath.Join(learningDir, "SPEC.md")
		content := "# SPEC 更新\n\n" + updates.SPEC + "\n"
		if err := os.WriteFile(specPath, []byte(content), 0644); err != nil {
			return fmt.Errorf("failed to write SPEC.md: %w", err)
		}
		fmt.Println("✅ 生成 SPEC.md")
	}

	// 生成 wiki/
	if len(updates.Wiki) > 0 {
		wikiDir := filepath.Join(learningDir, "wiki")
		if err := os.MkdirAll(wikiDir, 0755); err != nil {
			return fmt.Errorf("failed to create wiki directory: %w", err)
		}

		for filename, content := range updates.Wiki {
			wikiPath := filepath.Join(wikiDir, filename)
			if err := os.WriteFile(wikiPath, []byte(content), 0644); err != nil {
				return fmt.Errorf("failed to write wiki/%s: %w", filename, err)
			}
			fmt.Printf("✅ 生成 wiki/%s\n", filename)
		}
	}

	// 生成 skills/
	if len(updates.Skills) > 0 {
		skillsDir := filepath.Join(learningDir, "skills")
		if err := os.MkdirAll(skillsDir, 0755); err != nil {
			return fmt.Errorf("failed to create skills directory: %w", err)
		}

		for filename, content := range updates.Skills {
			skillPath := filepath.Join(skillsDir, filename)
			if err := os.WriteFile(skillPath, []byte(content), 0644); err != nil {
				return fmt.Errorf("failed to write skills/%s: %w", filename, err)
			}
			fmt.Printf("✅ 生成 skills/%s\n", filename)
		}
	}

	return nil
}

// promptForApproval prompts user to approve merging
func promptForApproval() bool {
	reader := bufio.NewReader(os.Stdin)
	fmt.Print("\n审核完成后，是否合并到全局目录？(y/n): ")
	response, err := reader.ReadString('\n')
	if err != nil {
		return false
	}

	response = strings.TrimSpace(strings.ToLower(response))
	return response == "y" || response == "yes"
}

// mergeToGlobal merges learning/ content to .rick/ global directory
func mergeToGlobal(learningDir, rickDir string) error {
	// 合并 OKR.md
	if err := mergeOKR(learningDir, rickDir); err != nil {
		return fmt.Errorf("failed to merge OKR: %w", err)
	}

	// 合并 SPEC.md
	if err := mergeSPEC(learningDir, rickDir); err != nil {
		return fmt.Errorf("failed to merge SPEC: %w", err)
	}

	// 合并 wiki/
	if err := mergeWiki(learningDir, rickDir); err != nil {
		return fmt.Errorf("failed to merge wiki: %w", err)
	}

	// 合并 skills/
	if err := mergeSkills(learningDir, rickDir); err != nil {
		return fmt.Errorf("failed to merge skills: %w", err)
	}

	return nil
}

// mergeOKR merges OKR.md with deduplication
func mergeOKR(learningDir, rickDir string) error {
	learningOKR := filepath.Join(learningDir, "OKR.md")
	globalOKR := filepath.Join(rickDir, "OKR.md")

	// 检查 learning/OKR.md 是否存在
	if _, err := os.Stat(learningOKR); os.IsNotExist(err) {
		return nil // 没有更新，跳过
	}

	learningContent, err := os.ReadFile(learningOKR)
	if err != nil {
		return fmt.Errorf("failed to read learning OKR: %w", err)
	}

	// 读取全局 OKR（如果存在）
	var globalContent []byte
	if _, err := os.Stat(globalOKR); err == nil {
		globalContent, _ = os.ReadFile(globalOKR)
	}

	// 简单合并：追加到全局文件（TODO: 实现智能去重）
	merged := string(globalContent)
	if len(globalContent) > 0 {
		merged += "\n\n"
	}
	merged += string(learningContent)

	if err := os.WriteFile(globalOKR, []byte(merged), 0644); err != nil {
		return fmt.Errorf("failed to write global OKR: %w", err)
	}

	fmt.Println("✅ 合并 OKR.md")
	return nil
}

// mergeSPEC merges SPEC.md with deduplication
func mergeSPEC(learningDir, rickDir string) error {
	learningSPEC := filepath.Join(learningDir, "SPEC.md")
	globalSPEC := filepath.Join(rickDir, "SPEC.md")

	// 检查 learning/SPEC.md 是否存在
	if _, err := os.Stat(learningSPEC); os.IsNotExist(err) {
		return nil // 没有更新，跳过
	}

	learningContent, err := os.ReadFile(learningSPEC)
	if err != nil {
		return fmt.Errorf("failed to read learning SPEC: %w", err)
	}

	// 读取全局 SPEC（如果存在）
	var globalContent []byte
	if _, err := os.Stat(globalSPEC); err == nil {
		globalContent, _ = os.ReadFile(globalSPEC)
	}

	// 简单合并：追加到全局文件（TODO: 实现智能去重）
	merged := string(globalContent)
	if len(globalContent) > 0 {
		merged += "\n\n"
	}
	merged += string(learningContent)

	if err := os.WriteFile(globalSPEC, []byte(merged), 0644); err != nil {
		return fmt.Errorf("failed to write global SPEC: %w", err)
	}

	fmt.Println("✅ 合并 SPEC.md")
	return nil
}

// mergeWiki merges wiki/ directory
func mergeWiki(learningDir, rickDir string) error {
	learningWiki := filepath.Join(learningDir, "wiki")
	globalWiki := filepath.Join(rickDir, "wiki")

	// 检查 learning/wiki/ 是否存在
	if _, err := os.Stat(learningWiki); os.IsNotExist(err) {
		return nil // 没有 wiki 更新，跳过
	}

	// 创建全局 wiki 目录
	if err := os.MkdirAll(globalWiki, 0755); err != nil {
		return fmt.Errorf("failed to create global wiki directory: %w", err)
	}

	// 复制所有 wiki 文件
	entries, err := os.ReadDir(learningWiki)
	if err != nil {
		return fmt.Errorf("failed to read learning wiki: %w", err)
	}

	for _, entry := range entries {
		if entry.IsDir() {
			continue
		}

		srcPath := filepath.Join(learningWiki, entry.Name())
		dstPath := filepath.Join(globalWiki, entry.Name())

		content, err := os.ReadFile(srcPath)
		if err != nil {
			return fmt.Errorf("failed to read %s: %w", entry.Name(), err)
		}

		if err := os.WriteFile(dstPath, content, 0644); err != nil {
			return fmt.Errorf("failed to write %s: %w", entry.Name(), err)
		}

		fmt.Printf("✅ 合并 wiki/%s\n", entry.Name())
	}

	return nil
}

// mergeSkills merges skills/ directory
func mergeSkills(learningDir, rickDir string) error {
	learningSkills := filepath.Join(learningDir, "skills")
	globalSkills := filepath.Join(rickDir, "skills")

	// 检查 learning/skills/ 是否存在
	if _, err := os.Stat(learningSkills); os.IsNotExist(err) {
		return nil // 没有 skills 更新，跳过
	}

	// 创建全局 skills 目录
	if err := os.MkdirAll(globalSkills, 0755); err != nil {
		return fmt.Errorf("failed to create global skills directory: %w", err)
	}

	// 复制所有 skills 文件
	entries, err := os.ReadDir(learningSkills)
	if err != nil {
		return fmt.Errorf("failed to read learning skills: %w", err)
	}

	for _, entry := range entries {
		if entry.IsDir() {
			continue
		}

		srcPath := filepath.Join(learningSkills, entry.Name())
		dstPath := filepath.Join(globalSkills, entry.Name())

		content, err := os.ReadFile(srcPath)
		if err != nil {
			return fmt.Errorf("failed to read %s: %w", entry.Name(), err)
		}

		if err := os.WriteFile(dstPath, content, 0644); err != nil {
			return fmt.Errorf("failed to write %s: %w", entry.Name(), err)
		}

		fmt.Printf("✅ 合并 skills/%s\n", entry.Name())
	}

	return nil
}

// commitLearningResults commits the learning results to git
func commitLearningResults(jobID string) error {
	// Get current working directory
	cwd, err := os.Getwd()
	if err != nil {
		return fmt.Errorf("failed to get current working directory: %w", err)
	}

	// Create git manager
	gm := git.New(cwd)

	// Create auto committer
	ac := git.NewAutoCommitter(gm)

	// Check if there are any changes
	hasChanges, err := ac.HasChanges()
	if err != nil {
		return fmt.Errorf("failed to check for changes: %w", err)
	}

	if !hasChanges {
		if GetVerbose() {
			fmt.Println("[INFO] No changes to commit")
		}
		return nil
	}

	// Generate commit message
	commitMsg := fmt.Sprintf("rick: learning %s - COMPLETED\n\nLearning phase completed with knowledge documentation.\n\nCo-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>",
		jobID)

	// Add all files and commit
	if err := ac.AutoAddAndCommitJob(jobID, commitMsg); err != nil {
		return fmt.Errorf("failed to commit changes: %w", err)
	}

	fmt.Println("✅ 已提交到 Git")
	return nil
}
