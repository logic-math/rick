romptManager(tmpDir)\n    46вҶ’\n    47вҶ’\t// Create context manager\n    48вҶ’\tcontextMgr := NewContextManager(\"job_1\")\n    49вҶ’\n    50вҶ’\t// Load OKR\n    51вҶ’\tokrContent := \"# Objectives\\n- Build Rick CLI\\n\\n# Key Results\\n- Complete 8 modules\"\n    52вҶ’\tcontextMgr.LoadOKRFromContent(okrContent)\n    53вҶ’\n    54вҶ’\t// Load SPEC\n    55вҶ’\tspecContent := \"# Specifications\\n- Use Go language\\n- Support DAG execution\"\n    56вҶ’\tcontextMgr.LoadSPECFromContent(specContent)\n    57вҶ’\n    58вҶ’\t// Load history\n    59вҶ’\tcontextMgr.LoadHistory([]string{\"Module 1 completed\", \"Module 2 completed\"})\n    60вҶ’\n    61вҶ’\t// Generate plan prompt\n    62вҶ’\trequirement := \"Implement prompt management system\"\n    63вҶ’\tprompt, err := GeneratePlanPrompt(requirement, contextMgr, manager)\n    64вҶ’\n    65вҶ’\tif err != nil {\n    66вҶ’\t\tt.Fatalf(\"GeneratePlanPrompt failed: %v\", err)\n    67вҶ’\t}\n    68вҶ’\n    69вҶ’\t// Verify prompt contains project information\n    70вҶ’\tif !strings.Contains(prompt, \"Rick CLI\") {\n    71вҶ’\t\tt.Error(\"Expected prompt to contain project name\")\n    72вҶ’\t}\n    73вҶ’\n    74вҶ’\tif !strings.Contains(prompt, \"Context-First AI Coding Framework\") {\n    75вҶ’\t\tt.Error(\"Expected prompt to contain project description\")\n    76вҶ’\t}\n    77вҶ’\n    78вҶ’\t// Verify prompt contains user requirement\n    79вҶ’\tif !strings.Contains(prompt, requirement) {\n    80вҶ’\t\tt.Error(\"Expected prompt to contain user requirement\")\n    81вҶ’\t}\n    82вҶ’\n    83вҶ’\t// Verify prompt contains OKR information\n    84вҶ’\tif !strings.Contains(prompt, \"Build Rick CLI\") {\n    85вҶ’\t\tt.Error(\"Expected prompt to contain OKR information\")\n    86вҶ’\t}\n    87вҶ’\n    88вҶ’\t// Verify prompt contains SPEC information\n    89вҶ’\tif !strings.Contains(prompt, \"Use Go language\") {\n    90вҶ’\t\tt.Error(\"Expected prompt to contain SPEC information\")\n    91вҶ’\t}\n    92вҶ’\n    93вҶ’\t// Verify prompt contains completed work\n    94вҶ’\tif !strings.Contains(prompt, \"Module 1 completed\") {\n    95вҶ’\t\tt.Error(\"Expected prompt to contain completed work\")\n    96вҶ’\t}\n    97вҶ’}\n    98вҶ’\n    99вҶ’func TestGeneratePlanPrompt_EmptyRequirement(t *testing.T) {\n   100вҶ’\ttmpDir := t.TempDir()\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"31db7691-f921-4766-a6a9-1cd86dff7cea","uuid":"b070f753-4860-4674-a78f-cd78a403b64f","tool_use_result":{"type":"text","file":{"filePath":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/plan_prompt_test.go","content":"package prompt\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/sunquan/rick/internal/parser\"\n)\n\nfunc TestGeneratePlanPrompt_Success(t *testing.T) {\n\t// Create temporary template directory\n\ttmpDir := t.TempDir()\n\n\t// Create plan.md template\n\tplanTemplate := `# Rick йЎ№зӣ®и§„еҲ’йҳ¶ж®өжҸҗзӨәиҜҚ\n\n## йЎ№зӣ®иғҢжҷҜ\n\n**йЎ№зӣ®еҗҚз§°**: {{project_name}}\n**йЎ№зӣ®жҸҸиҝ°**: {{project_description}}\n\n### йЎ№зӣ® OKR\n{{okr_content}}\n\n### йЎ№зӣ® SPEC\n{{spec_content}}\n\n### е·Іе®ҢжҲҗзҡ„е·ҘдҪң\n{{completed_work}}\n\n## и§„еҲ’д»»еҠЎ\n\nж №жҚ®дёҠиҝ°иғҢжҷҜпјҢиҜ·дёәд»ҘдёӢйңҖжұӮз”ҹжҲҗиҜҰз»Ҷзҡ„и§„еҲ’ж–ҮжЎЈпјҡ\n\n**з”ЁжҲ·йңҖжұӮ**: {{user_requirement}}`\n\n\tplanPath := filepath.Join(tmpDir, \"plan.md\")\n\tif err := os.WriteFile(planPath, []byte(planTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create plan template: %v\", err)\n\t}\n\n\t// Create prompt manager\n\tmanager := NewPromptManager(tmpDir)\n\n\t// Create context manager\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\t// Load OKR\n\tokrContent := \"# Objectives\\n- Build Rick CLI\\n\\n# Key Results\\n- Complete 8 modules\"\n\tcontextMgr.LoadOKRFromContent(okrContent)\n\n\t// Load SPEC\n\tspecContent := \"# Specifications\\n- Use Go language\\n- Support DAG execution\"\n\tcontextMgr.LoadSPECFromContent(specContent)\n\n\t// Load history\n\tcontextMgr.LoadHistory([]string{\"Module 1 completed\", \"Module 2 completed\"})\n\n\t// Generate plan prompt\n\trequirement := \"Implement prompt management system\"\n\tprompt, err := GeneratePlanPrompt(requirement, contextMgr, manager)\n\n\tif err != nil {\n\t\tt.Fatalf(\"GeneratePlanPrompt failed: %v\", err)\n\t}\n\n\t// Verify prompt contains project information\n\tif !strings.Contains(prompt, \"Rick CLI\") {\n\t\tt.Error(\"Expected prompt to contain project name\")\n\t}\n\n\tif !strings.Contains(prompt, \"Context-First AI Coding Framework\") {\n\t\tt.Error(\"Expected prompt to contain project description\")\n\t}\n\n\t// Verify prompt contains user requirement\n\tif !strings.Contains(prompt, requirement) {\n\t\tt.Error(\"Expected prompt to contain user requirement\")\n\t}\n\n\t// Verify prompt contains OKR information\n\tif !strings.Contains(prompt, \"Build Rick CLI\") {\n\t\tt.Error(\"Expected prompt to contain OKR information\")\n\t}\n\n\t// Verify prompt contains SPEC information\n\tif !strings.Contains(prompt, \"Use Go language\") {\n\t\tt.Error(\"Expected prompt to contain SPEC information\")\n\t}\n\n\t// Verify prompt contains completed work\n\tif !strings.Contains(prompt, \"Module 1 completed\") {\n\t\tt.Error(\"Expected prompt to contain completed work\")\n\t}\n}\n\nfunc TestGeneratePlanPrompt_EmptyRequirement(t *testing.T) {\n\ttmpDir := t.TempDir()","numLines":100,"startLine":1,"totalLines":413}}},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_5b903dba-d94","type":"message","content":[{"text":"Now let me create the test file for doing_prompt.go:","type":"text"}],"context_management":null},"parent_tool_use_id":null,"session_id":"31db7691-f921-4766-a6a9-1cd86dff7cea","uuid":"bddc8e2e-35a8-4bd9-b6fe-c74330458f5a"},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_5b903dba-d94","type":"message","content":[{"input":{"file_path":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/doing_prompt_test.go","content":"package prompt\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/sunquan/rick/internal/parser\"\n)\n\nfunc TestGenerateDoingPrompt_Success(t *testing.T) {\n\t// Create temporary template directory\n\ttmpDir := t.TempDir()\n\n\t// Create doing.md template\n\tdoingTemplate := `# Rick йЎ№зӣ®жү§иЎҢйҳ¶ж®өжҸҗзӨәиҜҚ\n\nдҪ жҳҜдёҖдёӘиө„ж·ұзҡ„иҪҜд»¶е·ҘзЁӢеёҲгҖӮдҪ зҡ„д»»еҠЎжҳҜжү§иЎҢи§„еҲ’еҘҪзҡ„д»»еҠЎпјҢе®ҢжҲҗе…·дҪ“зҡ„зј–з Ғе·ҘдҪңгҖӮ\n\n## д»»еҠЎдҝЎжҒҜ\n\n**д»»еҠЎ ID**: {{task_id}}\n**д»»еҠЎеҗҚз§°**: {{task_name}}\n**йҮҚиҜ•ж¬Ўж•°**: {{retry_count}}\n\n### д»»еҠЎзӣ®ж Ү\n{{task_objective}}\n\n### е…ій”®з»“жһң\n{{key_results}}\n\n### жөӢиҜ•ж–№жі•\n{{test_methods}}\n\n## йЎ№зӣ®иғҢжҷҜ\n\n**йЎ№зӣ®еҗҚз§°**: {{project_name}}\n**йЎ№зӣ®жҸҸиҝ°**: {{project_description}}\n\n### йЎ№зӣ® SPEC\n{{spec_content}}\n\n### йЎ№зӣ®жһ¶жһ„\n{{project_architecture}}\n\n## жү§иЎҢдёҠдёӢж–Ү\n\n### е·Іе®ҢжҲҗзҡ„д»»еҠЎ\n{{completed_tasks}}\n\n### д»»еҠЎдҫқиө–\n{{task_dependencies}}\n\n{{#if retry_count > 0}}\n### еүҚж¬Ўжү§иЎҢзҡ„й—®йўҳи®°еҪ•\n\nж №жҚ®еүҚж¬Ўжү§иЎҢйҒҮеҲ°зҡ„й—®йўҳпјҢиҜ·йҮҚзӮ№е…іжіЁд»ҘдёӢеҶ…е®№пјҡ\n\n{{debug_context}}\n\nиҜ·зЎ®дҝқиҝҷж¬Ўжү§иЎҢиғҪеӨҹи§ЈеҶід№ӢеүҚйҒҮеҲ°зҡ„й—®йўҳгҖӮ\n{{/if}}\n\n## жү§иЎҢиҰҒжұӮ\n\n1. **зҗҶи§ЈйңҖжұӮ**: д»”з»Ҷйҳ…иҜ»д»»еҠЎзӣ®ж Үе’Ңе…ій”®з»“жһң\n2. **и®ҫи®Ўж–№жЎҲ**: ж №жҚ®йЎ№зӣ®жһ¶жһ„е’ҢзҺ°жңүд»Јз ҒпјҢи®ҫи®Ўе®һзҺ°ж–№жЎҲ\n3. **зј–еҶҷд»Јз Ғ**: е®һзҺ°жүҖжңүеҝ…иҰҒзҡ„еҠҹиғҪ\n4. **жөӢиҜ•йӘҢиҜҒ**: жҢүз…§жөӢиҜ•ж–№жі•йӘҢиҜҒеҠҹиғҪзҡ„жӯЈзЎ®жҖ§\n5. **жҸҗдәӨд»Јз Ғ**: дҪҝз”Ё git жҸҗдәӨд»Јз ҒпјҢжҸҗдәӨдҝЎжҒҜеә”иҜҘжё…жҷ°жҳҺзЎ®`\n\n\tdoingPath := filepath.Join(tmpDir, \"doing.md\")\n\tif err := os.WriteFile(doingPath, []byte(doingTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create doing template: %v\", err)\n\t}\n\n\t// Create prompt manager\n\tmanager := NewPromptManager(tmpDir)\n\n\t// Create context manager\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\t// Load SPEC\n\tspecContent := \"# Specifications\\n- Use Go language\\n- Support DAG execution\"\n\tcontextMgr.LoadSPECFromContent(specContent)\n\n\t// Load history\n\tcontextMgr.LoadHistory([]string{\"Module 1 completed\", \"Module 2 completed\"})\n\n\t// Create a task\n\ttask := &parser.Task{\n\t\tID:           \"task1\",\n\t\tName:         \"е®һзҺ°жҸҗзӨәиҜҚжһ„е»әеҷЁ\",\n\t\tGoal:         \"е®һзҺ°еҠЁжҖҒжҸҗзӨәиҜҚжһ„е»әеҠҹиғҪ\",\n\t\tKeyResults:   []string{\"е®ҢжҲҗ PromptBuilder зұ»еһӢе®ҡд№ү\", \"е®һзҺ° Build() ж–№жі•\", \"зј–еҶҷеҚ•е…ғжөӢиҜ•\"},\n\t\tTestMethod:   \"иҝҗиЎҢ go test ./internal/prompt\",\n\t\tDependencies: []string{},\n\t}\n\n\t// Generate doing prompt\n\tprompt, err := GenerateDoingPrompt(task, 0, contextMgr, manager)\n\n\tif err != nil {\n\t\tt.Fatalf(\"GenerateDoingPrompt failed: %v\", err)\n\t}\n\n\t// Verify prompt contains task information\n\tif !strings.Contains(prompt, \"task1\") {\n\t\tt.Error(\"Expected prompt to contain task ID\")\n\t}\n\n\tif !strings.Contains(prompt, \"е®һзҺ°жҸҗзӨәиҜҚжһ„е»әеҷЁ\") {\n\t\tt.Error(\"Expected prompt to contain task name\")\n\t}\n\n\tif !strings.Contains(prompt, \"е®һзҺ°еҠЁжҖҒжҸҗзӨәиҜҚжһ„е»әеҠҹиғҪ\") {\n\t\tt.Error(\"Expected prompt to contain task goal\")\n\t}\n\n\t// Verify prompt contains key results\n\tif !strings.Contains(prompt, \"е®ҢжҲҗ PromptBuilder зұ»еһӢе®ҡд№ү\") {\n\t\tt.Error(\"Expected prompt to contain key results\")\n\t}\n\n\t// Verify prompt contains test method\n\tif !strings.Contains(prompt, \"go test\") {\n\t\tt.Error(\"Expected prompt to contain test method\")\n\t}\n\n\t// Verify prompt contains project information\n\tif !strings.Contains(prompt, \"Rick CLI\") {\n\t\tt.Error(\"Expected prompt to contain project name\")\n\t}\n\n\t// Verify prompt contains SPEC information\n\tif !strings.Contains(prompt, \"Use Go language\") {\n\t\tt.Error(\"Expected prompt to contain SPEC information\")\n\t}\n\n\t// Verify prompt contains completed tasks\n\tif !strings.Contains(prompt, \"Module 1 completed\") {\n\t\tt.Error(\"Expected prompt to contain completed tasks\")\n\t}\n}\n\nfunc TestGenerateDoingPrompt_WithRetry(t *testing.T) {\n\t// Create temporary template directory\n\ttmpDir := t.TempDir()\n\n\t// Create doing.md template\n\tdoingTemplate := `# Rick йЎ№зӣ®жү§иЎҢйҳ¶ж®өжҸҗзӨәиҜҚ\n\n## д»»еҠЎдҝЎжҒҜ\n\n**д»»еҠЎ ID**: {{task_id}}\n**д»»еҠЎеҗҚз§°**: {{task_name}}\n**йҮҚиҜ•ж¬Ўж•°**: {{retry_count}}\n\n### д»»еҠЎзӣ®ж Ү\n{{task_objective}}\n\n### е…ій”®з»“жһң\n{{key_results}}\n\n### жөӢиҜ•ж–№жі•\n{{test_methods}}\n\n## йЎ№зӣ®иғҢжҷҜ\n\n**йЎ№зӣ®еҗҚз§°**: {{project_name}}\n**йЎ№зӣ®жҸҸиҝ°**: {{project_description}}\n\n### йЎ№зӣ® SPEC\n{{spec_content}}\n\n### йЎ№зӣ®жһ¶жһ„\n{{project_architecture}}\n\n## жү§иЎҢдёҠдёӢж–Ү\n\n### е·Іе®ҢжҲҗзҡ„д»»еҠЎ\n{{completed_tasks}}\n\n### д»»еҠЎдҫқиө–\n{{task_dependencies}}\n\n### еүҚж¬Ўжү§иЎҢзҡ„й—®йўҳи®°еҪ•\n\nж №жҚ®еүҚж¬Ўжү§иЎҢйҒҮеҲ°зҡ„й—®йўҳпјҢиҜ·йҮҚзӮ№е…іжіЁд»ҘдёӢеҶ…е®№пјҡ\n\n{{debug_context}}`\n\n\tdoingPath := filepath.Join(tmpDir, \"doing.md\")\n\tif err := os.WriteFile(doingPath, []byte(doingTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create doing template: %v\", err)\n\t}\n\n\t// Create prompt manager\n\tmanager := NewPromptManager(tmpDir)\n\n\t// Create context manager\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\t// Load SPEC\n\tspecContent := \"# Specifications\\n- Use Go language\"\n\tcontextMgr.LoadSPECFromContent(specContent)\n\n\t// Load debug information\n\tdebugContent := `# Debug Log\n\n## debug1: зј–иҜ‘й”ҷиҜҜ\n\n**й—®йўҳ**: зјәе°‘еҜје…ҘеҢ…\n**и§ЈеҶіж–№жЎҲ**: ж·»еҠ  import \"fmt\"`\n\tcontextMgr.LoadDebugFromContent(debugContent)\n\n\t// Create a task\n\ttask := &parser.Task{\n\t\tID:           \"task2\",\n\t\tName:         \"е®һзҺ°дёҠдёӢж–Үз®ЎзҗҶеҷЁ\",\n\t\tGoal:         \"е®һзҺ°жү§иЎҢдёҠдёӢж–Үз®ЎзҗҶеҠҹиғҪ\",\n\t\tKeyResults:   []string{\"е®ҢжҲҗ ContextManager зұ»еһӢе®ҡд№ү\", \"е®һзҺ° Load ж–№жі•\"},\n\t\tTestMethod:   \"иҝҗиЎҢ go test ./internal/prompt\",\n\t\tDependencies: []string{\"task1\"},\n\t}\n\n\t// Generate doing prompt with retry\n\tprompt, err := GenerateDoingPrompt(task, 1, contextMgr, manager)\n\n\tif err != nil {\n\t\tt.Fatalf(\"GenerateDoingPrompt failed: %v\", err)\n\t}\n\n\t// Verify retry count is set\n\tif !strings.Contains(prompt, \"1\") {\n\t\tt.Error(\"Expected prompt to contain retry count\")\n\t}\n\n\t// Verify debug context is included\n\tif !strings.Contains(prompt, \"зј–иҜ‘й”ҷиҜҜ\") {\n\t\tt.Error(\"Expected prompt to contain debug information\")\n\t}\n\n\t// Verify task dependency is included\n\tif !strings.Contains(prompt, \"task1\") {\n\t\tt.Error(\"Expected prompt to contain task dependency\")\n\t}\n}\n\nfunc TestGenerateDoingPrompt_NilTask(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tmanager := NewPromptManager(tmpDir)\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\t_, err := GenerateDoingPrompt(nil, 0, contextMgr, manager)\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for nil task\")\n\t}\n\n\tif !strings.Contains(err.Error(), \"task cannot be nil\") {\n\t\tt.Errorf(\"Expected error message about nil task, got: %v\", err)\n\t}\n}\n\nfunc TestGenerateDoingPrompt_NilContextManager(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tmanager := NewPromptManager(tmpDir)\n\ttask := &parser.Task{\n\t\tID:   \"task1\",\n\t\tName: \"Test Task\",\n\t\tGoal: \"Test goal\",\n\t}\n\n\t_, err := GenerateDoingPrompt(task, 0, nil, manager)\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for nil context manager\")\n\t}\n\n\tif !strings.Contains(err.Error(), \"context manager cannot be nil\") {\n\t\tt.Errorf(\"Expected error message about nil context manager, got: %v\", err)\n\t}\n}\n\nfunc TestGenerateDoingPrompt_NilPromptManager(t *testing.T) {\n\tcontextMgr := NewContextManager(\"job_1\")\n\ttask := &parser.Task{\n\t\tID:   \"task1\",\n\t\tName: \"Test Task\",\n\t\tGoal: \"Test goal\",\n\t}\n\n\t_, err := GenerateDoingPrompt(task, 0, contextMgr, nil)\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for nil prompt manager\")\n\t}\n\n\tif !strings.Contains(err.Error(), \"prompt manager cannot be nil\") {\n\t\tt.Errorf(\"Expected error message about nil prompt manager, got: %v\", err)\n\t}\n}\n\nfunc TestGenerateDoingPrompt_MissingTemplate(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tmanager := NewPromptManager(tmpDir)\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\ttask := &parser.Task{\n\t\tID:   \"task1\",\n\t\tName: \"Test Task\",\n\t\tGoal: \"Test goal\",\n\t}\n\n\t_, err := GenerateDoingPrompt(task, 0, contextMgr, manager)\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for missing template\")\n\t}\n\n\tif !strings.Contains(err.Error(), \"failed to load doing template\") {\n\t\tt.Errorf(\"Expected error message about missing template, got: %v\", err)\n\t}\n}\n\nfunc TestGenerateDoingPrompt_WithDependencies(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tdoingTemplate := `# Rick йЎ№зӣ®жү§иЎҢйҳ¶ж®өжҸҗзӨәиҜҚ\n\n## д»»еҠЎдҝЎжҒҜ\n\n**д»»еҠЎ ID**: {{task_id}}\n**д»»еҠЎеҗҚз§°**: {{task_name}}\n\n### д»»еҠЎзӣ®ж Ү\n{{task_objective}}\n\n### д»»еҠЎдҫқиө–\n{{task_dependencies}}`\n\n\tdoingPath := filepath.Join(tmpDir, \"doing.md\")\n\tif err := os.WriteFile(doingPath, []byte(doingTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create doing template: %v\", err)\n\t}\n\n\tmanager := NewPromptManager(tmpDir)\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\ttask := &parser.Task{\n\t\tID:             \"task3\",\n\t\tName:           \"Test Task\",\n\t\tGoal:           \"Test goal\",\n\t\tDependencies:   []string{\"task1\", \"task2\"},\n\t\tKeyResults:     []string{},\n\t\tTestMethod:     \"\",\n\t}\n\n\tprompt, err := GenerateDoingPrompt(task, 0, contextMgr, manager)\n\n\tif err != nil {\n\t\tt.Fatalf(\"GenerateDoingPrompt failed: %v\", err)\n\t}\n\n\t// Verify task dependencies are included\n\tif !strings.Contains(prompt, \"task1\") || !strings.Contains(prompt, \"task2\") {\n\t\tt.Error(\"Expected prompt to contain all task dependencies\")\n\t}\n\n\tif !strings.Contains(prompt, \"иҜҘд»»еҠЎдҫқиө–д»ҘдёӢд»»еҠЎзҡ„е®ҢжҲҗ\") {\n\t\tt.Error(\"Expected prompt to contain dependency header\")\n\t}\n}\n\nfunc TestGenerateDoingPrompt_NoKeyResults(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tdoingTemplate := `# Rick йЎ№зӣ®жү§иЎҢйҳ¶ж®өжҸҗзӨәиҜҚ\n\n### е…ій”®з»“жһң\n{{key_results}}`\n\n\tdoingPath := filepath.Join(tmpDir, \"doing.md\")\n\tif err := os.WriteFile(doingPath, []byte(doingTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create doing template: %v\", err)\n\t}\n\n\tmanager := NewPromptManager(tmpDir)\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\ttask := &parser.Task{\n\t\tID:           \"task1\",\n\t\tName:         \"Test Task\",\n\t\tGoal:         \"Test goal\",\n\t\tKeyResults:   []string{},\n\t\tTestMethod:   \"\",\n\t\tDependencies: []string{},\n\t}\n\n\tprompt, err := GenerateDoingPrompt(task, 0, contextMgr, manager)\n\n\tif err != nil {\n\t\tt.Fatalf(\"GenerateDoingPrompt failed: %v\", err)\n\t}\n\n\tif !strings.Contains(prompt, \"жҡӮж— е…ій”®з»“жһң\") {\n\t\tt.Error(\"Expected prompt to contain 'no key results' message\")\n\t}\n}\n\nfunc TestGenerateDoingPrompt_CompleteFlow(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tdoingTemplate := `# Rick йЎ№зӣ®жү§иЎҢйҳ¶ж®өжҸҗзӨәиҜҚ\n\n## д»»еҠЎдҝЎжҒҜ\n\n**д»»еҠЎ ID**: {{task_id}}\n**д»»еҠЎеҗҚз§°**: {{task_name}}\n**йҮҚиҜ•ж¬Ўж•°**: {{retry_count}}\n\n### д»»еҠЎзӣ®ж Ү\n{{task_objective}}\n\n### е…ій”®з»“жһң\n{{key_results}}\n\n### жөӢиҜ•ж–№жі•\n{{test_methods}}\n\n## йЎ№зӣ®иғҢжҷҜ\n\n**йЎ№зӣ®еҗҚз§°**: {{project_name}}\n**йЎ№зӣ®жҸҸиҝ°**: {{project_description}}\n\n### йЎ№зӣ® SPEC\n{{spec_content}}\n\n### йЎ№зӣ®жһ¶жһ„\n{{project_architecture}}\n\n## жү§иЎҢдёҠдёӢж–Ү\n\n### е·Іе®ҢжҲҗзҡ„д»»еҠЎ\n{{completed_tasks}}\n\n### д»»еҠЎдҫқиө–\n{{task_dependencies}}`\n\n\tdoingPath := filepath.Join(tmpDir, \"doing.md\")\n\tif err := os.WriteFile(doingPath, []byte(doingTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create doing template: %v\", err)\n\t}\n\n\tmanager := NewPromptManager(tmpDir)\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\t// Load SPEC\n\tspecContent := \"# Specifications\\n- Use Go language\\n- Support DAG execution\"\n\tcontextMgr.LoadSPECFromContent(specContent)\n\n\t// Load history\n\tcontextMgr.LoadHistory([]string{\"Infrastructure module completed\", \"Parser module completed\"})\n\n\ttask := &parser.Task{\n\t\tID:           \"task1\",\n\t\tName:         \"е®һзҺ°жҸҗзӨәиҜҚжһ„е»әеҷЁ\",\n\t\tGoal:         \"е®һзҺ°еҠЁжҖҒжҸҗзӨәиҜҚжһ„е»әеҠҹиғҪ\",\n\t\tKeyResults:   []string{\"е®ҢжҲҗ PromptBuilder зұ»еһӢе®ҡд№ү\", \"е®һзҺ° Build() ж–№жі•\", \"зј–еҶҷеҚ•е…ғжөӢиҜ•\"},\n\t\tTestMethod:   \"иҝҗиЎҢ go test ./internal/prompt\",\n\t\tDependencies: []string{},\n\t}\n\n\tprompt, err := GenerateDoingPrompt(task, 0, contextMgr, manager)\n\n\tif err != nil {\n\t\tt.Fatalf(\"GenerateDoingPrompt failed: %v\", err)\n\t}\n\n\t// Comprehensive verification\n\trequiredContent := []string{\n\t\t\"task1\",\n\t\t\"е®һзҺ°жҸҗзӨәиҜҚжһ„е»әеҷЁ\",\n\t\t\"е®һзҺ°еҠЁжҖҒжҸҗзӨәиҜҚжһ„е»әеҠҹиғҪ\",\n\t\t\"е®ҢжҲҗ PromptBuilder зұ»еһӢе®ҡд№ү\",\n\t\t\"е®һзҺ° Build() ж–№жі•\",\n\t\t\"зј–еҶҷеҚ•е…ғжөӢиҜ•\",\n\t\t\"go test\",\n\t\t\"Rick CLI\",\n\t\t\"Context-First AI Coding Framework\",\n\t\t\"Use Go language\",\n\t\t\"Support DAG execution\",\n\t\t\"Infrastructure module completed\",\n\t\t\"Parser module completed\",\n\t\t\"иҜҘд»»еҠЎж— дҫқиө–е…ізі»\",\n\t}\n\n\tfor _, content := range requiredContent {\n\t\tif !strings.Contains(prompt, content) {\n\t\t\tt.Errorf(\"Expected prompt to contain: %s\", content)\n\t\t}\n\t}\n}\n"},"name":"Write","id":"toolu_bdrk_013L8diPb6sHcdLq2Rey33E6","type":"tool_use"}],"context_management":null},"parent_tool_use_id":null,"session_id":"31db7691-f921-4766-a6a9-1cd86dff7cea","uuid":"1d51ec88-1ecc-4f4e-95fb-d308968e8bd3"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_013L8diPb6sHcdLq2Rey33E6","type":"tool_result","content":"File created successfully at: /Users/sunquan/ai_coding/CODING/rick/internal/prompt/doing_prompt_test.go"}]},"parent_tool_use_id":null,"session_id":"31db7691-f921-4766-a6a9-1cd86dff7cea","uuid":"52a9167b-8011-43c2-a80c-9191ac233c01","tool_use_result":{"type":"create","filePath":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/doing_prompt_test.go","content":"package prompt\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/sunquan/rick/internal/parser\"\n)\n\nfunc TestGenerateDoingPrompt_Success(t *testing.T) {\n\t// Create temporary template directory\n\ttmpDir := t.TempDir()\n\n\t// Create doing.md template\n\tdoingTemplate := `# Rick йЎ№зӣ®жү§иЎҢйҳ¶ж®өжҸҗзӨәиҜҚ\n\nдҪ жҳҜдёҖдёӘиө„ж·ұзҡ„иҪҜд»¶е·ҘзЁӢеёҲгҖӮдҪ зҡ„д»»еҠЎжҳҜжү§иЎҢи§„еҲ’еҘҪзҡ„д»»еҠЎпјҢе®ҢжҲҗе…·дҪ“зҡ„зј–з Ғе·ҘдҪңгҖӮ\n\n## д»»еҠЎдҝЎжҒҜ\n\n**д»»еҠЎ ID**: {{task_id}}\n**д»»еҠЎеҗҚз§°**: {{task_name}}\n**йҮҚиҜ•ж¬Ўж•°**: {{retry_count}}\n\n### д»»еҠЎзӣ®ж Ү\n{{task_objective}}\n\n### е…ій”®з»“жһң\n{{key_results}}\n\n### жөӢиҜ•ж–№жі•\n{{test_methods}}\n\n## йЎ№зӣ®иғҢжҷҜ\n\n**йЎ№зӣ®еҗҚз§°**: {{project_name}}\n**йЎ№зӣ®жҸҸиҝ°**: {{project_description}}\n\n### йЎ№зӣ® SPEC\n{{spec_content}}\n\n### йЎ№зӣ®жһ¶жһ„\n{{project_architecture}}\n\n## жү§иЎҢдёҠдёӢж–Ү\n\n### е·Іе®ҢжҲҗзҡ„д»»еҠЎ\n{{completed_tasks}}\n\n### д»»еҠЎдҫқиө–\n{{task_dependencies}}\n\n{{#if retry_count > 0}}\n### еүҚж¬Ўжү§иЎҢзҡ„й—®йўҳи®°еҪ•\n\nж №жҚ®еүҚж¬Ўжү§иЎҢйҒҮеҲ°зҡ„й—®йўҳпјҢиҜ·йҮҚзӮ№е…іжіЁд»ҘдёӢеҶ…е®№пјҡ\n\n{{debug_context}}\n\nиҜ·зЎ®дҝқиҝҷж¬Ўжү§иЎҢиғҪеӨҹи§ЈеҶід№ӢеүҚйҒҮеҲ°зҡ„й—®йўҳгҖӮ\n{{/if}}\n\n## жү§иЎҢиҰҒжұӮ\n\n1. **зҗҶи§ЈйңҖжұӮ**: д»”з»Ҷйҳ…иҜ»д»»еҠЎзӣ®ж Үе’Ңе…ій”®з»“жһң\n2. **и®ҫи®Ўж–№жЎҲ**: ж №жҚ®йЎ№зӣ®жһ¶жһ„е’ҢзҺ°жңүд»Јз ҒпјҢи®ҫи®Ўе®һзҺ°ж–№жЎҲ\n3. **зј–еҶҷд»Јз Ғ**: е®һзҺ°жүҖжңүеҝ…иҰҒзҡ„еҠҹиғҪ\n4. **жөӢиҜ•йӘҢиҜҒ**: жҢүз…§жөӢиҜ•ж–№жі•йӘҢиҜҒеҠҹиғҪзҡ„жӯЈзЎ®жҖ§\n5. **жҸҗдәӨд»Јз Ғ**: дҪҝз”Ё git жҸҗдәӨд»Јз ҒпјҢжҸҗдәӨдҝЎжҒҜеә”иҜҘжё…жҷ°жҳҺзЎ®`\n\n\tdoingPath := filepath.Join(tmpDir, \"doing.md\")\n\tif err := os.WriteFile(doingPath, []byte(doingTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create doing template: %v\", err)\n\t}\n\n\t// Create prompt manager\n\tmanager := NewPromptManager(tmpDir)\n\n\t// Create context manager\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\t// Load SPEC\n\tspecContent := \"# Specifications\\n- Use Go language\\n- Support DAG execution\"\n\tcontextMgr.LoadSPECFromContent(specContent)\n\n\t// Load history\n\tcontextMgr.LoadHistory([]string{\"Module 1 completed\", \"Module 2 completed\"})\n\n\t// Create a task\n\ttask := &parser.Task{\n\t\tID:           \"task1\",\n\t\tName:         \"е®һзҺ°жҸҗзӨәиҜҚжһ„е»әеҷЁ\",\n\t\tGoal:         \"е®һзҺ°еҠЁжҖҒжҸҗзӨәиҜҚжһ„е»әеҠҹиғҪ\",\n\t\tKeyResults:   []string{\"е®ҢжҲҗ PromptBuilder зұ»еһӢе®ҡд№ү\", \"е®һзҺ° Build() ж–№жі•\", \"зј–еҶҷеҚ•е…ғжөӢиҜ•\"},\n\t\tTestMethod:   \"иҝҗиЎҢ go test ./internal/prompt\",\n\t\tDependencies: []string{},\n\t}\n\n\t// Generate doing prompt\n\tprompt, err := GenerateDoingPrompt(task, 0, contextMgr, manager)\n\n\tif err != nil {\n\t\tt.Fatalf(\"GenerateDoingPrompt failed: %v\", err)\n\t}\n\n\t// Verify prompt contains task information\n\tif !strings.Contains(prompt, \"task1\") {\n\t\tt.Error(\"Expected prompt to contain task ID\")\n\t}\n\n\tif !strings.Contains(prompt, \"е®һзҺ°жҸҗзӨәиҜҚжһ„е»әеҷЁ\") {\n\t\tt.Error(\"Expected prompt to contain task name\")\n\t}\n\n\tif !strings.Contains(prompt, \"е®һзҺ°еҠЁжҖҒжҸҗзӨәиҜҚжһ„е»әеҠҹиғҪ\") {\n\t\tt.Error(\"Expected prompt to contain task goal\")\n\t}\n\n\t// Verify prompt contains key results\n\tif !strings.Contains(prompt, \"е®ҢжҲҗ PromptBuilder зұ»еһӢе®ҡд№ү\") {\n\t\tt.Error(\"Expected prompt to contain key results\")\n\t}\n\n\t// Verify prompt contains test method\n\tif !strings.Contains(prompt, \"go test\") {\n\t\tt.Error(\"Expected prompt to contain test method\")\n\t}\n\n\t// Verify prompt contains project information\n\tif !strings.Contains(prompt, \"Rick CLI\") {\n\t\tt.Error(\"Expected prompt to contain project name\")\n\t}\n\n\t// Verify prompt contains SPEC information\n\tif !strings.Contains(prompt, \"Use Go language\") {\n\t\tt.Error(\"Expected prompt to contain SPEC information\")\n\t}\n\n\t// Verify prompt contains completed tasks\n\tif !strings.Contains(prompt, \"Module 1 completed\") {\n\t\tt.Error(\"Expected prompt to contain completed tasks\")\n\t}\n}\n\nfunc TestGenerateDoingPrompt_WithRetry(t *testing.T) {\n\t// Create temporary template directory\n\ttmpDir := t.TempDir()\n\n\t// Create doing.md template\n\tdoingTemplate := `# Rick йЎ№зӣ®жү§иЎҢйҳ¶ж®өжҸҗзӨәиҜҚ\n\n## д»»еҠЎдҝЎжҒҜ\n\n**д»»еҠЎ ID**: {{task_id}}\n**д»»еҠЎеҗҚз§°**: {{task_name}}\n**йҮҚиҜ•ж¬Ўж•°**: {{retry_count}}\n\n### д»»еҠЎзӣ®ж Ү\n{{task_objective}}\n\n### е…ій”®з»“жһң\n{{key_results}}\n\n### жөӢиҜ•ж–№жі•\n{{test_methods}}\n\n## йЎ№зӣ®иғҢжҷҜ\n\n**йЎ№зӣ®еҗҚз§°**: {{project_name}}\n**йЎ№зӣ®жҸҸиҝ°**: {{project_description}}\n\n### йЎ№зӣ® SPEC\n{{spec_content}}\n\n### йЎ№зӣ®жһ¶жһ„\n{{project_architecture}}\n\n## жү§иЎҢдёҠдёӢж–Ү\n\n### е·Іе®ҢжҲҗзҡ„д»»еҠЎ\n{{completed_tasks}}\n\n### д»»еҠЎдҫқиө–\n{{task_dependencies}}\n\n### еүҚж¬Ўжү§иЎҢзҡ„й—®йўҳи®°еҪ•\n\nж №жҚ®еүҚж¬Ўжү§иЎҢйҒҮеҲ°зҡ„й—®йўҳпјҢиҜ·йҮҚзӮ№е…іжіЁд»ҘдёӢеҶ…е®№пјҡ\n\n{{debug_context}}`\n\n\tdoingPath := filepath.Join(tmpDir, \"doing.md\")\n\tif err := os.WriteFile(doingPath, []byte(doingTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create doing template: %v\", err)\n\t}\n\n\t// Create prompt manager\n\tmanager := NewPromptManager(tmpDir)\n\n\t// Create context manager\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\t// Load SPEC\n\tspecContent := \"# Specifications\\n- Use Go language\"\n\tcontextMgr.LoadSPECFromContent(specContent)\n\n\t// Load debug information\n\tdebugContent := `# Debug Log\n\n## debug1: зј–иҜ‘й”ҷиҜҜ\n\n**й—®йўҳ**: зјәе°‘еҜје…ҘеҢ…\n**и§ЈеҶіж–№жЎҲ**: ж·»еҠ  import \"fmt\"`\n\tcontextMgr.LoadDebugFromContent(debugContent)\n\n\t// Create a task\n\ttask := &parser.Task{\n\t\tID:           \"task2\",\n\t\tName:         \"е®һзҺ°дёҠдёӢж–Үз®ЎзҗҶеҷЁ\",\n\t\tGoal:         \"е®һзҺ°жү§иЎҢдёҠдёӢж–Үз®ЎзҗҶеҠҹиғҪ\",\n\t\tKeyResults:   []string{\"е®ҢжҲҗ ContextManager зұ»еһӢе®ҡд№ү\", \"е®һзҺ° Load ж–№жі•\"},\n\t\tTestMethod:   \"иҝҗиЎҢ go test ./internal/prompt\",\n\t\tDependencies: []string{\"task1\"},\n\t}\n\n\t// Generate doing prompt with retry\n\tprompt, err := GenerateDoingPrompt(task, 1, contextMgr, manager)\n\n\tif err != nil {\n\t\tt.Fatalf(\"GenerateDoingPrompt failed: %v\", err)\n\t}\n\n\t// Verify retry count is set\n\tif !strings.Contains(prompt, \"1\") {\n\t\tt.Error(\"Expected prompt to contain retry count\")\n\t}\n\n\t// Verify debug context is included\n\tif !strings.Contains(prompt, \"зј–иҜ‘й”ҷиҜҜ\") {\n\t\tt.Error(\"Expected prompt to contain debug information\")\n\t}\n\n\t// Verify task dependency is included\n\tif !strings.Contains(prompt, \"task1\") {\n\t\tt.Error(\"Expected prompt to contain task dependency\")\n\t}\n}\n\nfunc TestGenerateDoingPrompt_NilTask(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tmanager := NewPromptManager(tmpDir)\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\t_, err := GenerateDoingPrompt(nil, 0, contextMgr, manager)\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for nil task\")\n\t}\n\n\tif !strings.Contains(err.Error(), \"task cannot be nil\") {\n\t\tt.Errorf(\"Expected error message about nil task, got: %v\", err)\n\t}\n}\n\nfunc TestGenerateDoingPrompt_NilContextManager(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tmanager := NewPromptManager(tmpDir)\n\ttask := &parser.Task{\n\t\tID:   \"task1\",\n\t\tName: \"Test Task\",\n\t\tGoal: \"Test goal\",\n\t}\n\n\t_, err := GenerateDoingPrompt(task, 0, nil, manager)\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for nil context manager\")\n\t}\n\n\tif !strings.Contains(err.Error(), \"context manager cannot be nil\") {\n\t\tt.Errorf(\"Expected error message about nil context manager, got: %v\", err)\n\t}\n}\n\nfunc TestGenerateDoingPrompt_NilPromptManager(t *testing.T) {\n\tcontextMgr := NewContextManager(\"job_1\")\n\ttask := &parser.Task{\n\t\tID:   \"task1\",\n\t\tName: \"Test Task\",\n\t\tGoal: \"Test goal\",\n\t}\n\n\t_, err := GenerateDoingPrompt(task, 0, contextMgr, nil)\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for nil prompt manager\")\n\t}\n\n\tif !strings.Contains(err.Error(), \"prompt manager cannot be nil\") {\n\t\tt.Errorf(\"Expected error message about nil prompt manager, got: %v\", err)\n\t}\n}\n\nfunc TestGenerateDoingPrompt_MissingTemplate(t *testing.T) {\n\ttmpDir := t.TempDir()\n\tmanager := NewPromptManager(tmpDir)\n\tcontextMgr := NewContextManager(\"job_1\")\n\n\ttask := &parser.Task{\n\t\tID:   \"task1\",\n\t\tName: \"Test Task\",\n\t\tGoal: \"Test goal\",\n\t}\n\n\t_, err := GenerateDoingPrompt(task, 0, contextMgr, manager)\n\n\tif err == nil {\n\t\tt.Error(\"Expected error for missing template\")\n\t}\n\n\tif !strings.Contains(err.Error(), \"failed to load doing template\") {\n\t\tt.Errorf(\"Expected error message about missing template, got: %v\", err)\n\t}\n}\n\nfunc TestGenerateDoingPrompt_WithDependencies(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\tdoingTemplate := `# Rick йЎ№зӣ®жү§иЎҢйҳ¶ж®өжҸҗзӨәиҜҚ\n\n## д»»еҠЎдҝЎжҒҜ\n\n**д»»еҠЎ ID**: {{task_id}}\n**д»»еҠЎеҗҚз§°**: {{task_name}}\n\n### д»»еҠЎзӣ®ж Ү\n{{task_objective}}\n\n### д»»еҠЎдҫқиө–\n{{task_dependencies}}`\n\n\tdoingPath := filepath.Join(tmpDir, \"doing.md\")\n\tif err := os.WriteFile(doingPath, []byte(doingTemplate), 0644); err != nil {\n\t\tt.Fatalf(\"Failed to create doing template: %v\", err)\n\t}\n\n\tmanager := Ne