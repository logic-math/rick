on))\n\n\t\tif entry.Reproduce != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- еӨҚзҺ°: %s\\n\", entry.Reproduce))\n\t\t}\n\n\t\tif entry.Hypothesis != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- зҢңжғі: %s\\n\", entry.Hypothesis))\n\t\t}\n\n\t\tif entry.Verify != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- йӘҢиҜҒ: %s\\n\", entry.Verify))\n\t\t}\n\n\t\tif entry.Fix != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- дҝ®еӨҚ: %s\\n\", entry.Fix))\n\t\t}\n\n\t\tif entry.Progress != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- иҝӣеұ•: %s\\n\", entry.Progress))\n\t\t}\n\n\t\tcontent.WriteString(\"\\n\")\n\t}\n\n\treturn content.String()\n}","originalFile":"package prompt\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"github.com/sunquan/rick/internal/parser\"\n)\n\n// GenerateDoingPrompt generates the execution phase prompt from a task\n// It includes task information, test methods, and debug context if it's a retry\nfunc GenerateDoingPrompt(task *parser.Task, retryCount int, contextMgr *ContextManager, manager *PromptManager) (string, error) {\n\tif task == nil {\n\t\treturn \"\", fmt.Errorf(\"task cannot be nil\")\n\t}\n\n\tif contextMgr == nil {\n\t\treturn \"\", fmt.Errorf(\"context manager cannot be nil\")\n\t}\n\n\tif manager == nil {\n\t\treturn \"\", fmt.Errorf(\"prompt manager cannot be nil\")\n\t}\n\n\t// Load doing template\n\ttemplate, err := manager.LoadTemplate(\"doing\")\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to load doing template: %w\", err)\n\t}\n\n\t// Create prompt builder\n\tbuilder := NewPromptBuilder(template)\n\n\t// Set task information\n\tbuilder.SetVariable(\"task_id\", task.ID)\n\tbuilder.SetVariable(\"task_name\", task.Name)\n\tbuilder.SetVariable(\"retry_count\", fmt.Sprintf(\"%d\", retryCount))\n\n\t// Set task details\n\tbuilder.SetVariable(\"task_objective\", task.Goal)\n\tbuilder.SetVariable(\"key_results\", formatKeyResults(task.KeyResults))\n\tbuilder.SetVariable(\"test_methods\", task.TestMethod)\n\n\t// Set project information\n\tbuilder.SetVariable(\"project_name\", \"Rick CLI\")\n\tbuilder.SetVariable(\"project_description\", \"Context-First AI Coding Framework\")\n\n\t// Set SPEC content\n\tspecContent := formatSPECContent(contextMgr.GetSPECInfo())\n\tbuilder.SetVariable(\"spec_content\", specContent)\n\n\t// Set project architecture\n\tprojectArch := formatProjectArchitecture()\n\tbuilder.SetVariable(\"project_architecture\", projectArch)\n\n\t// Set completed tasks\n\tcompletedTasks := formatCompletedTasks(contextMgr.GetHistory())\n\tbuilder.SetVariable(\"completed_tasks\", completedTasks)\n\n\t// Set task dependencies\n\ttaskDeps := formatTaskDependencies(task.Dependencies)\n\tbuilder.SetVariable(\"task_dependencies\", taskDeps)\n\n\t// If it's a retry, include debug context\n\tif retryCount > 0 {\n\t\tdebugContext := formatDebugContext(contextMgr.GetDebug())\n\t\tbuilder.SetVariable(\"debug_context\", debugContext)\n\t} else {\n\t\t// For non-retry, set empty debug context\n\t\tbuilder.SetVariable(\"debug_context\", \"\")\n\t}\n\n\t// Build final prompt\n\tprompt, err := builder.Build()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to build doing prompt: %w\", err)\n\t}\n\n\treturn prompt, nil\n}\n\n// formatKeyResults formats key results for the prompt\nfunc formatKeyResults(keyResults []string) string {\n\tif len(keyResults) == 0 {\n\t\treturn \"жҡӮж— е…ій”®з»“жһң\"\n\t}\n\n\tvar content strings.Builder\n\tfor i, kr := range keyResults {\n\t\tcontent.WriteString(fmt.Sprintf(\"%d. %s\\n\", i+1, kr))\n\t}\n\n\treturn content.String()\n}\n\n// formatProjectArchitecture formats project architecture information\nfunc formatProjectArchitecture() string {\n\treturn `Rick йЎ№зӣ®йҮҮз”ЁжЁЎеқ—еҢ–жһ¶жһ„и®ҫи®Ўпјҡ\n\n**ж ёеҝғжЁЎеқ—**:\n- infrastructure: еҹәзЎҖи®ҫж–ҪжЁЎеқ—пјҲGo йЎ№зӣ®еҲқе§ӢеҢ–гҖҒCLIгҖҒе·ҘдҪңз©әй—ҙгҖҒй…ҚзҪ®гҖҒж—Ҙеҝ—пјү\n- parser: еҶ…е®№и§ЈжһҗжЁЎеқ—пјҲMarkdownгҖҒtask.mdгҖҒdebug.mdгҖҒOKR/SPEC и§Јжһҗпјү\n- dag_executor: DAG жү§иЎҢжЁЎеқ—пјҲDAG жһ„е»әгҖҒжӢ“жү‘жҺ’еәҸгҖҒд»»еҠЎжү§иЎҢгҖҒйҮҚиҜ•жңәеҲ¶пјү\n- prompt_manager: жҸҗзӨәиҜҚз®ЎзҗҶжЁЎеқ—пјҲжЁЎжқҝгҖҒжһ„е»әгҖҒдёҠдёӢж–ҮгҖҒеҗ„йҳ¶ж®өжҸҗзӨәиҜҚз”ҹжҲҗпјү\n- cli_commands: е‘Ҫд»ӨеӨ„зҗҶжЁЎеқ—пјҲinitгҖҒplanгҖҒdoingгҖҒlearning е‘Ҫд»Өпјү\n\n**е…ій”®и®ҫи®Ў**:\n- дҪҝз”Ё Go ж ҮеҮҶеә“дёәдё»пјҢжңҖе°ҸеҢ–еӨ–йғЁдҫқиө–\n- жҸҗзӨәиҜҚз®ЎзҗҶжҳҜж ёеҝғеҲӣж–°пјҢж”ҜжҢҒеӨҡйҳ¶ж®өжҸҗзӨәиҜҚз”ҹжҲҗ\n- д»»еҠЎжү§иЎҢйҮҮз”Ё DAG жӢ“жү‘жҺ’еәҸпјҢж”ҜжҢҒе№¶иЎҢе’ҢдёІиЎҢжү§иЎҢ\n- еӨұиҙҘйҮҚиҜ•жңәеҲ¶пјҢи¶…иҝҮйҷҗеҲ¶еҗҺйңҖдәәе·Ҙе№Ійў„`\n}\n\n// formatCompletedTasks formats completed tasks for the prompt\nfunc formatCompletedTasks(history []string) string {\n\tif len(history) == 0 {\n\t\treturn \"жҡӮж— е·Іе®ҢжҲҗзҡ„д»»еҠЎ\"\n\t}\n\n\tvar content strings.Builder\n\tfor _, item := range history {\n\t\tcontent.WriteString(fmt.Sprintf(\"- %s\\n\", item))\n\t}\n\n\treturn content.String()\n}\n\n// formatTaskDependencies formats task dependencies for the prompt\nfunc formatTaskDependencies(dependencies []string) string {\n\tif len(dependencies) == 0 {\n\t\treturn \"иҜҘд»»еҠЎж— дҫқиө–е…ізі»\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(\"иҜҘд»»еҠЎдҫқиө–д»ҘдёӢд»»еҠЎзҡ„е®ҢжҲҗпјҡ\\n\")\n\tfor _, dep := range dependencies {\n\t\tcontent.WriteString(fmt.Sprintf(\"- %s\\n\", dep))\n\t}\n\n\treturn content.String()\n}\n\n// formatDebugContext formats debug information for retry prompts\nfunc formatDebugContext(debugInfo *parser.DebugInfo) string {\n\tif debugInfo == nil || len(debugInfo.Entries) == 0 {\n\t\treturn \"жҡӮж— й—®йўҳи®°еҪ•\"\n\t}\n\n\tvar content strings.Builder\n\tfor i, entry := range debugInfo.Entries {\n\t\tcontent.WriteString(fmt.Sprintf(\"**й—®йўҳ %d: %s**\\n\", i+1, entry.Title))\n\t\tif entry.Description != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"жҸҸиҝ°: %s\\n\", entry.Description))\n\t\t}\n\t\tif entry.Solution != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"и§ЈеҶіж–№жЎҲ: %s\\n\", entry.Solution))\n\t\t}\n\t\tcontent.WriteString(\"\\n\")\n\t}\n\n\treturn content.String()\n}\n","structuredPatch":[{"oldStart":147,"oldLines":14,"newStart":147,"newLines":29,"lines":["   }"," ","   var content strings.Builder","-  for i, entry := range debugInfo.Entries {","-    content.WriteString(fmt.Sprintf(\"**й—®йўҳ %d: %s**\\n\", i+1, entry.Title))","-    if entry.Description != \"\" {","-      content.WriteString(fmt.Sprintf(\"жҸҸиҝ°: %s\\n\", entry.Description))","+  for _, entry := range debugInfo.Entries {","+    content.WriteString(fmt.Sprintf(\"**debug%d: %s**\\n\", entry.ID, entry.Phenomenon))","+","+    if entry.Reproduce != \"\" {","+      content.WriteString(fmt.Sprintf(\"- еӨҚзҺ°: %s\\n\", entry.Reproduce))","     }","-    if entry.Solution != \"\" {","-      content.WriteString(fmt.Sprintf(\"и§ЈеҶіж–№жЎҲ: %s\\n\", entry.Solution))","+","+    if entry.Hypothesis != \"\" {","+      content.WriteString(fmt.Sprintf(\"- зҢңжғі: %s\\n\", entry.Hypothesis))","     }","+","+    if entry.Verify != \"\" {","+      content.WriteString(fmt.Sprintf(\"- йӘҢиҜҒ: %s\\n\", entry.Verify))","+    }","+","+    if entry.Fix != \"\" {","+      content.WriteString(fmt.Sprintf(\"- дҝ®еӨҚ: %s\\n\", entry.Fix))","+    }","+","+    if entry.Progress != \"\" {","+      content.WriteString(fmt.Sprintf(\"- иҝӣеұ•: %s\\n\", entry.Progress))","+    }","+","     content.WriteString(\"\\n\")","   }"," "]}],"userModified":false,"replaceAll":false}},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_8c9c493d-044","type":"message","content":[{"text":"Now I need to update the test file to match the actual DebugEntry structure:","type":"text"}],"context_management":null},"parent_tool_use_id":null,"session_id":"31db7691-f921-4766-a6a9-1cd86dff7cea","uuid":"9e57781c-e54a-44d2-9cdb-2d9463461b3c"},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens"