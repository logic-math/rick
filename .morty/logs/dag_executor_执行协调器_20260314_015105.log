cuteJob executes all tasks in the job\n   107вҶ’// It performs serial execution based on topological order\n   108вҶ’// Returns ExecutionJobResult with overall status and per-task results\n   109вҶ’func (e *Executor) ExecuteJob() (*ExecutionJobResult, error) {\n   110вҶ’\tstartTime := time.Now()\n   111вҶ’\tresult := &ExecutionJobResult{\n   112вҶ’\t\tJobID:       e.jobID,\n   113вҶ’\t\tStartTime:   startTime,\n   114вҶ’\t\tTotalTasks:  len(e.sortedTaskIDs),\n   115вҶ’\t\tTaskResults: make([]*RetryResult, 0),\n   116вҶ’\t}\n   117вҶ’\n   118вҶ’\te.logf(\"Starting job execution: %s\", e.jobID)\n   119вҶ’\te.logf(\"Total tasks: %d\", result.TotalTasks)\n   120вҶ’\te.logf(\"Task execution order: %v\", e.sortedTaskIDs)\n   121вҶ’\n   122вҶ’\t// Save initial tasks.json\n   123вҶ’\tif err := SaveTasksJSON(e.tasksJSONPath, e.tasksJSON); err != nil {\n   124вҶ’\t\te.logf(\"ERROR: Failed to save initial tasks.json: %v\", err)\n   125вҶ’\t\tresult.Status = \"failed\"\n   126вҶ’\t\tresult.ErrorSummary = fmt.Sprintf(\"Failed to save initial tasks.json: %v\", err)\n   127вҶ’\t\tresult.EndTime = time.Now()\n   128вҶ’\t\treturn result, err\n   129вҶ’\t}\n   130вҶ’\n   131вҶ’\t// Execute each task in order\n   132вҶ’\tfor i, taskID := range e.sortedTaskIDs {\n   133вҶ’\t\te.logf(\"[%d/%d] Executing task: %s\", i+1, result.TotalTasks, taskID)\n   134вҶ’\n   135вҶ’\t\t// Update task status to running\n   136вҶ’\t\tif err := e.tasksJSON.UpdateTaskStatus(taskID, \"running\"); err != nil {\n   137вҶ’\t\t\te.logf(\"ERROR: Failed to update task status to running: %v\", err)\n   138вҶ’\t\t}\n   139вҶ’\t\tif err := SaveTasksJSON(e.tasksJSONPath, e.tasksJSON); err != nil {\n   140вҶ’\t\t\te.logf(\"ERROR: Failed to save tasks.json: %v\", err)\n   141вҶ’\t\t}\n   142вҶ’\n   143вҶ’\t\t// Get the task from DAG\n   144вҶ’\t\ttask, exists := e.dag.Tasks[taskID]\n   145вҶ’\t\tif !exists {\n   146вҶ’\t\t\te.logf(\"ERROR: Task not found in DAG: %s\", taskID)\n   147вҶ’\t\t\tif err := e.tasksJSON.UpdateTaskStatusWithError(taskID, \"failed\", \"Task not found in DAG\"); err != nil {\n   148вҶ’\t\t\t\te.logf(\"ERROR: Failed to update task status: %v\", err)\n   149вҶ’\t\t\t}\n   150вҶ’\t\t\tresult.FailedTasks++\n   151вҶ’\t\t\tcontinue\n   152вҶ’\t\t}\n   153вҶ’\n   154вҶ’\t\t// Execute task with retry logic\n   155вҶ’\t\tretryResult, err := e.retryManager.RetryTask(task)\n   156вҶ’\t\tif err != nil {\n   157вҶ’\t\t\te.logf(\"ERROR: Failed to execute task: %v\", err)\n   158вҶ’\t\t\tretryResult = &RetryResult{\n   159вҶ’\t\t\t\tTaskID:        taskID,\n   160вҶ’\t\t\t\tTaskName:      task.Name,\n   161вҶ’\t\t\t\tStatus:        \"failed\",\n   162вҶ’\t\t\t\tLastError:     fmt.Sprintf(\"Execution error: %v\", err),\n   163вҶ’\t\t\t\tStartTime:     time.Now(),\n   164вҶ’\t\t\t\tEndTime:       time.Now(),\n   165вҶ’\t\t\t}\n   166вҶ’\t\t}\n   167вҶ’\n   168вҶ’\t\tresult.TaskResults = append(result.TaskResults, retryResult)\n   169вҶ’\n   170вҶ’\t\t// Update task status based on result\n   171вҶ’\t\tif retryResult.Status == \"success\" {\n   172вҶ’\t\t\te.logf(\"вң“ Task succeeded: %s (attempts: %d)\", taskID, retryResult.TotalAttempts)\n   173вҶ’\t\t\tif err := e.tasksJSON.UpdateTaskStatus(taskID, \"success\"); err != nil {\n   174вҶ’\t\t\t\te.logf(\"ERROR: Failed to update task status: %v\", err)\n   175вҶ’\t\t\t}\n   176вҶ’\t\t\tresult.SuccessfulTasks++\n   177вҶ’\t\t} else {\n   178вҶ’\t\t\te.logf(\"вң— Task failed: %s (status: %s, attempts: %d)\", taskID, retryResult.Status, retryResult.TotalAttempts)\n   179вҶ’\t\t\tif err := e.tasksJSON.UpdateTaskStatusWithError(taskID, \"failed\", retryResult.LastError); err != nil {\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"p