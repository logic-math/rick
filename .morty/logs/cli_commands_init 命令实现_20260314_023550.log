figPath = oldGetConfigPath\n\t}()\n\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn filepath.Join(rickDir, \"config.json\"), nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Read .gitignore\n\tgitignorePath := filepath.Join(rickDir, \".gitignore\")\n\tcontent, err := os.ReadFile(gitignorePath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read .gitignore: %v\", err)\n\t}\n\n\tcontentStr := string(content)\n\tif contentStr == \"\" {\n\t\tt.Error(\".gitignore is empty\")\n\t}\n\n\t// Check for expected entries\n\texpectedEntries := []string{\"*.log\", \".DS_Store\"}\n\tfor _, entry := range expectedEntries {\n\t\tif !contains(contentStr, entry) {\n\t\t\tt.Errorf(\"expected .gitignore to contain %q, but it doesn't\", entry)\n\t\t}\n\t}\n}\n\n// Helper function to check if string contains substring\nfunc contains(s, substr string) bool {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n","structuredPatch":[{"oldStart":64,"oldLines":403,"newStart":64,"newLines":70,"lines":["   }"," }"," ","-// TestInitCmdCreatesWorkspace tests that init creates the workspace structure","-func TestInitCmdCreatesWorkspace(t *testing.T) {","-  // Create a temporary home directory for testing","-  tmpHome := t.TempDir()","-","-  // Override GetRickDir to use temp directory","-  oldGetRickDir := workspace.GetRickDir","-  defer func() {","-    workspace.GetRickDir = oldGetRickDir","-  }()","-","-  workspace.GetRickDir = func() (string, error) {","-    return filepath.Join(tmpHome, \".rick\"), nil","-  }","-","-  // Override config path to use temp directory","-  oldGetConfigPath := config.GetConfigPath","-  defer func() {","-    config.GetConfigPath = oldGetConfigPath","-  }()","-","-  config.GetConfigPath = func() (string, error) {","-    return filepath.Join(tmpHome, \".rick\", \"config.json\"