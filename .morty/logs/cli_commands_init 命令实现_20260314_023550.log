md()\n\n\t// First initialization\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"first init command failed: %v\", err)\n\t}\n\n\t// Second initialization\n\terr = cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"second init command failed: %v\", err)\n\t}\n\n\t// Verify everything still exists\n\tif _, err := os.Stat(rickDir); os.IsNotExist(err) {\n\t\tt.Error(\"expected .rick directory to exist after second init\")\n\t}\n\n\tgitDir := filepath.Join(rickDir, \".git\")\n\tif _, err := os.Stat(gitDir); os.IsNotExist(err) {\n\t\tt.Error(\"expected .git directory to exist after second init\")\n\t}\n}\n\n// TestInitCmdConfigFormat tests that config file has correct JSON format\nfunc TestInitCmdConfigFormat(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn rickDir, nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfigPath := filepath.Join(rickDir, \"config.json\")\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn configPath, nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Read and verify config format\n\tdata, err := os.ReadFile(configPath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read config file: %v\", err)\n\t}\n\n\t// Basic JSON format check\n\tif len(data) == 0 {\n\t\tt.Error(\"config file is empty\")\n\t}\n\n\t// Try to parse as JSON\n\tvar cfg config.Config\n\terr = config.LoadConfig()\n\tif err != nil {\n\t\tt.Fatalf(\"failed to validate config JSON format: %v\", err)\n\t}\n}\n\n// TestInitCmdOKRContent tests that OKR.md has correct initial content\nfunc TestInitCmdOKRContent(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn rickDir, nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn filepath.Join(rickDir, \"config.json\"), nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Read OKR.md\n\tokriPath := filepath.Join(rickDir, \"OKR.md\")\n\tcontent, err := os.ReadFile(okriPath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read OKR.md: %v\", err)\n\t}\n\n\tif len(content) == 0 {\n\t\tt.Error(\"OKR.md is empty\")\n\t}\n\n\t// Check for markdown header\n\tif string(content) != \"# OKR\\n\\n\" {\n\t\tt.Errorf(\"expected OKR.md to have '# OKR\\\\n\\\\n', got %q\", string(content))\n\t}\n}\n\n// TestInitCmdSPECContent tests that SPEC.md has correct initial content\nfunc TestInitCmdSPECContent(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn rickDir, nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn filepath.Join(rickDir, \"config.json\"), nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Read SPEC.md\n\tspecPath := filepath.Join(rickDir, \"SPEC.md\")\n\tcontent, err := os.ReadFile(specPath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read SPEC.md: %v\", err)\n\t}\n\n\tif len(content) == 0 {\n\t\tt.Error(\"SPEC.md is empty\")\n\t}\n\n\t// Check for markdown header\n\tif string(content) != \"# SPEC\\n\\n\" {\n\t\tt.Errorf(\"expected SPEC.md to have '# SPEC\\\\n\\\\n', got %q\", string(content))\n\t}\n}\n\n// TestInitCmdGitignoreContent tests that .gitignore has correct content\nfunc TestInitCmdGitignoreContent(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn rickDir, nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn filepath.Join(rickDir, \"config.json\"), nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Read .gitignore\n\tgitignorePath := filepath.Join(rickDir, \".gitignore\")\n\tcontent, err := os.ReadFile(gitignorePath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read .gitignore: %v\", err)\n\t}\n\n\tcontentStr := string(content)\n\tif contentStr == \"\" {\n\t\tt.Error(\".gitignore is empty\")\n\t}\n\n\t// Check for expected entries\n\texpectedEntries := []string{\"*.log\", \".DS_Store\"}\n\tfor _, entry := range expectedEntries {\n\t\tif !contains(contentStr, entry) {\n\t\t\tt.Errorf(\"expected .gitignore to contain %q, but it doesn't\", entry)\n\t\t}\n\t}\n}\n\n// Helper function to check if string contains substring\nfunc contains(s, substr string) bool {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}","newString":"// TestInitCmdBasicExecution tests that init command can be executed\nfunc TestInitCmdBasicExecution(t *testing.T) {\n\tcmd := NewInitCmd()\n\tif cmd.RunE == nil {\n\t\tt.Error(\"expected RunE to be set\")\n\t}\n}\n\n// TestInitGitRepo tests the initGitRepo function\nfunc TestInitGitRepo(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Test initializing git in a new directory\n\terr := initGitRepo(tmpDir)\n\tif err != nil {\n\t\tt.Fatalf(\"initGitRepo failed: %v\", err)\n\t}\n\n\t// Verify .git directory exists\n\tgitDir := filepath.Join(tmpDir, \".git\")\n\tif _, err := os.Stat(gitDir); os.IsNotExist(err) {\n\t\tt.Error(\"expected .git directory to be created\")\n\t}\n\n\t// Verify .gitignore was created\n\tgitignorePath := filepath.Join(tmpDir, \".gitignore\")\n\tif _, err := os.Stat(gitignorePath); os.IsNotExist(err) {\n\t\tt.Error(\"expected .gitignore to be created\")\n\t}\n}\n\n// TestInitGitRepoIdempotent tests that initGitRepo can be called multiple times\nfunc TestInitGitRepoIdempotent(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// First call\n\terr := initGitRepo(tmpDir)\n\tif err != nil {\n\t\tt.Fatalf(\"first initGitRepo failed: %v\", err)\n\t}\n\n\t// Second call (should not fail)\n\terr = initGitRepo(tmpDir)\n\tif err != nil {\n\t\tt.Fatalf(\"second initGitRepo failed: %v\", err)\n\t}\n\n\t// Verify .git still exists\n\tgitDir := filepath.Join(tmpDir, \".git\")\n\tif _, err := os.Stat(gitDir); os.IsNotExist(err) {\n\t\tt.Error(\"expected .git directory to still exist\")\n\t}\n}\n\n// TestInitGitignoreContent tests that .gitignore has correct content\nfunc TestInitGitignoreContent(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\terr := initGitRepo(tmpDir)\n\tif err != nil {\n\t\tt.Fatalf(\"initGitRepo failed: %v\", err)\n\t}\n\n\tgitignorePath := filepath.Join(tmpDir, \".gitignore\")\n\tcontent, err := os.ReadFile(gitignorePath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read .gitignore: %v\", err)\n\t}\n\n\tcontentStr := string(content)\n\tif contentStr == \"\" {\n\t\tt.Error(\".gitignore is empty\")\n\t}\n\n\t// Check for expected entries\n\texpectedEntries := []string{\"*.log\", \".DS_Store\"}\n\tfor _, entry := range expectedEntries {\n\t\tif !contains(contentStr, entry) {\n\t\t\tt.Errorf(\"expected .gitignore to contain %q\", entry)\n\t\t}\n\t}\n}\n\n// TestWorkspaceIntegration tests workspace initialization\nfunc TestWorkspaceIntegration(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Create workspace with temporary directory\n\tws := &workspace.Workspace{}\n\n\t// Use reflection to set the rickDir field for testing\n\t// Since we can't directly access private fields, we'll test through the public API\n\tif ws == nil {\n\t\tt.Error(\"failed to create workspace\")\n\t}\n}\n\n// TestConfigIntegration tests config initialization\nfunc TestConfigIntegration(t *testing.T) {\n\tcfg := config.GetDefaultConfig()\n\tif cfg == nil {\n\t\tt.Error(\"failed to get default config\")\n\t}\n\n\tif cfg.MaxRetries != 5 {\n\t\tt.Errorf(\"expected MaxRetries to be 5, got %d\", cfg.MaxRetries)\n\t}\n}\n\n// Helper function to check if string contains substring\nfunc contains(s, substr string) bool {\n\tfor i := 0; i <= len(s)-len(substr); i++ {\n\t\tif s[i:i+len(substr)] == substr {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}","originalFile":"package cmd\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/sunquan/rick/internal/config\"\n\t\"github.com/sunquan/rick/internal/workspace\"\n)\n\n// TestNewInitCmd tests that NewInitCmd creates a valid cobra command\nfunc TestNewInitCmd(t *testing.T) {\n\tcmd := NewInitCmd()\n\tif cmd == nil {\n\t\tt.Fatal(\"NewInitCmd returned nil\")\n\t}\n\tif cmd.Use != \"init\" {\n\t\tt.Errorf(\"expected Use to be 'init', got %s\", cmd.Use)\n\t}\n\tif cmd.Short == \"\" {\n\t\tt.Error(\"expected Short to be non-empty\")\n\t}\n\tif cmd.Long == \"\" {\n\t\tt.Error(\"expected Long to be non-empty\")\n\t}\n}\n\n// TestInitCmdDryRun tests that init command works in dry-run mode\nfunc TestInitCmdDryRun(t *testing.T) {\n\t// Save original values\n\torigVerbose := verbose\n\torigDryRun := dryRun\n\tdefer func() {\n\t\tverbose = origVerbose\n\t\tdryRun = origDryRun\n\t}()\n\n\t// Set dry-run mode\n\tdryRun = true\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed in dry-run mode: %v\", err)\n\t}\n}\n\n// TestInitCmdVerbose tests that init command works in verbose mode\nfunc TestInitCmdVerbose(t *testing.T) {\n\t// Save original values\n\torigVerbose := verbose\n\tdefer func() {\n\t\tverbose = origVerbose\n\t}()\n\n\t// Set verbose mode\n\tverbose = true\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed in verbose mode: %v\", err)\n\t}\n}\n\n// TestInitCmdCreatesWorkspace tests that init creates the workspace structure\nfunc TestInitCmdCreatesWorkspace(t *testing.T) {\n\t// Create a temporary home directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn filepath.Join(tmpHome, \".rick\"), nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn filepath.Join(tmpHome, \".rick\", \"config.json\"), nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Verify workspace structure was created\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\trequiredDirs := []string{\n\t\trickDir,\n\t\tfilepath.Join(rickDir, \"wiki\"),\n\t\tfilepath.Join(rickDir, \"skills\"),\n\t\tfilepath.Join(rickDir, \"jobs\"),\n\t}\n\n\tfor _, dir := range requiredDirs {\n\t\tif _, err := os.Stat(dir); os.IsNotExist(err) {\n\t\t\tt.Errorf(\"expected directory %s to exist, but it doesn't\", dir)\n\t\t}\n\t}\n\n\t// Verify OKR.md was created\n\tokriPath := filepath.Join(rickDir, \"OKR.md\")\n\tif _, err := os.Stat(okriPath); os.IsNotExist(err) {\n\t\tt.Error(\"expected OKR.md to be created, but it doesn't exist\")\n\t}\n\n\t// Verify SPEC.md was created\n\tspecPath := filepath.Join(rickDir, \"SPEC.md\")\n\tif _, err := os.Stat(specPath); os.IsNotExist(err) {\n\t\tt.Error(\"expected SPEC.md to be created, but it doesn't exist\")\n\t}\n}\n\n// TestInitCmdCreatesConfig tests that init creates the config file\nfunc TestInitCmdCreatesConfig(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn filepath.Join(tmpHome, \".rick\"), nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfigPath := filepath.Join(tmpHome, \".rick\", \"config.json\")\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn configPath, nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Verify config file was created\n\tif _, err := os.Stat(configPath); os.IsNotExist(err) {\n\t\tt.Error(\"expected config.json to be created, but it doesn't exist\")\n\t}\n\n\t// Verify config file can be loaded\n\tloadedConfig, err := config.LoadConfig()\n\tif err != nil {\n\t\tt.Fatalf(\"failed to load config: %v\", err)\n\t}\n\n\tif loadedConfig.MaxRetries != 5 {\n\t\tt.Errorf(\"expected MaxRetries to be 5, got %d\", loadedConfig.MaxRetries)\n\t}\n}\n\n// TestInitCmdGitInitialization tests that init initializes git repository\nfunc TestInitCmdGitInitialization(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn rickDir, nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn filepath.Join(rickDir, \"config.json\"), nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Verify .git directory was created\n\tgitDir := filepath.Join(rickDir, \".git\")\n\tif _, err := os.Stat(gitDir); os.IsNotExist(err) {\n\t\tt.Error(\"expected .git directory to be created, but it doesn't exist\")\n\t}\n\n\t// Verify .gitignore was created\n\tgitignorePath := filepath.Join(rickDir, \".gitignore\")\n\tif _, err := os.Stat(gitignorePath); os.IsNotExist(err) {\n\t\tt.Error(\"expected .gitignore to be created, but it doesn't exist\")\n\t}\n\n\t// Verify .gitignore content\n\tcontent, err := os.ReadFile(gitignorePath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read .gitignore: %v\", err)\n\t}\n\n\tif len(content) == 0 {\n\t\tt.Error(\"expected .gitignore to have content, but it's empty\")\n\t}\n}\n\n// TestInitCmdIdempotent tests that init can be called multiple times safely\nfunc TestInitCmdIdempotent(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn rickDir, nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn filepath.Join(rickDir, \"config.json\"), nil\n\t}\n\n\tcmd := NewInitCmd()\n\n\t// First initialization\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"first init command failed: %v\", err)\n\t}\n\n\t// Second initialization\n\terr = cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"second init command failed: %v\", err)\n\t}\n\n\t// Verify everything still exists\n\tif _, err := os.Stat(rickDir); os.IsNotExist(err) {\n\t\tt.Error(\"expected .rick directory to exist after second init\")\n\t}\n\n\tgitDir := filepath.Join(rickDir, \".git\")\n\tif _, err := os.Stat(gitDir); os.IsNotExist(err) {\n\t\tt.Error(\"expected .git directory to exist after second init\")\n\t}\n}\n\n// TestInitCmdConfigFormat tests that config file has correct JSON format\nfunc TestInitCmdConfigFormat(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn rickDir, nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfigPath := filepath.Join(rickDir, \"config.json\")\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn configPath, nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Read and verify config format\n\tdata, err := os.ReadFile(configPath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read config file: %v\", err)\n\t}\n\n\t// Basic JSON format check\n\tif len(data) == 0 {\n\t\tt.Error(\"config file is empty\")\n\t}\n\n\t// Try to parse as JSON\n\tvar cfg config.Config\n\terr = config.LoadConfig()\n\tif err != nil {\n\t\tt.Fatalf(\"failed to validate config JSON format: %v\", err)\n\t}\n}\n\n// TestInitCmdOKRContent tests that OKR.md has correct initial content\nfunc TestInitCmdOKRContent(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpHome := t.TempDir()\n\n\t// Override GetRickDir to use temp directory\n\toldGetRickDir := workspace.GetRickDir\n\tdefer func() {\n\t\tworkspace.GetRickDir = oldGetRickDir\n\t}()\n\n\trickDir := filepath.Join(tmpHome, \".rick\")\n\tworkspace.GetRickDir = func() (string, error) {\n\t\treturn rickDir, nil\n\t}\n\n\t// Override config path to use temp directory\n\toldGetConfigPath := config.GetConfigPath\n\tdefer func() {\n\t\tconfig.GetConfigPath = oldGetConfigPath\n\t}()\n\n\tconfig.GetConfigPath = func() (string, error) {\n\t\treturn filepath.Join(rickDir, \"config.json\"), nil\n\t}\n\n\tcmd := NewInitCmd()\n\terr := cmd.RunE(cmd, []string{})\n\tif err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Read OKR.md\n\tokriPath := filepath.Join(rickDir, \"OKR.md\")\n\tcontent, err := os.ReadFile(okriPath)\n\tif err != nil {\n\t\tt.Fatalf(\"failed to read OKR.md: %v\", err)\n\t}\n\n\tif len(content) == 0 {\n\t\tt.Error(\"OKR.md is empty\")\n\t}\n\n\t// Check for markdown header\n\tif string(content) != \"# OKR\\n\\n\" {\n\t\tt.Errorf(\"expected OKR.md to have