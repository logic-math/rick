ction\n    27→func ParseMarkdownWithSource(content string) (*MarkdownDocument, error) {\n    28→\tmd := goldmark.New()\n    29→\tsource := []byte(content)\n    30→\treader := text.NewReader(source)\n    31→\tnode := md.Parser().Parse(reader)\n    32→\treturn &MarkdownDocument{\n    33→\t\tAST:    node,\n    34→\t\tSource: source,\n    35→\t}, nil\n    36→}\n    37→\n    38→// ExtractHeading extracts headings of a specific level from the AST\n    39→// level: 1 for h1, 2 for h2, etc.\n    40→func ExtractHeading(node ast.Node, level int) []string {\n    41→\treturn ExtractHeadingWithSource(node, level, nil)\n    42→}\n    43→\n    44→// ExtractHeadingWithSource extracts headings with source bytes for proper text extraction\n    45→func ExtractHeadingWithSource(node ast.Node, level int, source []byte) []string {\n    46→\tvar headings []string\n    47→\twalkNode(node, func(n ast.Node, entering bool) ast.WalkStatus {\n    48→\t\tif !entering {\n    49→\t\t\treturn ast.WalkContinue\n    50→\t\t}\n    51→\t\theading, ok := n.(*ast.Heading)\n    52→\t\tif ok && heading.Level == level {\n    53→\t\t\ttext := extractTextFromNode(heading, source)\n    54→\t\t\theadings = append(headings, text)\n    55→\t\t}\n    56→\t\treturn ast.WalkContinue\n    57→\t})\n    58→\treturn headings\n    59→}\n    60→\n    61→// ExtractListItems extracts all list items from the AST\n    62→func ExtractListItems(node ast.Node) []string {\n    63→\treturn ExtractListItemsWithSource(node, nil)\n    64→}\n    65→\n    66→// ExtractListItemsWithSource extracts all list items with source bytes\n    67→func ExtractListItemsWithSource(node ast.Node, source []byte) []string {\n    68→\tvar items []string\n    69→\twalkNode(node, func(n ast.Node, entering bool) ast.WalkStatus {\n    70→\t\tif !entering {\n    71→\t\t\treturn ast.WalkContinue\n    72→\t\t}\n    73→\t\titem, ok := n.(*ast.ListItem)\n    74→\t\tif ok {\n    75→\t\t\ttext := extractTextFromNode(item, source)\n    76→\t\t\tif text != \"\" {\n