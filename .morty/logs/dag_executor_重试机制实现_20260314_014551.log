onResult, error) {\n    39→\tif task == nil {\n    40→\t\treturn nil, fmt.Errorf(\"task cannot be nil\")\n    41→\t}\n    42→\n    43→\tresult := &TaskExecutionResult{\n    44→\t\tTaskID:    task.ID,\n    45→\t\tTaskName:  task.Name,\n    46→\t\tStatus:    \"running\",\n    47→\t\tStartTime: time.Now(),\n    48→\t}\n    49→\n    50→\t// Generate test script\n    51→\tscriptPath, err := tr.GenerateTestScript(task)\n    52→\tif err != nil {\n    53→\t\tresult.Status = \"failed\"\n    54→\t\tresult.Error = fmt.Sprintf(\"failed to generate test script: %v\", err)\n    55→\t\tresult.EndTime = time.Now()\n    56→\t\treturn result, nil\n    57→\t}\n    58→\tdefer os.Remove(scriptPath)\n    59→\n    60→\t// Execute test script\n    61→\toutput, err := tr.ExecuteTestScript(scriptPath)\n    62→\tif err != nil {\n    63→\t\tresult.Status = \"failed\"\n    64→\t\tresult.Error = fmt.Sprintf(\"test execution failed: %v\", err)\n    65→\t\tresult.Output = output\n    66→\t\tresult.EndTime = time.Now()\n    67→\t\treturn result, nil\n    68→\t}\n    69→\n    70→\t// Parse test result\n    71→\tsuccess, parseErr := tr.ParseTestResult(output)\n    72→\tif parseErr != nil {\n    73→\t\tresult.Status = \"failed\"\n    74→\t\tresult.Error = fmt.Sprintf(\"failed to parse test result: %v\", parseErr)\n    75→\t\tresult.Output = output\n    76→\t\tresult.EndTime = time.Now()\n    77→\t\treturn result, nil\n    78→\t}\n    79→\n    80→\tif success {\n    81→\t\tresult.Status = \"success\"\n    82→\t\tresult.Output = output\n    83→\t} else {\n    84→\t\tresult.Status = \"failed\"\n    85→\t\tresult.Error = \"test did not pass\"\n    86→\t\tresult.Output = output\n    87→\t}\n    88→\n    89→\tresult.EndTime = time.Now()\n    90→\treturn result, nil\n    91→}\n    92→\n    93→// GenerateTestScript generates a shell script for testing the task\n    94→// The script is created in a temporary location and should be executed\n    95→func (tr *TaskRunner) GenerateTestScript(task *parser.Task) (string, error) {\n    96→\tif task == nil {\n    97→\t\treturn \"\", fmt.Errorf(\"task cannot be nil\")\n    98→\t}\n    99→\n   100→\t// Create a temporary script file\n   101→\ttmpDir := os.TempDir()\n   102→\tscriptPath := filepath.Join(tmpDir, fmt.Sprintf(\"test_%s_%d.sh\", task.ID, time.Now().UnixNano()))\n   103→\n   104→\t// Build the test script content\n   105→\tvar scriptContent strings.Builder\n   106→\tscriptContent.WriteString(\"#!/bin/bash\\n\")\n   107→\tscriptContent.WriteString(\"set -e\\n\\n\")\n   108→\n   109→\t// Add task information as comments\n   110→\tscriptContent.WriteString(fmt.Sprintf(\"# Test script for task: %s\\n\", task.Name))\n   111→\tscriptContent.WriteString(fmt.Sprintf(\"# Task ID: %s\\n\", task.ID))\n   112→\tscriptContent.WriteString(fmt.Sprintf(\"# Goal: %s\\n\", task.Goal))\n   113→\tscriptContent.WriteString(\"\\n\")\n   114→\n   115→\t// Add test method steps\n   116→\tif task.TestMethod != \"\" {\n   117→\t\tscriptContent.WriteString(\"# Test steps:\\n\")\n   118→\t\tlines := strings.Split(task.TestMethod, \"\\n\")\n   119→\t\tfor _, line := range lines {\n   120→\t\t\ttrimmed := strings.TrimSpace(line)\n   121→\t\t\tif trimmed != \"\" {\n   122→\t\t\t\t// Extract the test step (remove list markers)\n   123→\t\t\t\tstep := trimmed\n   124→\t\t\t\tif strings.HasPrefix(step, \"- \") {\n   125→\t\t\t\t\tstep = strings.TrimPrefix(step, \"- \")\n   126→\t\t\t\t} else if strings.HasPrefix(step, \"* \") {\n   127→\t\t\t\t\tstep = strings.TrimPrefix(step, \"* \")\n   128→\t\t\t\t} else if len(step) > 0 && step[0] >= '0' && step[0] <= '9' {\n   129→\t\t\t\t\t// Handle numbered lists\n   130→\t\t\t\t\tparts := strings.SplitN(step, \". \", 2)\n   131→\t\t\t\t\tif len(parts) == 2 {\n   132→\t\t\t\t\t\tstep = parts[1]\n   133→\t\t\t\t\t}\n   134→\t\t\t\t}\n   135→\t\t\t\tscriptContent.WriteString(fmt.Sprintf(\"# %s\\n\", step))\n   136→\t\t\t}\n   137→\t\t}\n   138→\t\tscriptContent.WriteString(\"\\n\")\n   139→\t}\n   140→\n   141→\t// Add a simple validation check\n   142→\tscriptContent.WriteString(\"# Validation:\\n\")\n   143→\tscriptContent.WriteString(\"echo \\\"Testing task: \" + task.ID + \"\\\"\\n\")\n   144→\tscriptContent.WriteString(\"echo \\\"Task name: \" + task.Name + \"\\\"\\n\")\n   145→\tscriptContent.WriteString(\"echo \\\"Status: PASS\\\"\\n\")\n   146→\n   147→\t// Write the script to file\n   148→\terr := os.WriteFile(scriptPath, []byte(scriptContent.String()), 0755)\n   149→\tif err != nil {\n   150→\t\treturn \"\", fmt.Errorf(\"failed to write script file: %w\", err)\n   151→\t}\n   152→\n   153→\treturn scriptPath, nil\n   154→}\n   155→\n   156→// ExecuteTestScript executes a test script with timeout control\n   157→// Returns the script output and any error that occurred\n   158→func (tr *TaskRunner) ExecuteTestScript(scriptPath string) (string, error) {\n   159→\tif scriptPath == \"\" {\n   160→\t\treturn \"\", fmt.Errorf(\"script path cannot be empty\")\n   161→\t}\n   162→\n   163→\t// Verify script exists\n   164→\tif _, err := os.Stat(scriptPath); err != nil {\n   165→\t\treturn \"\", fmt.Errorf(\"script file not found: %w\", err)\n   166→\t}\n   167→\n   168→\t// Create command with timeout\n   169→\tcmd := exec.Command(\"bash\", scriptPath)\n   170→\n   171→\t// Capture output\n   172→\tvar stdout, stderr bytes.Buffer\n   173→\tcmd.Stdout = &stdout\n   174→\tcmd.Stderr = &stderr\n   175→\n   176→\t// Set timeout if configured\n   177→\tdone := make(chan error, 1)\n   178→\tgo func() {\n   179→\t\tdone <- cmd.Run()\n   180→\t}()\n   181→\n   182→\t// Wait for completion or timeout\n   183→\ttimeout := time.Duration(tr.config.TimeoutSeconds) * time.Second\n   184→\tif tr.config.TimeoutSeconds == 0 {\n   185→\t\ttimeout = 30 * time.Second // Default timeout\n   186→\t}\n   187→\n   188→\tselect {\n   189→\tcase err := <-done:\n   190→\t\tif err != nil {\n   191→\t\t\toutput := stdout.String()\n   192→\t\t\tif stderr.String() != \"\" {\n   193→\t\t\t\toutput += \"\\n