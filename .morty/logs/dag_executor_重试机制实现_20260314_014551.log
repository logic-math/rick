  23→\tdeps, err := ParseDependencies(content)\n    24→\tif err != nil {\n    25→\t\treturn nil, fmt.Errorf(\"failed to parse dependencies: %w\", err)\n    26→\t}\n    27→\ttask.Dependencies = deps\n    28→\n    29→\t// Parse task name\n    30→\tname, err := ParseTaskName(content)\n    31→\tif err != nil {\n    32→\t\treturn nil, fmt.Errorf(\"failed to parse task name: %w\", err)\n    33→\t}\n    34→\ttask.Name = name\n    35→\n    36→\t// Parse goal\n    37→\tgoal, err := ParseGoal(content)\n    38→\tif err != nil {\n    39→\t\treturn nil, fmt.Errorf(\"failed to parse goal: %w\", err)\n    40→\t}\n    41→\ttask.Goal = goal\n    42→\n    43→\t// Parse key results\n    44→\tkeyResults, err := ParseKeyResults(content)\n    45→\tif err != nil {\n    46→\t\treturn nil, fmt.Errorf(\"failed to parse key results: %w\", err)\n    47→\t}\n    48→\ttask.KeyResults = keyResults\n    49→\n    50→\t// Parse test method\n    51→\ttestMethod, err := ParseTestMethod(content)\n    52→\tif err != nil {\n    53→\t\treturn nil, fmt.Errorf(\"failed to parse test method: %w\", err)\n    54→\t}\n    55→\ttask.TestMethod = testMethod\n    56→\n    57→\treturn task, nil\n    58→}\n    59→\n    60→// ParseDependencies extracts dependencies from \"# 依赖关系\" section\n    61→func ParseDependencies(content string) ([]string, error) {\n    62→\theading := extractSectionContent(content, \"# 依赖关系\")\n    63→\tif heading == \"\" {\n    64→\t\treturn []string{}, nil\n    65→\t}\n    66→\n    67→\t// Split by comma and trim whitespace\n    68→\tparts := strings.Split(heading, \",\")\n    69→\tvar deps []string\n    70→\tfor _, part := range parts {\n    71→\t\ttrimmed := strings.TrimSpace(part)\n    72→\t\tif trimmed != \"\" {\n    73→\t\t\tdeps = append(deps, trimmed)\n    74→\t\t}\n    75→\t}\n    76→\treturn deps, nil\n    77→}\n    78→\n    79→// ParseTaskName extracts task name from \"# 任务名称\" section\n    80→func ParseTaskName(content string) (string, error) {\n    81→\theading := extractSectionC