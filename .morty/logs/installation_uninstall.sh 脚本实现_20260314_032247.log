_dir\" \"rick\"\n    create_mock_install \"$dev_dir\" \"rick_dev\"\n\n    # Verify both installations exist\n    if [[ -d \"$prod_dir\" ]] && [[ -d \"$dev_dir\" ]]; then\n        print_test_pass \"Both mock installations created\"\n    else\n        print_test_fail \"Failed to create mock installations\"\n        return\n    fi\n\n    # Test uninstall with automatic confirmation (need to confirm twice)\n    local output=$(echo -e \"y\\ny\" | timeout 10 HOME=\"$TEST_TEMP_DIR\" \"$SCRIPTS_DIR/uninstall.sh\" \\\n        --all \\\n        --prefix \"$prod_dir\" \\\n        2>&1 || true)\n\n    # Note: --all flag uses hardcoded paths, so we can't easily test with custom prefixes\n    # This test verifies the --all flag is accepted without error\n    if echo \"$output\" | grep -q \"Starting uninstallation\"; then\n        print_test_pass \"--all flag accepted and processed\"\n    else\n        print_test_fail \"--all flag not processed correctly\"\n    fi\n}","originalFile":"#!/bin/bash\n#\n# test_uninstall.sh - Test script for uninstall.sh functionality\n#\n# This script tests all aspects of the uninstall.sh script:\n# - Parameter parsing (--dev, --all, --prefix)\n# - Uninstalling production version\n# - Uninstalling development version\n# - Uninstalling all versions\n# - Symbolic link deletion\n# - Directory cleanup\n# - Error handling\n#\n\nset -e\n\n# Script directory\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nPROJECT_DIR=\"$(dirname \"$SCRIPT_DIR\")\"\nSCRIPTS_DIR=\"$PROJECT_DIR/scripts\"\n\n# Test configuration\nTEST_TEMP_DIR=$(mktemp -d)\nTEST_LOG_FILE=\"$TEST_TEMP_DIR/test.log\"\nTEST_PASSED=0\nTEST_FAILED=0\n\n# Colors for output\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nNC='\\033[0m' # No Color\n\n# Functions\nprint_test_header() {\n    echo \"\"\n    echo -e \"${BLUE}========================================${NC}\"\n    echo -e \"${BLUE}Test: $1${NC}\"\n    echo -e \"${BLUE}========================================${NC}\"\n}\n\nprint_test_pass() {\n    echo -e \"${GREEN}[PASS]${NC} $1\"\n    ((TEST_PASSED++))\n}\n\nprint_test_fail() {\n    echo -e \"${RED}[FAIL]${NC} $1\"\n    ((TEST_FAILED++))\n}\n\nprint_info() {\n    echo -e \"${YELLOW}[INFO]${NC} $1\"\n}\n\nprint_debug() {\n    echo -e \"${BLUE}[DEBUG]${NC} $1\"\n}\n\ncleanup_test() {\n    rm -rf \"$TEST_TEMP_DIR\"\n}\n\ntrap cleanup_test EXIT\n\n# Create mock installation directory\ncreate_mock_install() {\n    local install_dir=\"$1\"\n    local bin_name=\"${2:-rick}\"\n\n    mkdir -p \"$install_dir/bin\"\n\n    # Create a mock binary\n    cat > \"$install_dir/bin/rick\" << 'EOF'\n#!/bin/bash\necho \"Rick CLI v1.0.0\"\nEOF\n    chmod +x \"$install_dir/bin/rick\"\n\n    # Create a mock symlink\n    mkdir -p \"$TEST_TEMP_DIR/.local/bin\"\n    ln -s \"$install_dir/bin/rick\" \"$TEST_TEMP_DIR/.local/bin/$bin_name\"\n\n    print_debug \"Created mock installation at: $install_dir\"\n}\n\n# Test 1: Help message\ntest_help_message() {\n    print_test_header \"Help Message\"\n\n    local output=$(\"$SCRIPTS_DIR/uninstall.sh\" -h 2>&1 || true)\n\n    if echo \"$output\" | grep -q \"Usage:\"; then\n        print_test_pass \"Help message displayed correctly\"\n    else\n        print_test_fail \"Help message not displayed\"\n    fi\n\n    if echo \"$output\" | grep -q \"\\-\\-dev\"; then\n        print_test_pass \"Help includes --dev option\"\n    else\n        print_test_fail \"Help missing --dev option\"\n    fi\n\n    if echo \"$output\" | grep -q \"\\-\\-all\"; then\n        print_test_pass \"Help includes --all option\"\n    else\n        print_test_fail \"Help missing --all option\"\n    fi\n}\n\n# Test 2: Invalid parameter handling\ntest_invalid_parameters() {\n    print_test_header \"Invalid Parameter Handling\"\n\n    local output=$(\"$SCRIPTS_DIR/uninstall.sh\" --invalid 2>&1 || true)\n\n    if echo \"$output\" | grep -q \"Unknown option\"; then\n        print_test_pass \"Invalid parameter error detected\"\n    else\n        print_test_fail \"Invalid parameter not handled correctly\"\n    fi\n}\n\n# Test 3: Production version uninstall (non-interactive)\ntest_production_uninstall() {\n    print_test_header \"Production Version Uninstall\"\n\n    local test_install_dir=\"$TEST_TEMP_DIR/test_rick_prod\"\n    create_mock_install \"$test_install_dir\" \"rick\"\n\n    # Verify installation exists\n    if [[ -d \"$test_install_dir\" ]]; then\n        print_test_pass \"Mock production installation created\"\n    else\n        print_test_fail \"Failed to create mock production installation\"\n        return\n    fi\n\n    # Test uninstall with automatic confirmation (echo \"y\")\n    local output=$(echo \"y\" | timeout 5 HOME=\"$TEST_TEMP_DIR\" \"$SCRIPTS_DIR/uninstall.sh\" --prefix \"$test_install_dir\" 2>&1 || true)\n\n    # Verify directory was removed\n    if [[ ! -d \"$test_install_dir\" ]]; then\n        print_test_pass \"Production installation directory removed\"\n    else\n        print_test_fail \"Production installation directory still exists\"\n    fi\n\n    # Verify symlink was removed\n    if [[ ! -L \"$TEST_TEMP_DIR/.local/bin/rick\" ]]; then\n        print_test_pass \"Production symlink removed\"\n    else\n        print_test_fail \"Production symlink still exists\"\n    fi\n}\n\n# Test 4: Development version uninstall (non-interactive)\ntest_dev_uninstall() {\n    print_test_header \"Development Version Uninstall\"\n\n    local test_install_dir=\"$TEST_TEMP_DIR/test_rick_dev\"\n    create_mock_install \"$test_install_dir\" \"rick_dev\"\n\n    # Verify installation exists\n    if [[ -d \"$test_install_dir\" ]]; then\n        print_test_pass \"Mock development installation created\"\n    else\n        print_test_fail \"Failed to create mock development installation\"\n        return\n    fi\n\n    # Test uninstall with automatic confirmation\n    local output=$(echo \"y\" | timeout 5 HOME=\"$TEST_TEMP_DIR\" \"$SCRIPTS_DIR/uninstall.sh\" --dev --prefix \"$test_install_dir\" 2>&1 || true)\n\n    # Verify directory was removed\n    if [[ ! -d \"$test_install_dir\" ]]; then\n        print_test_pass \"Development installation directory removed\"\n    else\n        print_test_fail \"Development installation directory still exists\"\n    fi\n\n    # Verify symlink was removed\n    if [[ ! -L \"$TEST_TEMP_DIR/.local/bin/rick_dev\" ]]; then\n        print_test_pass \"Development symlink removed\"\n    else\n        print_test_fail \"Development symlink still exists\"\n    fi\n}\n\n# Test 5: Uninstall both versions\ntest_uninstall_all() {\n    print_test_header \"Uninstall Both Versions\"\n\n    local prod_dir=\"$TEST_TEMP_DIR/test_rick_prod_all\"\n    local dev_dir=\"$TEST_TEMP_DIR/test_rick_dev_all\"\n\n    create_mock_install \"$prod_dir\" \"rick\"\n    create_mock_install \"$dev_dir\" \"rick_dev\"\n\n    # Verify both installations exist\n    if [[ -d \"$prod_dir\" ]] && [[ -d \"$dev_dir\" ]]; then\n        print_test_pass \"Both mock installations created\"\n    else\n        print_test_fail \"Failed to create mock installations\"\n        return\n    fi\n\n    # Test uninstall with automatic confirmation (need to confirm twice)\n    local output=$(echo -e \"y\\ny\" | HOME=\"$TEST_TEMP_DIR\" \"$SCRIPTS_DIR/uninstall.sh\" \\\n        --all \\\n        --prefix \"$prod_dir\" \\\n        2>&1 || true)\n\n    # Note: --all flag uses hardcoded paths, so we can't easily test with custom prefixes\n    # This test verifies the --all flag is accepted without error\n    if echo \"$output\" | grep -q \"Starting uninstallation\"; then\n        print_test_pass \"--all flag accepted and processed\"\n    else\n        print_test_fail \"--all flag not processed correctly\"\n    fi\n}\n\n# Test 6: Cancellation handling\ntest_cancellation() {\n    print_test_header \"Cancellation Handling\"\n\n    local test_install_dir=\"$TEST_TEMP_DIR/test_rick_cancel\"\n    create_mock_install \"$test_install_dir\" \"rick\"\n\n    # Test uninstall with cancellation (echo \"n\")\n    local output=$(echo \"n\" | HOME=\"$TEST_TEMP_DIR\" \"$SCRIPTS_DIR/uninstall.sh\" --prefix \"$test_install_dir\" 2>&1 || true)\n\n    # Verify directory still exists\n    if [[ -d \"$test_install_dir\" ]]; then\n        print_test_pass \"Installation directory preserved when cancelled\"\n    else\n        print_test_fail \"Installation directory was removed despite cancellation\"\n    fi\n\n    if echo \"$output\" | grep -q \"cancelled\"; then\n        print_test_pass \"Cancellation message displayed\"\n    else\n        print_test_fail \"Cancellation message not displayed\"\n    fi\n}\n\n# Test 7: Non-existent installation handling\ntest_nonexistent_installation() {\n    print_test_header \"Non-existent Installation Handling\"\n\n    local nonexistent_dir=\"$TEST_TEMP_DIR/nonexistent_rick\"\n\n    # Test uninstall of non-existent directory\n    local output=$(\"$SCRIPTS_DIR/uninstall.sh\" --prefix \"$nonexistent_dir\" 2>&1 || true)\n\n    if echo \"$output\" | grep -q \"not found\"; then\n        print_test_pass \"Non-existent installation handled gracefully\"\n    else\n        print_test_fail \"Non-existent installation not handled correctly\"\n    fi\n}\n\n# Test 8: Script syntax check\ntest_script_syntax() {\n    print_test_header \"Script Syntax Check\"\n\n    if bash -n \"$SCRIPTS_DIR/uninstall.sh\" 2>/dev/null; then\n        print_test_pass \"Script syntax is valid\"\n    else\n        print_test_fail \"Script has syntax errors\"\n    fi\n}\n\n# Test 9: Verify output messages\ntest_output_messages() {\n    print_test_header \"Output Messages\"\n\n    local test_install_dir=\"$TEST_TEMP_DIR/test_rick_output\"\n    create_mock_install \"$test_install_dir\" \"rick\"\n\n    local output=$(echo \"y\" | HOME=\"$TEST_TEMP_DIR\" \"$SCRIPTS_DIR/uninstall.sh\" --prefix \"$test_install_dir\" 2>&1 || true)\n\n    if echo \"$output\" | grep -q \"Starting uninstallation\"; then\n        print_test_pass \"Starting message displayed\"\n    else\n        print_test_fail \"Starting message not displayed\"\n    fi\n\n    if echo \"$output\" | grep -q \"SUCCESS\"; then\n        print_test_pass \"Success message displayed\"\n    else\n        print_test_fail \"Success message not displayed\"\n    fi\n\n    if echo \"$output\" | grep -q \"Uninstallation Complete\"; then\n        print_test_pass \"Completion summary displayed\"\n    else\n        print_test_fail \"Completion summary not displayed\"\n    fi\n}\n\n# Test 10: Verify script is executable\ntest_script_executable() {\n    print_test_header \"Script Executable\"\n\n    if [[ -x \"$SCRIPTS_DIR/uninstall.sh\" ]]; then\n        print_test_pass \"uninstall.sh is executable\"\n    else\n        print_test_fail \"uninstall.sh is not executable\"\n    fi\n}\n\n# Main test execution\nmain() {\n    echo -e \"${BLUE}========================================${NC}\"\n    echo -e \"${BLUE}Rick CLI Uninstall Script Test Suite${NC}\"\n    echo -e \"${BLUE}========================================${NC}\"\n\n    test_script_executable\n    test_script_syntax\n    test_help_message\n    test_invalid_parameters\n    test_production_uninstall\n    test_dev_uninstall\n    test_uninstall_all\n    test_cancellation\n    test_nonexistent_installation\n    test_output_messages\n\n    # Print summary\n    echo \"\"\n    echo -e \"${BLUE}========================================${NC}\"\n    echo -e \"${BLUE}Test Summary${NC}\"\n    echo -e \"${BLUE}========================================${NC}\"\n    echo -e \"${GREEN}Passed: $TEST_PASSED${NC}\"\n    echo -e \"${RED}Failed: $TEST_FAILED${NC}\"\n    echo -e \"${BLUE}========================================${NC}\"\n\n    if [[ $TEST_FAILED -eq 0 ]]; then\n        echo -e \"${GREEN}All tests passed!${NC}\"\n        return 0\n    else\n        echo -e \"${RED}Some tests failed.${NC}\"\n        return 1\n    fi\n}\n\nmain \"$@\"\n","structuredPatch":[{"oldStart":208,"oldLines":7,"newStart":208,"newLines":7,"lines":["     fi"," ","     # Te