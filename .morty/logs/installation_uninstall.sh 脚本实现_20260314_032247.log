n prefix (default: ~/.rick or ~/.rick_dev)\n    13→#   --version VERSION       Specify version to install (default: latest)\n    14→#   -h, --help              Show this help message\n    15→#\n    16→# Examples:\n    17→#   ./scripts/install.sh                    # Install production version from source\n    18→#   ./scripts/install.sh --dev              # Install development version from source\n    19→#   ./scripts/install.sh --binary           # Install production version from binary\n    20→#   ./scripts/install.sh --binary --dev     # Install development version from binary\n    21→#\n    22→\n    23→set -e\n    24→\n    25→# Script directory\n    26→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n    27→PROJECT_DIR=\"$(dirname \"$SCRIPT_DIR\")\"\n    28→\n    29→# Default values\n    30→INSTALL_MODE=\"source\"  # source or binary\n    31→IS_DEV_MODE=false\n    32→PREFIX=\"\"\n    33→VERSION=\"latest\"\n    34→\n    35→# Colors for output\n    36→RED='\\033[0;31m'\n    37→GREEN='\\033[0;32m'\n    38→YELLOW='\\033[1;33m'\n    39→BLUE='\\033[0;34m'\n    40→NC='\\033[0m' # No Color\n    41→\n    42→# Functions\n    43→print_error() {\n    44→    echo -e \"${RED}[ERROR]${NC} $1\" >&2\n    45→}\n    46→\n    47→print_success() {\n    48→    echo -e \"${GREEN}[SUCCESS]${NC} $1\"\n    49→}\n    50→\n    51→print_info() {\n    52→    echo -e \"${YELLOW}[INFO]${NC} $1\"\n    53→}\n    54→\n    55→print_debug() {\n    56→    echo -e \"${BLUE}[DEBUG]${NC} $1\"\n    57→}\n    58→\n    59→show_help() {\n    60→    sed -n '2,/^$/p' \"$0\" | sed 's/^# //' | sed 's/^#//'\n    61→}\n    62→\n    63→parse_args() {\n    64→    while [[ $# -gt 0 ]]; do\n    65→        case $1 in\n    66→            --source)\n    67→                INSTALL_MODE=\"source\"\n    68→                shift\n    69→                ;;\n    70→            --binary)\n    71→                INSTALL_MODE=\"binary\"\n    72→                shift\n    73→                ;;\n    74→          