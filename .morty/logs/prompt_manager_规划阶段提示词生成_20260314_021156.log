extInfo) string {\n\tif specInfo == nil || len(specInfo.Specifications) == 0 {\n\t\treturn \"وڑ‚و— é،¹ç›® SPEC ن؟،وپ¯\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(\"**Specifications:**\\n\")\n\n\tfor _, spec := range specInfo.Specifications {\n\t\tcontent.WriteString(fmt.Sprintf(\"- %s\\n\", spec))\n\t}\n\n\treturn content.String()\n}\n\n// formatCompletedWork formats completed work history for the prompt\nfunc formatCompletedWork(history []string) string {\n\tif len(history) == 0 {\n\t\treturn \"è؟™وک¯é،¹ç›®çڑ„ç¬¬ن¸€éک¶و®µè§„هˆ’\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(\"**ه·²ه®Œوˆگçڑ„ه·¥ن½œ:**\\n\")\n\n\tfor _, item := range history {\n\t\tcontent.WriteString(fmt.Sprintf(\"- %s\\n\", item))\n\t}\n\n\treturn content.String()\n}\n","structuredPatch":[],"originalFile":null}},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_d9bfc38b-304","type":"message","content":[{"text":"Good! Now let me create comprehensive unit tests for the plan prompt generation. First, let me check the existing test patterns:","type":"text"}],"context_management":null},"parent_tool_use_id":null,"session_id":"cbe0952f-8069-4f6c-9098-8c341f72891a","uuid":"8586ad8d-8f86-4a02-a400-39a9794c34a7"},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_d9bfc38b-304","type":"message","content":[{"input":{"file_path":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/builder_test.go","limit":60},"name":"Read","id":"toolu_bdrk_01UFYyCRijLc7n1WQWEUNmev","type":"tool_use"}],"context_management":null},"parent_tool_use_id":null,"session_id":"cbe0952f-8069-4f6c-9098-8c341f72891a","uuid":"71b38be