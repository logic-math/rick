esult = strings.ReplaceAll(result, placeholder, value)\n\t}\n\n\t// Replace unreplaced variables with empty string\n\tfor _, variable := range pb.Template.Variables {\n\t\tplaceholder := \"{{\" + variable + \"}}\"\n\t\tif _, exists := pb.Variables[variable]; !exists {\n\t\t\tresult = strings.ReplaceAll(result, placeholder, \"\")\n\t\t}\n\t}\n\n\treturn result\n}","new_string":"// replaceVariables replaces {{variable}} placeholders with their values\nfunc (pb *PromptBuilder) replaceVariables(content string) string {\n\tresult := content\n\n\t// Replace each variable\n\tfor key, value := range pb.Variables {\n\t\tplaceholder := \"{{\" + key + \"}}\"\n\t\tresult = strings.ReplaceAll(result, placeholder, value)\n\t}\n\n\treturn result\n}"},"name":"Edit","id":"toolu_bdrk_014kEokf8SGKANAjqkRGZK3r","type":"tool_use"}],"context_management":null},"parent_tool_use_id":null,"session_id":"45d568cc-46cb-4aae-ae0b-763678fca600","uuid":"963b4694-bdd2-4e71-a65b-02dfc8dcb282"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_014kEokf8SGKANAjqkRGZK3r","type":"tool_result","content":"The file /Users/sunquan/ai_coding/CODING/rick/internal/prompt/builder.go has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"45d568cc-46cb-4aae-ae0b-763678fca600","uuid":"54e0aeeb-1b99-4c37-91cd-f087f6b5f760","tool_use_result":{"filePath":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/builder.go","oldString":"// replaceVariables replaces {{variable}} placeholders with their values\nfunc (pb *PromptBuilder) replaceVariables(content string) string {\n\tresult := content\n\n\t// Replace each variable\n\tfor key, value := range pb.Variables {\n\t\tplaceholder := \"{{\" + key + \"}}\"\n\t\tresult = strings.ReplaceAll(result, placeholder, value)\n\t}\n\n\t// Replace unreplaced variables with empty string\n\tfor _, variable := range pb.Template.Variables {\n\t\tplaceholder := \"{{\" + variable + \"}}\"\n\t\tif _, exists := pb.Variables[variable]; !exists {\n\t\t\tresult = strings.ReplaceAll(result, placeholder, \"\")\n\t\t}\n\t}\n\n\treturn result\n}","newString":"// replaceVariables replaces {{variable}} placeholders with their values\nfunc (pb *PromptBuilder) replaceVariables(content string) string {\n\tresult := content\n\n\t// Replace each variable\n\tfor key, value := range pb.Variables {\n\t\tplaceholder := \"{{\" + key + \"}}\"\n\t\tresult = strings.ReplaceAll(result, placeholder, value)\n\t}\n\n\treturn result\n}","originalFile":"package prompt\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n)\n\n// PromptBuilder builds prompts by substituting variables and context into templates\ntype PromptBuilder struct {\n\tTemplate  *PromptTemplate\n\tVariables map[string]string\n\tContext   map[string]interface{}\n}\n\n// NewPromptBuilder creates a new PromptBuilder instance with the given template\nfunc NewPromptBuilder(template *PromptTemplate) *PromptBuilder {\n\treturn &PromptBuilder{\n\t\tTemplate:  template,\n\t\tVariables: make(map[string]string),\n\t\tContext:   make(map[string]interface{}),\n\t}\n}\n\n// SetVariable sets a template variable\nfunc (pb *PromptBuilder) SetVariable(key, value string) *PromptBuilder {\n\tpb.Variables[key] = value\n\treturn pb\n}\n\n// SetContext sets a context value\nfunc (pb *PromptBuilder) SetContext(key string, value interface{}) *PromptBuilder {\n\tpb.Context[key] = value\n\treturn pb\n}\n\n// Build constructs the final prompt by replacing variables and injecting context\nfunc (pb *PromptBuilder) Build() (string, error) {\n\tif pb.Template == nil {\n\t\treturn \"\", fmt.Errorf(\"template is not set\")\n\t}\n\n\tresult := pb.Template.Content\n\n\t// Replace variables first\n\tresult = pb.replaceVariables(result)\n\n\t// Inject context\n\tresult = pb.injectContext(result)\n\n\treturn result, nil\n}\n\n// replaceVariables replaces {{variable}} placeholders with their values\nfunc (pb *PromptBuilder) replaceVariables(content string) string {\n\tresult := content\n\n\t// Replace each variable\n\tfor key, value := range pb.Variables {\n\t\tplaceholder := \"{{\" + key + \"}}\"\n\t\tresult = strings.ReplaceAll(result, placeholder, value)\n\t}\n\n\t// Replace unreplaced variables with empty string\n\tfor _, variable := range pb.Template.Variables {\n\t\tplaceholder := \"{{\" + variable + \"}}\"\n\t\tif _, exists := pb.Variables[variable]; !exists {\n\t\t\tresult = strings.ReplaceAll(result, placeholder, \"\")\n\t\t}\n\t}\n\n\treturn result\n}\n\n// injectContext injects context values into the prompt\n// Context values are converted to strings and injected into the prompt\nfunc (pb *PromptBuilder) injectContext(content string) string {\n\tresult := content\n\n\t// Inject each context value\n\tfor key, value := range pb.Context {\n\t\tplaceholder := \"{{\" + key + \"}}\"\n\t\tvalueStr := fmt.Sprintf(\"%v\", value)\n\t\tresult = strings.ReplaceAll(result, placeholder, valueStr)\n\t}\n\n\treturn result\n}\n\n// GetVariables returns the list of variables that need to be set\nfunc (pb *PromptBuilder) GetVariables() []string {\n\tif pb.Template == nil {\n\t\treturn []string{}\n\t}\n\treturn pb.Template.Variables\n}\n\n// GetMissingVariables returns variables that haven't been set\nfunc (pb *PromptBuilder) GetMissingVariables() []string {\n\tvar missing []string\n\tfor _, variable := range pb.GetVariables() {\n\t\tif _, exists := pb.Variables[variable]; !exists {\n\t\t\tif _, existsInContext := pb.Context[variable]; !existsInContext {\n\t\t\t\tmissing = append(missing, variable)\n\t\t\t}\n\t\t}\n\t}\n\treturn missing\n}\n","structuredPatch":[{"oldStart":60,"oldLines":14,"newStart":60,"newLines":6,"lines":["     result = strings.ReplaceAll(result, placeholder, value)","   }"," ","-  // Replace unreplaced variables with empty string","-  for _, variable := range pb.Template.Variables {","-    placeholder := \"{{\" + variable + \"}}\"","-    if _, exists := pb.Variables[variable]; !exists {","-      result = strings.ReplaceAll(result, placeholder, \"\")","-    }","