nitRepo initializes a Git repository at the given path\n    33→func (gm *GitManager) InitRepo() error {\n    34→\tif err := os.MkdirAll(gm.repoPath, 0755); err != nil {\n    35→\t\treturn fmt.Errorf(\"failed to create directory: %w\", err)\n    36→\t}\n    37→\n    38→\tcmd := exec.Command(\"git\", \"init\")\n    39→\tcmd.Dir = gm.repoPath\n    40→\tif err := cmd.Run(); err != nil {\n    41→\t\treturn fmt.Errorf(\"failed to initialize git repo: %w\", err)\n    42→\t}\n    43→\n    44→\treturn nil\n    45→}\n    46→\n    47→// AddFiles adds files to the staging area\n    48→func (gm *GitManager) AddFiles(paths []string) error {\n    49→\tif len(paths) == 0 {\n    50→\t\treturn fmt.Errorf(\"no files to add\")\n    51→\t}\n    52→\n    53→\targs := append([]string{\"add\"}, paths...)\n    54→\tcmd := exec.Command(\"git\", args...)\n    55→\tcmd.Dir = gm.repoPath\n    56→\tif err := cmd.Run(); err != nil {\n    57→\t\treturn fmt.Errorf(\"failed to add files: %w\", err)\n    58→\t}\n    59→\n    60→\treturn nil\n    61→}\n    62→\n    63→// Commit commits changes with the given message\n    64→func (gm *GitManager) Commit(message string) error {\n    65→\tif message == \"\" {\n    66→\t\treturn fmt.Errorf(\"commit message cannot be empty\")\n    67→\t}\n    68→\n    69→\tcmd := exec.Command(\"git\", \"commit\", \"-m\", message)\n    70→\tcmd.Dir = gm.repoPath\n    71→\tif err := cmd.Run(); err != nil {\n    72→\t\treturn fmt.Errorf(\"failed to commit: %w\", err)\n    73→\t}\n    74→\n    75→\treturn nil\n    76→}\n    77→\n    78→// GetLog retrieves commit history with the given limit\n    79→func (gm *GitManager) GetLog(limit int) ([]CommitInfo, error) {\n    80→\tif limit <= 0 {\n    81→\t\tlimit = 10\n    82→\t}\n    83→\n    84→\tformat := \"%H%n%s%n%an%n%ai\"\n    85→\tcmd := exec.Command(\"git\", \"log\", fmt.Sprintf(\"--max-count=%d\", limit), fmt.Sprintf(\"--format=%s\", format))\n    86→\tcmd.Dir = gm.repoPath\n    87→\toutput, err := cmd.Output()\n    88→\tif err != nil {\n    89→\t\treturn nil, fmt.Errorf(\"failed to get log: %w\", err)\n    90→\t}\n    91→\n    92→\tcommits := []CommitInfo{}\n    93→\tlines := strings.Split(strings.TrimSpace(string(output)), \"\\n\")\n    94→\n    95→\tfor i := 0; i < len(lines); i += 4 {\n    96→\t\tif i+3 >= len(lines) {\n    97→\t\t\tbreak\n    98→\t\t}\n    99→\n   100→\t\tdateStr := lines[i+3]\n   101→\t\tdate, err := time.Parse(\"2006-01-02 15:04:05 -0700\", dateStr)\n   102→\t\tif err != nil {\n   103→\t\t\tdate = time.Now()\n   104→\t\t}\n   105→\n   106→\t\tcommits = append(commits, CommitInfo{\n   107→\t\t\tHash:    lines[i],\n   108→\t\t\tMessage: lines[i+1],\n   109→\t\t\tAuthor:  lines[i+2],\n   110→\t\t\tDate:    date,\n   111→\t\t})\n   112→\t}\n   113→\n   114→\treturn commits, nil\n   115→}\n   116→\n   117→// GetCurrentBranch returns the name of the current branch\n   118→func (gm *GitManager) GetCurrentBranch() (string, error) {\n   119→\tcmd := exec.Command(\"git\", \"rev-parse\", \"--abbrev-ref\", \"HEAD\")\n   120→\tcmd.Dir = gm.repoPath\n   121→\toutput, err := cmd.Output()\n   122→\tif err != nil {\n   123→\t\treturn \"\", fmt.Errorf(\"failed to get current branch: %w\", err)\n   124→\t}\n   125→\n   126→\tbranch := strings.TrimSpace(string(output))\n   127→\treturn branch, nil\n   128→}\n   129→\n   130→// IsRepository checks if the given path is a Git repository\n   131→func (gm *GitManager) IsRepository() bool {\n   132→\tgitDir := filepath.Join(gm.repoPath, \".git\")\n   133→\t_, err := os.Stat(gitDir)\n   134→\treturn err == nil\n   135→}\n   136→\n   137→// GetRepoPath returns the repository path\n   138→func (gm *GitManager) GetRepoPath() string {\n   139→\treturn gm.repoPath\n   140→}\n   141→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, wri