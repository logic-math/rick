t   time.Time `json:\"created_at\"`\n    20→\tUpdatedAt   time.Time `json:\"updated_at\"`\n    21→}\n    22→\n    23→// TasksJSON represents the entire tasks.json structure\n    24→type TasksJSON struct {\n    25→\tVersion   string       `json:\"version\"`\n    26→\tCreatedAt time.Time    `json:\"created_at\"`\n    27→\tUpdatedAt time.Time    `json:\"updated_at\"`\n    28→\tTasks     []TaskState  `json:\"tasks\"`\n    29→\ttaskMap   map[string]*TaskState // internal map for fast lookup\n    30→}\n    31→\n    32→// GenerateTasksJSON generates a TasksJSON structure from a DAG and sorted tasks\n    33→// dag: the DAG structure containing task definitions\n    34→// sortedTasks: task IDs in topological order\n    35→func GenerateTasksJSON(dag *DAG, sortedTasks []string) (*TasksJSON, error) {\n    36→\tif dag == nil {\n    37→\t\treturn nil, fmt.Errorf(\"DAG cannot be nil\")\n    38→\t}\n    39→\tif len(sortedTasks) == 0 {\n    40→\t\treturn nil, fmt.Errorf(\"sortedTasks cannot be empty\")\n    41→\t}\n    42→\n    43→\tnow := time.Now()\n    44→\ttasksJSON := &TasksJSON{\n    45→\t\tVersion:   \"1.0\",\n    46→\t\tCreatedAt: now,\n    47→\t\tUpdatedAt: now,\n    48→\t\tTasks:     make([]TaskState, 0, len(sortedTasks)),\n    49→\t\ttaskMap:   make(map[string]*TaskState),\n    50→\t}\n    51→\n    52→\t// Create TaskState for each sorted task\n    53→\tfor _, taskID := range sortedTasks {\n    54→\t\ttask, exists := dag.Tasks[taskID]\n    55→\t\tif !exists {\n    56→\t\t\treturn nil, fmt.Errorf(\"task '%s' not found in DAG\", taskID)\n    57→\t\t}\n    58→\n    59→\t\ttaskState := TaskState{\n    60→\t\t\tTaskID:       taskID,\n    61→\t\t\tTaskName:     task.Name,\n    62→\t\t\tStatus:       \"pending\",\n    63→\t\t\tDependencies: task.Dependencies,\n    64→\t\t\tAttempts:     0,\n    65→\t\t\tCreatedAt:    now,\n    66→\t\t\tUpdatedAt:    now,\n    67→\t\t}\n    68→\n    69→\t\ttasksJSON.Tasks = append(tasksJSON.Tasks, taskState)\n    70→\t\ttasksJSON.taskMap[taskID] = &tasksJSON.Tasks[len(tasksJSON.Tasks)-1]\n    71→\t}\n    72→\n    73→\treturn tasksJSON, nil\n    74→}\n    75→\n    76→// LoadTasksJSON loads a TasksJSON from a file\n    77→func LoadTasksJSON(filePath string) (*TasksJSON, error) {\n    78→\tif filePath == \"\" {\n    79→\t\treturn nil, fmt.Errorf(\"file path cannot be empty\")\n    80→\t}\n    81→\n    82→\tdata, err := ioutil.ReadFile(filePath)\n    83→\tif err != nil {\n    84→\t\treturn nil, fmt.Errorf(\"failed to read tasks.json: %w\", err)\n    85→\t}\n    86→\n    87→\tvar tasksJSON TasksJSON\n    88→\tif err := json.Unmarshal(data, &tasksJSON); err != nil {\n    89→\t\treturn nil, fmt.Errorf(\"failed to unmarshal tasks.json: %w\", err)\n    90→\t}\n    91→\n    92→\t// Rebuild the internal task map\n    93→\ttasksJSON.taskMap = make(map[string]*TaskState)\n    94→\tfor i := range tasksJSON.Tasks {\n    95→\t\ttasksJSON.taskMap[tasksJSON.Tasks[i].TaskID] = &tasksJSON.Tasks[i]\n    96→\t}\n    97→\n    98→\treturn &tasksJSON, nil\n    99→}\n   100→\n   101→// SaveTasksJSON saves a TasksJSON to a file\n   102→func SaveTasksJSON(filePath string, tasksJSON *TasksJSON) error {\n   103→\tif filePath == \"\" {\n   104→\t\treturn fmt.Errorf(\"file path cannot be empty\")\n   105→\t}\n   106→\tif tasksJSON == nil {\n   107→\t\treturn fmt.Errorf(\"tasksJSON cannot be nil\")\n   108→\t}\n   109→\n   110→\t// Update the UpdatedAt timestamp\n   111→\ttasksJSON.UpdatedAt = time.Now()\n   112→\n   113→\tdata, err := json.MarshalIndent(tasksJSON, \"\", \"  \")\n   114→\tif err != nil {\n   115→\t\treturn fmt.Errorf(\"failed to marshal tasks.json: %w\", err)\n   116→\t}\n   117→\n   118→\tif err := ioutil.WriteFile(filePath, data, 0644); err != nil {\n   119→\t\treturn fmt.Errorf(\"failed to write tasks.json: %w\", err)\n   120→\t}\n   121→\n   122→\treturn nil\n   123→}\n   124→\n   125→// UpdateTaskStatus updates the status of a task\n   126→// taskID: the ID of the task to update\n   127→// status: the new status (pending, running, success, failed, retrying)\n   128→func (tj *TasksJSON) UpdateTaskStatus(taskID, status string) error {\n   129→\tif taskID == \"\" {\n   130→\t\treturn fmt.Errorf(\"task ID cannot be empty\")\n   131→\t}\n   132→\n   133→\t// Validate status\n   134→\tvalidStatuses := map[string]bool{\n   135→\t\t\"pending\":   true,\n   136→\t\t\"running\":   true,\n   137→\t\t\"success\":   true,\n   138→\t\t\"failed\":    true,\n   139→\t\t\"retrying\":  true,\n   140→\t}\n   141→\tif !validStatuses[status] {\n   142→\t\treturn fmt.Errorf(\"invalid status '%s', must be one of: pending, running, success, failed, retrying\", status)\n   143→\t}\n   144→\n   145→\ttaskState, exists := tj.taskMap[taskID]\n   146→\tif !exists {\n   147→\t\treturn fmt.Errorf(\"task '%s' not found\", taskID)\n   148→\t}\n   149→\n   150→\ttaskState.Status = status\n   151→\ttaskState.UpdatedAt = time.Now()\n   152→\n   153→\treturn nil\n   154→}\n   155→\n   156→// UpdateTaskStatusWithError updates the status of a task with error information\n   157→func (tj *TasksJSON) UpdateTaskStatusWithError(taskID, status, errorMsg string) error {\n   158→\tif err := tj.UpdateTaskStatus(taskID, status); err != nil {\n   159→\t\treturn err\n   160→\t}\n   161→\n   162→\ttaskState, _ := tj.taskMap[taskID]\n   163→\ttaskState.Error = errorMsg\n   164→\ttaskState.UpdatedAt = time.Now()\n   165→\n   166→\treturn nil\n   167→}\n   168→\n   169→// UpdateTaskStatusWithOutput updates the status of a task with output information\n   170→func (tj *TasksJSON) UpdateTaskStatusWithOutput(taskID, status, output string) error {\n   171→\tif err := tj.UpdateTaskStatus(taskID, status); err != nil {\n   172→\t\treturn err\n   173→\t}\n   174→\n   175→\ttaskState, _ := tj.taskMap[taskID]\n   176→\ttaskState.Output = output\n   177→\ttaskState.UpdatedAt = time.Now()\n   178→\n   179→\treturn nil\n   180→}\n   181→\n   182→// GetTaskStatus returns the status of a task\n   183→// Returns the status string or an error if the task is not found\n   184→func (tj *TasksJSON) GetTaskStatus(taskID string) (string, error) {\n   185→\tif taskID == \"\" {\n   186→\t\treturn \"\", fmt.Errorf(\"task ID cannot be empty\")\n   187→\t}\n   188→\n   189→\ttaskState, exists := tj.taskMap[taskID]\n   190→\tif !exists {\n   191→\t\treturn \"\", fmt.Errorf(\"task '%s' not found\", taskID)\n   192→\t}\n   193→\n   194→\treturn taskState.Status, nil\n   195→}\n   196→\n   197→// GetTask returns the full TaskState for a task\n   198→func (tj *TasksJSON) GetTask(taskID string) (*TaskState, error) {\n   199→\tif taskID == \"\" {\n   200→\t\treturn nil, fmt.Errorf(\"task ID cannot be empty\")\n   201→\t}\n   202→\n   203→\ttaskState, exists := tj.taskMap[taskID]\n   204→\tif !exists {\n   205→\t\treturn nil, fmt.Errorf(\"task '%s' not found\", taskID)\n   206→\t}\n   207→\n   208→\treturn taskState, nil\n   209→}\n   210→\n   211→// IncrementAttempts increments the attempt count for a task\n   212→func (tj *TasksJSON) IncrementAttempts(taskID string) error {\n   213→\tif taskID == \"\" {\n   214→\t\treturn fmt.Errorf(\"task ID cannot be empty\")\n   215→\t}\n   216→\n   217→\ttaskState, exists := tj.taskMap[taskID]\n   218→\tif !exists {\n   219→\t\treturn fmt.Errorf(\"task '%s' not found\", taskID)\n   220→\t}\n   221→\n   222→\ttaskState.Attempts++\n   223→\ttaskState.UpdatedAt = time.Now()\n   224→\n   225→\treturn nil\n   226→}\n   227→\n   228→// GetAllTasks returns all tasks in the TasksJSON\n   229→func (tj *TasksJSON) GetAllTasks() []TaskState {\n   230→\treturn tj.Tasks\n   231→}\n   232→\n   233→// GetTasksByStatus returns all tasks with a specific status\n   234→func (tj *TasksJSON) GetTasksByStatus(status string) []TaskState {\n   235→\tvar result []TaskState\n   236→\tfor _, task := range tj.Tasks {\n   237→\t\tif task.Status == status {\n   238→\t\t\tresult = append(result, task)\n   239→\t\t}\n   240→\t}\n   241→\treturn result\n   242→}\n   243→\n   244→// GetCompletedTasks returns all tasks with status \"success\"\n   245→func (tj *TasksJSON) GetCompletedTasks() []TaskState {\n   246→\treturn tj.GetTasksByStatus(\"success\")\n   247→}\n   248→\n   249→// GetFailedTasks returns all tasks with status \"failed\"\n   250→func (tj *TasksJSON) GetFailedTasks() []TaskState {\n   251→\treturn tj.GetTasksByStatus(\"failed\")\n   252→}\n   253→\n   254→// GetPendingTasks returns all tasks with status \"pending\"\n   255→func (tj *TasksJSON) GetPendingTasks() []TaskState {\n   256→\treturn tj.GetTasksByStatus(\"pending\")\n   257→}\n   258→\n   259→// GetTaskCount returns the total number of tasks\n   260→func (tj *TasksJSON) GetTaskCount() int {\n   261→\treturn len(tj.Tasks)\n   262→}\n   263→\n   264→// GetCompletedCount returns the number of completed tasks\n   265→func (tj *TasksJSON) GetCompletedCount() int {\n   266→\treturn len(tj.GetCompletedTasks())\n   267→}\n   268→\n   269→// GetFailedCount returns the number of failed tasks\n   270→func (tj *TasksJSON) GetFailedCount() int {\n   271→\treturn len(tj.GetFailedTasks())\n   272→}\n   273→\n   274→// GetPendingCount returns the number of pending tasks\n   275→func (tj *TasksJSON) GetPendingCount() int {\n   276→\treturn len(tj.GetPendingTasks())\n   277→}\n   278→\n   279→// IsAllCompleted checks if all tasks are completed\n   280→func (tj *TasksJSON) IsAllCompleted() bool {\n   281→\treturn tj.GetCompletedCount() == tj.GetTaskCount()\n   282→}\n   283→\n   284→// IsAnyFailed checks if any task has failed\n   285→func (tj *TasksJSON) IsAnyFailed() bool {\n   286→\treturn tj.GetFailedCount() > 0\n   287→}\n   288→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_01FYkhSL1mdrrYtry