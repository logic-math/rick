turn fmt.Errorf(\"failed to create directory: %w\", err)\n    36→\t}\n    37→\n    38→\tcmd := exec.Command(\"git\", \"init\")\n    39→\tcmd.Dir = gm.repoPath\n    40→\tif err := cmd.Run(); err != nil {\n    41→\t\treturn fmt.Errorf(\"failed to initialize git repo: %w\", err)\n    42→\t}\n    43→\n    44→\treturn nil\n    45→}\n    46→\n    47→// AddFiles adds files to the staging area\n    48→func (gm *GitManager) AddFiles(paths []string) error {\n    49→\tif len(paths) == 0 {\n    50→\t\treturn fmt.Errorf(\"no files to add\")\n    51→\t}\n    52→\n    53→\targs := append([]string{\"add\"}, paths...)\n    54→\tcmd := exec.Command(\"git\", args...)\n    55→\tcmd.Dir = gm.repoPath\n    56→\tif err := cmd.Run(); err != nil {\n    57→\t\treturn fmt.Errorf(\"failed to add files: %w\", err)\n    58→\t}\n    59→\n    60→\treturn nil\n    61→}\n    62→\n    63→// Commit commits changes with the given message\n    64→func (gm *GitManager) Commit(message string) error {\n    65→\tif message == \"\" {\n    66→\t\treturn fmt.Errorf(\"commit message cannot be empty\")\n    67→\t}\n    68→\n    69→\tcmd := exec.Command(\"git\", \"commit\", \"-m\", message)\n    70→\tcmd.Dir = gm.repoPath\n    71→\tif err := cmd.Run(); err != nil {\n    72→\t\treturn fmt.Errorf(\"failed to commit: %w\", err)\n    73→\t}\n    74→\n    75→\treturn nil\n    76→}\n    77→\n    78→// GetLog retrieves commit history with the given limit\n    79→func (gm *GitManager) GetLog(limit int) ([]CommitInfo, error) {\n    80→\tif limit <= 0 {\n    81→\t\tlimit = 10\n    82→\t}\n    83→\n    84→\tformat := \"%H%n%s%n%an%n%ai\"\n    85→\tcmd := exec.Command(\"git\", \"log\", fmt.Sprintf(\"--max-count=%d\", limit), fmt.Sprintf(\"--format=%s\", format))\n    86→\tcmd.Dir = gm.repoPath\n    87→\toutput, err := cmd.Output()\n    88→\tif err != nil {\n    89→\t\treturn nil, fmt.Errorf(\"failed to get log: %w\", err)\n    90→\t}\n    91→\n    92→\tcommits := []CommitInfo{}\n    93→\tlines := strings.Split(strings.TrimSp