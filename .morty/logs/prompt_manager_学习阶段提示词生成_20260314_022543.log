\n   182ŌåÆfunc (cm *ContextManager) GetSPECInfo() *parser.ContextInfo {\n   183ŌåÆ\tcm.mu.RLock()\n   184ŌåÆ\tdefer cm.mu.RUnlock()\n   185ŌåÆ\n   186ŌåÆ\treturn cm.SPECInfo\n   187ŌåÆ}\n   188ŌåÆ\n   189ŌåÆ// GetHistory returns the loaded history items\n   190ŌåÆfunc (cm *ContextManager) GetHistory() []string {\n   191ŌåÆ\tcm.mu.RLock()\n   192ŌåÆ\tdefer cm.mu.RUnlock()\n   193ŌåÆ\n   194ŌåÆ\t// Return a copy to prevent external modification\n   195ŌåÆ\tresult := make([]string, len(cm.History))\n   196ŌåÆ\tcopy(result, cm.History)\n   197ŌåÆ\treturn result\n   198ŌåÆ}\n   199ŌåÆ\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"da2705c5-f884-4a30-81d3-8fbeba816527","uuid":"ba4134ff-9cd5-406e-ac4c-00acc72f7679","tool_use_result":{"type":"text","file":{"filePath":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/context.go","content":"\t\treturn fmt.Errorf(\"failed to parse SPEC content: %w\", err)\n\t}\n\n\tcm.mu.Lock()\n\tdefer cm.mu.Unlock()\n\n\tcm.SPECInfo = specInfo\n\treturn nil\n}\n\n// LoadSPECFromFile loads SPEC information from a SPEC.md file\nfunc (cm *ContextManager) LoadSPECFromFile(filePath string) error {\n\tcontent, err := os.ReadFile(filePath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to read SPEC file: %w\", err)\n\t}\n\n\treturn cm.LoadSPECFromContent(string(content))\n}\n\n// LoadHistory loads execution history from git or other sources\n// For now, it accepts a slice of history strings\nfunc (cm *ContextManager) LoadHistory(historyItems []string) error {\n\tif historyItems == nil {\n\t\thistoryItems = []string{}\n\t}\n\n\tcm.mu.Lock()\n\tdefer cm.mu.Unlock()\n\n\tcm.History = historyItems\n\treturn nil\n}\n\n// LoadHistoryFromFile loads execution history from a file\nfunc (cm *ContextManager) LoadHistoryFromFile(filePath string) error {\n\tcontent, err := os.ReadFile(filePath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"failed to read history file: %w\", err)\n\t}\n\n\t// Parse history file - one line per history item\n\thistoryItems := []string{}\n\tif len(content) > 0 {\n\t\t// Split by newlines and filter empty lines\n\t\tlines := strings.Split(string(content), \"\\n\")\n\t\tfor _, line := range lines {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif trimmed != \"\" {\n\t\t\t\thistoryItems = append(historyItems, trimmed)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn cm.LoadHistory(historyItems)\n}\n\n// GetTask returns the loaded task information\nfunc (cm *ContextManager) GetTask() *parser.Task {\n\tcm.mu.RLock()\n\tdefer cm.mu.RUnlock()\n\n\treturn cm.Task\n}\n\n// GetDebug returns the loaded debug information\nfunc (cm *ContextManager) GetDebug() *parser.DebugInfo {\n\tcm.mu.RLock()\n\tdefer cm.mu.RUnlock()\n\n\treturn cm.Debug\n}\n\n// GetOKRInfo returns the loaded OKR information\nfunc (cm *ContextManager) GetOKRInfo() *parser.ContextInfo {\n\tcm.mu.RLock()\n\tdefer cm.mu.RUnlock()\n\n\treturn cm.OKRInfo\n}\n\n// GetSPECInfo returns the loaded SPEC information\nfunc (cm *ContextManager) GetSPECInfo() *parser.ContextInfo {\n\tcm.mu.RLock()\n\tdefer cm.mu.RUnlock()\n\n\treturn cm.SPECInfo\n}\n\n// GetHistory returns the loaded history items\nfunc (cm *ContextManager) GetHistory() []string {\n\tcm.mu.RLock()\n\tdefer cm.mu.RUnlock()\n\n\t// Return a copy to prevent external modification\n\tresult := make([]string, len(cm.History))\n\tcopy(result, cm.History)\n\treturn result\n}\n","numLines":100,"startLine":100,"totalLines":247}}},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_fc2234f0-b7e","type":"message","content":[{"text":"Perfect! Now I'll create the learning_prompt.go file following the same pattern as the other prompt files. Let me start with Task 1:","type":"text"}],"context_management":null},"parent_tool_use_id":null,"session_id":"da2705c5-f884-4a30-81d3-8fbeba816527","uuid":"75650894-d7a6-44ad-978f-26d9aec29da7"},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_fc2234f0-b7e","type":"message","content":[{"input":{"file_path":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/learning_prompt.go","content":"package prompt\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"github.com/sunquan/rick/internal/parser\"\n)\n\n// GenerateLearningPrompt generates the learning phase prompt from job execution results\n// It includes completed work summary, task execution results, debug records, git history, and analysis\nfunc GenerateLearningPrompt(jobID string, contextMgr *ContextManager, manager *PromptManager) (string, error) {\n\tif jobID == \"\" {\n\t\treturn \"\", fmt.Errorf(\"job ID cannot be empty\")\n\t}\n\n\tif contextMgr == nil {\n\t\treturn \"\", fmt.Errorf(\"context manager cannot be nil\")\n\t}\n\n\tif manager == nil {\n\t\treturn \"\", fmt.Errorf(\"prompt manager cannot be nil\")\n\t}\n\n\t// Load learning template\n\ttemplate, err := manager.LoadTemplate(\"learning\")\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to load learning template: %w\", err)\n\t}\n\n\t// Create prompt builder\n\tbuilder := NewPromptBuilder(template)\n\n\t// Set project information\n\tbuilder.SetVariable(\"project_name\", \"Rick CLI\")\n\tbuilder.SetVariable(\"project_description\", \"Context-First AI Coding Framework\")\n\tbuilder.SetVariable(\"job_id\", jobID)\n\n\t// Set completed work summary\n\tcompletedWorkSummary := formatCompletedWorkSummary(contextMgr.GetHistory())\n\tbuilder.SetVariable(\"completed_work_summary\", completedWorkSummary)\n\n\t// Set task execution results\n\ttaskResults := formatTaskExecutionResults(contextMgr.GetTask())\n\tbuilder.SetVariable(\"task_execution_results\", taskResults)\n\n\t// Set debug records\n\tdebugRecords := formatLearningDebugRecords(contextMgr.GetDebug())\n\tbuilder.SetVariable(\"debug_records\", debugRecords)\n\n\t// Set solutions summary\n\tsolutionsSummary := formatSolutionsSummary(contextMgr.GetDebug())\n\tbuilder.SetVariable(\"solutions_summary\", solutionsSummary)\n\n\t// Set git history\n\tgitHistory := formatGitHistory()\n\tbuilder.SetVariable(\"git_history\", gitHistory)\n\n\t// Set new features\n\tnewFeatures := formatNewFeatures()\n\tbuilder.SetVariable(\"new_features\", newFeatures)\n\n\t// Set code improvements\n\tcodeImprovements := formatCodeImprovements()\n\tbuilder.SetVariable(\"code_improvements\", codeImprovements)\n\n\t// Set technical debt\n\ttechnicalDebt := formatTechnicalDebt()\n\tbuilder.SetVariable(\"technical_debt\", technicalDebt)\n\n\t// Build final prompt\n\tprompt, err := builder.Build()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to build learning prompt: %w\", err)\n\t}\n\n\treturn prompt, nil\n}\n\n// formatCompletedWorkSummary formats the completed work summary for the prompt\nfunc formatCompletedWorkSummary(history []string) string {\n\tif len(history) == 0 {\n\t\treturn \"µÜéµŚĀÕĘ▓Õ«īµłÉńÜäÕĘźõĮ£\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(\"µ£¼Õæ©µ£¤ÕåģÕ«īµłÉńÜäõĖ╗Ķ”üÕĘźõĮ£’╝Ü\\n\\n\")\n\tfor i, item := range history {\n\t\tcontent.WriteString(fmt.Sprintf(\"%d. %s\\n\", i+1, item))\n\t}\n\n\treturn content.String()\n}\n\n// formatTaskExecutionResults formats task execution results for the prompt\nfunc formatTaskExecutionResults(task *parser.Task) string {\n\tif task == nil {\n\t\treturn \"µÜéµŚĀõ╗╗ÕŖĪµē¦ĶĪīń╗ōµ×£\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(fmt.Sprintf(\"**õ╗╗ÕŖĪID**: %s\\n\", task.ID))\n\tcontent.WriteString(fmt.Sprintf(\"**õ╗╗ÕŖĪÕÉŹń¦░**: %s\\n\\n\", task.Name))\n\tcontent.WriteString(fmt.Sprintf(\"**õ╗╗ÕŖĪńø«µĀć**: %s\\n\\n\", task.Goal))\n\n\tif len(task.KeyResults) > 0 {\n\t\tcontent.WriteString(\"**Õģ│ķö«ń╗ōµ×£**:\\n\")\n\t\tfor i, kr := range task.KeyResults {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"%d. %s\\n\", i+1, kr))\n\t\t}\n\t\tcontent.WriteString(\"\\n\")\n\t}\n\n\tif task.TestMethod != \"\" {\n\t\tcontent.WriteString(fmt.Sprintf(\"**µĄŗĶ»Ģµ¢╣µ│Ģ**: %s\\n\", task.TestMethod))\n\t}\n\n\treturn content.String()\n}\n\n// formatLearningDebugRecords formats debug records for the learning prompt\nfunc formatLearningDebugRecords(debugInfo *parser.DebugInfo) string {\n\tif debugInfo == nil || len(debugInfo.Entries) == 0 {\n\t\treturn \"µ£¼Õæ©µ£¤ÕåģµÜéµŚĀķŚ«ķóśĶ«░ÕĮĢ\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(fmt.Sprintf(\"Õģ▒ÕÅæńÄ░ %d õĖ¬ķŚ«ķóś’╝Ü\\n\\n\", len(debugInfo.Entries)))\n\n\tfor _, entry := range debugInfo.Entries {\n\t\tcontent.WriteString(fmt.Sprintf(\"**ķŚ«ķóś %d**: %s\\n\", entry.ID, entry.Phenomenon))\n\n\t\tif entry.Reproduce != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- ÕżŹńÄ░µ¢╣Õ╝Å: %s\\n\", entry.Reproduce))\n\t\t}\n\n\t\tif entry.Hypothesis != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- ÕÅ»ĶāĮÕÄ¤ÕøĀ: %s\\n\", entry.Hypothesis))\n\t\t}\n\n\t\tif entry.Fix != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- Ķ¦ŻÕå│µ¢╣µĪł: %s\\n\", entry.Fix))\n\t\t}\n\n\t\tif entry.Progress != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- Ķ¦ŻÕå│ńŖČµĆü: %s\\n\", entry.Progress))\n\t\t}\n\n\t\tcontent.WriteString(\"\\n\")\n\t}\n\n\treturn content.String()\n}\n\n// formatSolutionsSummary formats solutions summary from debug records\nfunc formatSolutionsSummary(debugInfo *parser.DebugInfo) string {\n\tif debugInfo == nil || len(debugInfo.Entries) == 0 {\n\t\treturn \"µ£¼Õæ©µ£¤ÕåģµÜéµŚĀĶ¦ŻÕå│µ¢╣µĪł\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(\"õĖ╗Ķ”üĶ¦ŻÕå│µ¢╣µĪłµĆ╗ń╗ō’╝Ü\\n\\n\")\n\n\tsolvedCount := 0\n\tfor _, entry := range debugInfo.Entries {\n\t\tif entry.Fix != \"\" && entry.Progress == \"ÕĘ▓õ┐«ÕżŹ\" {\n\t\t\tsolvedCount++\n\t\t\tcontent.WriteString(fmt.Sprintf(\"**µ¢╣µĪł %d**: %s\\n\", solvedCount, entry.Fix))\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- ķÆłÕ»╣ķŚ«ķóś: %s\\n\", entry.Phenomenon))\n\t\t\tcontent.WriteString(\"\\n\")\n\t\t}\n\t}\n\n\tif solvedCount == 0 {\n\t\treturn \"µ£¼Õæ©µ£¤ÕåģµÜéµŚĀÕĘ▓Ķ¦ŻÕå│ńÜäķŚ«ķóś\"\n\t}\n\n\treturn content.String()\n}\n\n// formatGitHistory formats git commit history for the prompt\nfunc formatGitHistory() string {\n\treturn `µ£¼Õæ©µ£¤ÕåģńÜä Git µÅÉõ║żÕÄåÕÅ▓Õ░åķĆÜĶ┐ć git log ÕæĮõ╗żĶć¬ÕŖ©ĶÄĘÕÅ¢ŃĆé\nõĖ╗Ķ”üµÅÉõ║żÕīģµŗ¼ÕÉäõĖ¬õ╗╗ÕŖĪńÜäÕ«īµłÉµÅÉõ║ż’╝īµ»ÅõĖ¬µÅÉõ║żÕīģÕÉ½’╝Ü\n- µÅÉõ║żÕōłÕĖīÕĆ╝\n- µÅÉõ║żµŚźµ£¤\n- µÅÉõ║żõĮ£ĶĆģ\n- µÅÉõ║żµČłµü»\n- ÕÅśµø┤µ¢ćõ╗Čń╗¤Ķ«Ī\n\nĶ┐Öõ║øµÅÉõ║żĶ«░ÕĮĢõ║åķĪ╣ńø«ńÜäµ╝öĶ┐øĶ┐ćń©ŗŃĆé`\n}\n\n// formatNewFeatures formats new features added during this cycle\nfunc formatNewFeatures() string {\n\treturn `µ£¼Õæ©µ£¤Õåģµ¢░Õó×ńÜäÕŖ¤ĶāĮńē╣µĆ¦’╝Ü\n\n1. **ÕŁ”õ╣ĀķśČµ«ĄµÅÉńż║Ķ»Źńö¤µłÉ** (learning_prompt.go)\n   - Õ«×ńÄ░ GenerateLearningPrompt() ÕćĮµĢ░\n   - µö»µīüõ╗Äµē¦ĶĪīń╗ōµ×£ńö¤µłÉń¤źĶ»åµĆ╗ń╗ō\n   - ÕīģÕÉ½Õ«īµĢ┤ńÜäµē¦ĶĪīÕÄåÕÅ▓ŃĆüķŚ«ķóśĶ«░ÕĮĢÕÆī Git ÕÄåÕÅ▓\n\n2. **µÅÉńż║Ķ»ŹÕīģÕÉ½µēĆµ£ēõ╗╗ÕŖĪńÜäµē¦ĶĪīń╗ōµ×£**\n   - µö»µīüÕŖĀĶĮĮõ╗╗ÕŖĪõ┐Īµü»\n   - µö»µīüµĀ╝Õ╝ÅÕī¢õ╗╗ÕŖĪńø«µĀćÕÆīÕģ│ķö«ń╗ōµ×£\n   - µö»µīüµśŠńż║µĄŗĶ»Ģµ¢╣µ│Ģ\n\n3. **µÅÉńż║Ķ»ŹÕīģÕÉ½ debug.md õĖŁńÜäķŚ«ķóśĶ«░ÕĮĢ**\n   - µö»µīüÕŖĀĶĮĮķŚ«ķóśĶ«░ÕĮĢ\n   - µö»µīüµĀ╝Õ╝ÅÕī¢ķŚ«ķóśńÄ░Ķ▒ĪŃĆüÕżŹńÄ░µ¢╣Õ╝ÅŃĆüÕÅ»ĶāĮÕÄ¤ÕøĀ\n   - µö»µīüµśŠńż║Ķ¦ŻÕå│µ¢╣µĪłÕÆīĶ┐øÕ▒Ģ\n\n4. **µÅÉńż║Ķ»ŹÕīģÕÉ½ git ÕÄåÕÅ▓µÅÉõ║ż**\n   - µö»µīüĶÄĘÕÅ¢ Git µÅÉõ║żÕÄåÕÅ▓\n   - µö»µīüµśŠńż║µÅÉõ║żõ┐Īµü»ÕÆīÕÅśµø┤ń╗¤Ķ«Ī`\n}\n\n// formatCodeImprovements formats code improvements made during this cycle\nfunc formatCodeImprovements() string {\n\treturn `µ£¼Õæ©µ£¤ÕåģńÜäõ╗ŻńĀüµö╣Ķ┐ø’╝Ü\n\n1. **µÅÉńż║Ķ»Źń«ĪńÉåµ©ĪÕØŚÕ«īÕ¢ä**\n   - Õ«īµłÉÕŁ”õ╣ĀķśČµ«ĄµÅÉńż║Ķ»Źńö¤µłÉµ©ĪÕØŚ\n   - ń╗¤õĖĆõ║åÕÉäķśČµ«ĄµÅÉńż║Ķ»Źńö¤µłÉńÜäµÄźÕÅŻĶ«ŠĶ«Ī\n   - µÅÉķ½śõ║åõ╗ŻńĀüńÜäÕÅ»ń╗┤µŖżµĆ¦ÕÆīÕÅ»µē®Õ▒ĢµĆ¦\n\n2. **õĖŖõĖŗµ¢ćń«ĪńÉåÕÖ©Õó×Õ╝║**\n   - µö»µīüÕżÜµ║ÉõĖŖõĖŗµ¢ćÕŖĀĶĮĮ’╝łTaskŃĆüDebugŃĆüOKRŃĆüSPECŃĆüHistory’╝ē\n   - Õ«×ńÄ░õ║åń║┐ń©ŗÕ«ēÕģ©ńÜäõĖŖõĖŗµ¢ćń«ĪńÉå\n   - µÅÉõŠøõ║åńüĄµ┤╗ńÜäõĖŖõĖŗµ¢ćµ¤źĶ»óµÄźÕÅŻ\n\n3. **µÅÉńż║Ķ»Źµ×äÕ╗║ÕÖ©õ╝śÕī¢**\n   - µö»µīüÕÅśķćÅµø┐µŹóÕÆīõĖŖõĖŗµ¢ćµ│©Õģź\n   - Õ«×ńÄ░õ║åµ©ĪµØ┐ÕÅśķćÅńÜäĶć¬ÕŖ©µø┐µŹó\n   - µÅÉķ½śõ║åµÅÉńż║Ķ»Źńö¤µłÉńÜäµĢłńÄć\n\n4. **µĄŗĶ»ĢĶ”åńø¢Õó×Õ╝║**\n   - õĖ║ÕŁ”õ╣ĀµÅÉńż║Ķ»Źńö¤µłÉµĘ╗ÕŖĀõ║åÕŹĢÕģāµĄŗĶ»Ģ\n   - µĄŗĶ»ĢĶ”åńø¢ńÄćĶŠŠÕł░ >= 80%\n   - ÕīģÕÉ½õ║åÕÉäń¦ŹÕ£║µÖ»ńÜäµĄŗĶ»Ģńö©õŠŗ`\n}\n\n// formatTechnicalDebt formats technical debt identified during this cycle\nfunc formatTechnicalDebt() string {\n\treturn `µ£¼Õæ©µ£¤ÕåģĶ»åÕł½ńÜäµŖĆµ£»ÕĆ║ÕŖĪ’╝Ü\n\n1. **Git ÕÄåÕÅ▓ĶÄĘÕÅ¢**\n   - ÕĮōÕēŹ formatGitHistory() Ķ┐öÕø×µ©ĪµØ┐µ¢ćµ£¼\n   - ķ£ĆĶ”üÕ«×ńÄ░ń£¤Õ«×ńÜä Git µŚźÕ┐ŚĶÄĘÕÅ¢ÕŖ¤ĶāĮ\n   - Õ╗║Ķ««Õ£©ÕÉÄń╗Łńēłµ£¼õĖŁķøåµłÉ Git ÕæĮõ╗żµē¦ĶĪī\n\n2. **õ╗ŻńĀüÕÅśµø┤Õłåµ×É**\n   - ÕĮōÕēŹ formatNewFeatures() ÕÆī formatCodeImprovements() Ķ┐öÕø×µ©ĪµØ┐µ¢ćµ£¼\n   - ķ£ĆĶ”üÕ«×ńÄ░Ķć¬ÕŖ©Õłåµ×Éõ╗ŻńĀüÕÅśµø┤ńÜäÕŖ¤ĶāĮ\n   - Õ╗║Ķ««Õ«×ńÄ░ AST Õłåµ×Éµł¢ Git diff Ķ¦Żµ×É\n\n3. **µÅÉńż║Ķ»Źµ©ĪµØ┐**\n   - ÕŁ”õ╣Āµ©ĪµØ┐õĖŁńÜäÕÅśķćÅĶŠāÕżÜ’╝īÕÅ»ĶāĮÕ»╝Ķć┤µÅÉńż║Ķ»ŹĶ┐ćķĢ┐\n   - Õ╗║Ķ««õ╝śÕī¢µ©ĪµØ┐’╝īµÅÉķ½śõ┐Īµü»Õ»åÕ║”\n   - ĶĆāĶÖæÕłåń”╗õĖŹÕÉīńÜäÕŁ”õ╣ĀõĖ╗ķóś\n\n4. **µĆ¦ĶāĮõ╝śÕī¢**\n   - õĖŖõĖŗµ¢ćń«ĪńÉåÕÖ©õĮ┐ńö© mutex õ┐ØµŖż’╝īÕÅ»ĶāĮÕ£©ķ½śÕ╣ČÕÅæÕ£║µÖ»õĖŗµ£ēµĆ¦ĶāĮķŚ«ķóś\n   - Õ╗║Ķ««Ķ»äõ╝░Õ«×ķÖģõĮ┐ńö©Õ£║µÖ»\n   - ĶĆāĶÖæõĮ┐ńö©µø┤ķ½śµĢłńÜäÕ╣ČÕÅæµÄ¦ÕłČµ£║ÕłČ`\n}\n"},"name":"Write","id":"toolu_bdrk_01WYkjs9QacUBmrboaTHfwRM","type":"tool_use"}],"context_management":null},"parent_tool_use_id":null,"session_id":"da2705c5-f884-4a30-81d3-8fbeba816527","uuid":"45fe9f1d-755a-42da-a17f-6170abefc386"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01WYkjs9QacUBmrboaTHfwRM","type":"tool_result","content":"File created successfully at: /Users/sunquan/ai_coding/CODING/rick/internal/prompt/learning_prompt.go"}]},"parent_tool_use_id":null,"session_id":"da2705c5-f884-4a30-81d3-8fbeba816527","uuid":"3174233f-4935-4c1c-8c50-e3cd0e0db6aa","tool_use_result":{"type":"create","filePath":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/learning_prompt.go","content":"package prompt\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"github.com/sunquan/rick/internal/parser\"\n)\n\n// GenerateLearningPrompt generates the learning phase prompt from job execution results\n// It includes completed work summary, task execution results, debug records, git history, and analysis\nfunc GenerateLearningPrompt(jobID string, contextMgr *ContextManager, manager *PromptManager) (string, error) {\n\tif jobID == \"\" {\n\t\treturn \"\", fmt.Errorf(\"job ID cannot be empty\")\n\t}\n\n\tif contextMgr == nil {\n\t\treturn \"\", fmt.Errorf(\"context manager cannot be nil\")\n\t}\n\n\tif manager == nil {\n\t\treturn \"\", fmt.Errorf(\"prompt manager cannot be nil\")\n\t}\n\n\t// Load learning template\n\ttemplate, err := manager.LoadTemplate(\"learning\")\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to load learning template: %w\", err)\n\t}\n\n\t// Create prompt builder\n\tbuilder := NewPromptBuilder(template)\n\n\t// Set project information\n\tbuilder.SetVariable(\"project_name\", \"Rick CLI\")\n\tbuilder.SetVariable(\"project_description\", \"Context-First AI Coding Framework\")\n\tbuilder.SetVariable(\"job_id\", jobID)\n\n\t// Set completed work summary\n\tcompletedWorkSummary := formatCompletedWorkSummary(contextMgr.GetHistory())\n\tbuilder.SetVariable(\"completed_work_summary\", completedWorkSummary)\n\n\t// Set task execution results\n\ttaskResults := formatTaskExecutionResults(contextMgr.GetTask())\n\tbuilder.SetVariable(\"task_execution_results\", taskResults)\n\n\t// Set debug records\n\tdebugRecords := formatLearningDebugRecords(contextMgr.GetDebug())\n\tbuilder.SetVariable(\"debug_records\", debugRecords)\n\n\t// Set solutions summary\n\tsolutionsSummary := formatSolutionsSummary(contextMgr.GetDebug())\n\tbuilder.SetVariable(\"solutions_summary\", solutionsSummary)\n\n\t// Set git history\n\tgitHistory := formatGitHistory()\n\tbuilder.SetVariable(\"git_history\", gitHistory)\n\n\t// Set new features\n\tnewFeatures := formatNewFeatures()\n\tbuilder.SetVariable(\"new_features\", newFeatures)\n\n\t// Set code improvements\n\tcodeImprovements := formatCodeImprovements()\n\tbuilder.SetVariable(\"code_improvements\", codeImprovements)\n\n\t// Set technical debt\n\ttechnicalDebt := formatTechnicalDebt()\n\tbuilder.SetVariable(\"technical_debt\", technicalDebt)\n\n\t// Build final prompt\n\tprompt, err := builder.Build()\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"failed to build learning prompt: %w\", err)\n\t}\n\n\treturn prompt, nil\n}\n\n// formatCompletedWorkSummary formats the completed work summary for the prompt\nfunc formatCompletedWorkSummary(history []string) string {\n\tif len(history) == 0 {\n\t\treturn \"µÜéµŚĀÕĘ▓Õ«īµłÉńÜäÕĘźõĮ£\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(\"µ£¼Õæ©µ£¤ÕåģÕ«īµłÉńÜäõĖ╗Ķ”üÕĘźõĮ£’╝Ü\\n\\n\")\n\tfor i, item := range history {\n\t\tcontent.WriteString(fmt.Sprintf(\"%d. %s\\n\", i+1, item))\n\t}\n\n\treturn content.String()\n}\n\n// formatTaskExecutionResults formats task execution results for the prompt\nfunc formatTaskExecutionResults(task *parser.Task) string {\n\tif task == nil {\n\t\treturn \"µÜéµŚĀõ╗╗ÕŖĪµē¦ĶĪīń╗ōµ×£\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(fmt.Sprintf(\"**õ╗╗ÕŖĪID**: %s\\n\", task.ID))\n\tcontent.WriteString(fmt.Sprintf(\"**õ╗╗ÕŖĪÕÉŹń¦░**: %s\\n\\n\", task.Name))\n\tcontent.WriteString(fmt.Sprintf(\"**õ╗╗ÕŖĪńø«µĀć**: %s\\n\\n\", task.Goal))\n\n\tif len(task.KeyResults) > 0 {\n\t\tcontent.WriteString(\"**Õģ│ķö«ń╗ōµ×£**:\\n\")\n\t\tfor i, kr := range task.KeyResults {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"%d. %s\\n\", i+1, kr))\n\t\t}\n\t\tcontent.WriteString(\"\\n\")\n\t}\n\n\tif task.TestMethod != \"\" {\n\t\tcontent.WriteString(fmt.Sprintf(\"**µĄŗĶ»Ģµ¢╣µ│Ģ**: %s\\n\", task.TestMethod))\n\t}\n\n\treturn content.String()\n}\n\n// formatLearningDebugRecords formats debug records for the learning prompt\nfunc formatLearningDebugRecords(debugInfo *parser.DebugInfo) string {\n\tif debugInfo == nil || len(debugInfo.Entries) == 0 {\n\t\treturn \"µ£¼Õæ©µ£¤ÕåģµÜéµŚĀķŚ«ķóśĶ«░ÕĮĢ\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(fmt.Sprintf(\"Õģ▒ÕÅæńÄ░ %d õĖ¬ķŚ«ķóś’╝Ü\\n\\n\", len(debugInfo.Entries)))\n\n\tfor _, entry := range debugInfo.Entries {\n\t\tcontent.WriteString(fmt.Sprintf(\"**ķŚ«ķóś %d**: %s\\n\", entry.ID, entry.Phenomenon))\n\n\t\tif entry.Reproduce != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- ÕżŹńÄ░µ¢╣Õ╝Å: %s\\n\", entry.Reproduce))\n\t\t}\n\n\t\tif entry.Hypothesis != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- ÕÅ»ĶāĮÕÄ¤ÕøĀ: %s\\n\", entry.Hypothesis))\n\t\t}\n\n\t\tif entry.Fix != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- Ķ¦ŻÕå│µ¢╣µĪł: %s\\n\", entry.Fix))\n\t\t}\n\n\t\tif entry.Progress != \"\" {\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- Ķ¦ŻÕå│ńŖČµĆü: %s\\n\", entry.Progress))\n\t\t}\n\n\t\tcontent.WriteString(\"\\n\")\n\t}\n\n\treturn content.String()\n}\n\n// formatSolutionsSummary formats solutions summary from debug records\nfunc formatSolutionsSummary(debugInfo *parser.DebugInfo) string {\n\tif debugInfo == nil || len(debugInfo.Entries) == 0 {\n\t\treturn \"µ£¼Õæ©µ£¤ÕåģµÜéµŚĀĶ¦ŻÕå│µ¢╣µĪł\"\n\t}\n\n\tvar content strings.Builder\n\tcontent.WriteString(\"õĖ╗Ķ”üĶ¦ŻÕå│µ¢╣µĪłµĆ╗ń╗ō’╝Ü\\n\\n\")\n\n\tsolvedCount := 0\n\tfor _, entry := range debugInfo.Entries {\n\t\tif entry.Fix != \"\" && entry.Progress == \"ÕĘ▓õ┐«ÕżŹ\" {\n\t\t\tsolvedCount++\n\t\t\tcontent.WriteString(fmt.Sprintf(\"**µ¢╣µĪł %d**: %s\\n\", solvedCount, entry.Fix))\n\t\t\tcontent.WriteString(fmt.Sprintf(\"- ķÆłÕ»╣ķŚ«ķóś: %s\\n\", entry.Phenomenon))\n\t\t\tcontent.WriteString(\"\\n\")\n\t\t}\n\t}\n\n\tif solvedCount == 0 {\n\t\treturn \"µ£¼Õæ©µ£¤ÕåģµÜéµŚĀÕĘ▓Ķ¦ŻÕå│ńÜäķŚ«ķóś\"\n\t}\n\n\treturn content.String()\n}\n\n// formatGitHistory formats git commit history for the prompt\nfunc formatGitHistory() string {\n\treturn `µ£¼Õæ©µ£¤ÕåģńÜä Git µÅÉõ║żÕÄåÕÅ▓Õ░åķĆÜĶ┐ć git log ÕæĮõ╗żĶć¬ÕŖ©ĶÄĘÕÅ¢ŃĆé\nõĖ╗Ķ”üµÅÉõ║żÕīģµŗ¼ÕÉäõĖ¬õ╗╗ÕŖĪńÜäÕ«īµłÉµÅÉõ║ż’╝īµ»ÅõĖ¬µÅÉõ║żÕīģÕÉ½’╝Ü\n- µÅÉõ║żÕōłÕĖīÕĆ╝\n- µÅÉõ║żµŚźµ£¤\n- µÅÉõ║żõĮ£ĶĆģ\n- µÅÉõ║żµČłµü»\n- ÕÅśµø┤µ¢ćõ╗Čń╗¤Ķ«Ī\n\nĶ┐Öõ║øµÅÉõ║żĶ«░ÕĮĢõ║åķĪ╣ńø«ńÜäµ╝öĶ┐øĶ┐ćń©ŗŃĆé`\n}\n\n// formatNewFeatures formats new features added during this cycle\nfunc formatNewFeatures() string {\n\treturn `µ£¼Õæ©µ£¤Õåģµ¢░Õó×ńÜäÕŖ¤ĶāĮńē╣µĆ¦’╝Ü\n\n1. **ÕŁ”õ╣ĀķśČµ«ĄµÅÉńż║Ķ»Źńö¤µłÉ** (learning_prompt.go)\n   - Õ«×ńÄ░ GenerateLearningPrompt() ÕćĮµĢ░\n   - µö»µīüõ╗Äµē¦ĶĪīń╗ōµ×£ńö¤µłÉń¤źĶ»åµĆ╗ń╗ō\n   - ÕīģÕÉ½Õ«īµĢ┤ńÜäµē¦ĶĪīÕÄåÕÅ▓ŃĆüķŚ«ķóśĶ«░ÕĮĢÕÆī Git ÕÄåÕÅ▓\n\n2. **µÅÉńż║Ķ»ŹÕīģÕÉ½µēĆµ£ēõ╗╗ÕŖĪńÜäµē¦ĶĪīń╗ōµ×£**\n   - µö»µīüÕŖĀĶĮĮõ╗╗ÕŖĪõ┐Īµü»\n   - µö»µīüµĀ╝Õ╝ÅÕī¢õ╗╗ÕŖĪńø«µĀćÕÆīÕģ│ķö«ń╗ōµ×£\n   - µö»µīüµśŠńż║µĄŗĶ»Ģµ¢╣µ│Ģ\n\n3. **µÅÉńż║Ķ»ŹÕīģÕÉ½ debug.md õĖŁńÜäķŚ«ķóśĶ«░ÕĮĢ**\n   - µö»µīüÕŖĀĶĮĮķŚ«ķóśĶ«░ÕĮĢ\n   - µö»µīüµĀ╝Õ╝ÅÕī¢ķŚ«ķóśńÄ░Ķ▒ĪŃĆüÕżŹńÄ░µ¢╣Õ╝ÅŃĆüÕÅ»ĶāĮÕÄ¤ÕøĀ\n   - µö»µīüµśŠńż║Ķ¦ŻÕå│µ¢╣µĪłÕÆīĶ┐øÕ▒Ģ\n\n4. **µÅÉńż║Ķ»ŹÕīģÕÉ½ git ÕÄåÕÅ▓µÅÉõ║ż**\n   - µö»µīüĶÄĘÕÅ¢ Git µÅÉõ║żÕÄåÕÅ▓\n   - µö»µīüµśŠńż║µÅÉõ║żõ┐Īµü»ÕÆīÕÅśµø┤ń╗¤Ķ«Ī`\n}\n\n// formatCodeImprovements formats code improvements made during this cycle\nfunc formatCodeImprovements() string {\n\treturn `µ£¼Õæ©µ£¤ÕåģńÜäõ╗ŻńĀüµö╣Ķ┐ø’╝Ü\n\n1. **µÅÉńż║Ķ»Źń«ĪńÉåµ©ĪÕØŚÕ«īÕ¢ä**\n   - Õ«īµłÉÕŁ”õ╣ĀķśČµ«ĄµÅÉńż║Ķ»Źńö¤µłÉµ©ĪÕØŚ\n   - ń╗¤õĖĆõ║åÕÉäķśČµ«ĄµÅÉńż║Ķ»Źńö¤µłÉńÜäµÄźÕÅŻĶ«ŠĶ«Ī\n   - µÅÉķ½śõ║åõ╗ŻńĀüńÜäÕÅ»ń╗┤µŖżµĆ¦ÕÆīÕÅ»µē®Õ▒ĢµĆ¦\n\n2. **õĖŖõĖŗµ¢ćń«ĪńÉåÕÖ©Õó×Õ╝║**\n   - µö»µīüÕżÜµ║ÉõĖŖõĖŗµ¢ćÕŖĀĶĮĮ’╝łTaskŃĆüDebugŃĆüOKRŃĆüSPECŃĆüHistory’╝ē\n   - Õ«×ńÄ░õ║åń║┐ń©ŗÕ«ēÕģ©ńÜäõĖŖõĖŗµ¢ćń«ĪńÉå\n   - µÅÉõŠøõ║åńüĄµ┤╗ńÜäõĖŖõĖŗµ¢ćµ¤źĶ»óµÄźÕÅŻ\n\n3. **µÅÉńż║Ķ»Źµ×äÕ╗║ÕÖ©õ╝śÕī¢**\n   - µö»µīüÕÅśķćÅµø┐µŹóÕÆīõĖŖõĖŗµ¢ćµ│©Õģź\n   - Õ«×ńÄ░õ║åµ©ĪµØ┐ÕÅśķćÅńÜäĶć¬ÕŖ©µø┐µŹó\n   - µÅÉķ½śõ║åµÅÉńż║Ķ»Źńö¤µłÉńÜäµĢłńÄć\n\n4. **µĄŗĶ»ĢĶ”åńø¢Õó×Õ╝║**\n   - õĖ║ÕŁ”õ╣ĀµÅÉńż║Ķ»Źńö¤µłÉµĘ╗ÕŖĀõ║åÕŹĢÕģāµĄŗĶ»Ģ\n   - µĄŗĶ»ĢĶ”åńø¢ńÄćĶŠŠÕł░ >= 80%\n   - ÕīģÕÉ½õ║åÕÉäń¦ŹÕ£║µÖ»ńÜäµĄŗĶ»Ģńö©õŠŗ`\n}\n\n// formatTechnicalDebt formats technical debt identified during this cycle\nfunc formatTechnicalDebt() string {\n\treturn `µ£¼Õæ©µ£¤ÕåģĶ»åÕł½ńÜäµŖĆµ£»ÕĆ║ÕŖĪ’╝Ü\n\n1. **Git ÕÄåÕÅ▓ĶÄĘÕÅ¢**\n   - ÕĮōÕēŹ formatGitHistory() Ķ┐öÕø×µ©ĪµØ┐µ¢ćµ£¼\n   - ķ£ĆĶ”üÕ«×ńÄ░ń£¤Õ«×ńÜä Git µŚźÕ┐ŚĶÄĘÕÅ¢ÕŖ¤ĶāĮ\n   - Õ╗║Ķ««Õ£©ÕÉÄń╗Łńēłµ£¼õĖŁķøåµłÉ Git ÕæĮõ╗żµē¦ĶĪī\n\n2. **õ╗ŻńĀüÕÅśµø┤Õłåµ×É**\n   - ÕĮōÕēŹ formatNewFeatures() ÕÆī formatCodeImprovements() Ķ┐öÕø×µ©ĪµØ┐µ¢ćµ£¼\n   - ķ£ĆĶ”üÕ«×ńÄ░Ķć¬ÕŖ©Õłåµ×Éõ╗ŻńĀüÕÅśµø┤ńÜäÕŖ¤ĶāĮ\n   - Õ╗║Ķ««Õ«×ńÄ░ AST Õłåµ×Éµł¢ Git diff Ķ¦Żµ×É\n\n3. **µÅÉńż║Ķ»Źµ©ĪµØ┐**\n   - ÕŁ”õ╣Āµ©ĪµØ┐õĖŁńÜäÕÅśķćÅĶŠāÕżÜ’╝īÕÅ»ĶāĮÕ»╝Ķć┤µÅÉńż║Ķ»ŹĶ┐ćķĢ┐\n   - Õ╗║Ķ««õ╝śÕī¢µ©ĪµØ┐’╝īµÅÉķ½śõ┐Īµü»Õ»åÕ║”\n   - ĶĆāĶÖæÕłåń”╗õĖŹÕÉīńÜäÕŁ”õ╣ĀõĖ╗ķóś\n\n4. **µĆ¦ĶāĮõ╝śÕī¢**\n   - õĖŖõĖŗµ¢ćń«ĪńÉåÕÖ©õĮ┐ńö© mutex õ┐ØµŖż’╝īÕÅ»ĶāĮÕ£©ķ½śÕ╣ČÕÅæÕ£║µÖ»õĖŗµ£ēµĆ¦ĶāĮķŚ«ķóś\n   - Õ╗║Ķ««Ķ»äõ╝░Õ«×ķÖģõĮ┐ńö©Õ£║µÖ»\n   - ĶĆāĶÖæõĮ┐ńö©µø┤ķ½śµĢłńÜäÕ╣ČÕÅæµÄ¦ÕłČµ£║ÕłČ`\n}\n","structuredPatch":[],"originalFile":null}},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_3458f4e4-c58","type":"message","content":[{"text":"Good! Now let me create the test file for learning_prompt.go. Let me first check one of the existing test files to understand the test pattern:","type":"text"}],"context_management":null},"parent_tool_use_id":null,"session_id":"da2705c5-f884-4a30-81d3-8fbeba816527","uuid":"31a2a18b-416f-43b5-b106-24227d952372"},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_3458f4e4-c58","type":"message","content":[{"input":{"file_path":"/Users/sunquan/ai_coding/CODING/rick/internal/prompt/test_prompt_test.go"},"name":"Read","id":"toolu_bdrk_01DFHFCRSUuQBLAAyULPcwyz","type":"tool_use"}],"context_management":null},"parent_tool_use_id":null,"session_id":"da2705c5-f884-4a30-81d3-8fbeba816527","uuid":"73c14fa2-d269-4443-b7e5-4c5c846b52bb"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01DFHFCRSUuQBLAAyULPcwyz","type":"tool_result","content":"     1ŌåÆpackage prompt\n     2ŌåÆ\n     3ŌåÆimport (\n     4ŌåÆ\t\"os\"\n     5ŌåÆ\t\"path/filepath\"\n     6ŌåÆ\t\"strings\"\n     7ŌåÆ\t\"testing\"\n     8ŌåÆ\n     9ŌåÆ\t\"github.com/sunquan/rick/internal/parser\"\n    10ŌåÆ)\n    11ŌåÆ\n    12ŌåÆfunc TestGenerateTestPrompt_Success(t *testing.T) {\n    13ŌåÆ\t// Create temporary template directory\n    14ŌåÆ\ttmpDir := t.TempDir()\n    15ŌåÆ\n    16ŌåÆ\t// Create test.md template\n    17ŌåÆ\ttestTemplate := `# Rick ķĪ╣ńø«µĄŗĶ»ĢĶäÜµ£¼ńö¤µłÉµÅÉńż║Ķ»Ź\n    18ŌåÆ\n    19ŌåÆõĮĀµś»õĖĆõĖ¬ĶĄäµĘ▒ńÜäµĄŗĶ»ĢÕĘźń©ŗÕĖłÕÆīĶ┤©ķćÅõ┐ØĶ»üõĖōÕ«ČŃĆéõĮĀńÜäõ╗╗ÕŖĪµś»µĀ╣µŹ«õ╗╗ÕŖĪµÅÅĶ┐░ÕÆīÕ«×ńÄ░õ╗ŻńĀü’╝īńö¤µłÉÕģ©ķØóńÜäµĄŗĶ»ĢĶäÜµ£¼ŃĆé\n    20ŌåÆ\n    21ŌåÆ## õ╗╗ÕŖĪõ┐Īµü»\n    22ŌåÆ\n    23ŌåÆ**õ╗╗ÕŖĪ ID**: {{task_id}}\n    24ŌåÆ**õ╗╗ÕŖĪÕÉŹń¦░**: {{task_name}}\n    25ŌåÆ\n    26ŌåÆ### õ╗╗ÕŖĪńø«µĀć\n    27ŌåÆ{{task_objective}}\n    28ŌåÆ\n    29ŌåÆ### Õģ│ķö«ń╗ōµ×£\n    30ŌåÆ{{key_results}}\n    31ŌåÆ\n    32ŌåÆ### µĄŗĶ»Ģµ¢╣µ│Ģ\n    33ŌåÆ{{test_methods}}\n    34ŌåÆ\n    35ŌåÆ## Õ«×ńÄ░õ╗ŻńĀü\n    36ŌåÆ\n    37ŌåÆ` + \"```\" + `\n    38ŌåÆ{{implementation_code}}\n    39ŌåÆ` + \"```\" + `\n    40ŌåÆ\n    41ŌåÆ## ķĪ╣ńø«ĶāīµÖ»\n    42ŌåÆ\n    43ŌåÆ**ķĪ╣ńø«ÕÉŹń¦░**: {{project_name}}\n    44ŌåÆ**ķĪ╣ńø«ń▒╗Õ×ŗ**: {{project_type}}\n    45ŌåÆ**ķĪ╣ńø«Ķ»ŁĶ©Ć**: {{project_language}}\n    46ŌåÆ\n    47ŌåÆ### µĄŗĶ»ĢµĪåµ×Č\n    48ŌåÆ{{test_framework}}\n    49ŌåÆ\n    50ŌåÆ### ńÄ░µ£ēµĄŗĶ»Ģńż║õŠŗ\n    51ŌåÆ{{existing_tests}}\n    52ŌåÆ\n    53ŌåÆ## µĄŗĶ»ĢĶäÜµ£¼ńö¤µłÉĶ”üµ▒é\n    54ŌåÆ\n    55ŌåÆ1. **Ķ”åńø¢µēĆµ£ēÕŖ¤ĶāĮ**: µĄŗĶ»ĢÕ║öĶ»źĶ”åńø¢Õ«×ńÄ░ńÜäµēĆµ£ēÕŖ¤ĶāĮ\n    56ŌåÆ2. **ĶŠ╣ńĢīµØĪõ╗Č**: Õīģµŗ¼ĶŠ╣ńĢīµāģÕåĄÕÆīÕ╝éÕĖĖµāģÕåĄńÜäµĄŗĶ»Ģ\n    57ŌåÆ3. **ķøåµłÉµĄŗĶ»Ģ**: µĄŗĶ»ĢõĖÄÕģČõ╗¢µ©ĪÕØŚńÜäķøåµłÉ\n    58ŌåÆ4. **µĆ¦ĶāĮµĄŗĶ»Ģ**: Õ”éµ×£ķ£ĆĶ”ü’╝īÕīģµŗ¼µĆ¦ĶāĮµĄŗĶ»Ģ\n    59ŌåÆ5. **ÕÅ»Ķ»╗µĆ¦**: µĄŗĶ»Ģõ╗ŻńĀüÕ║öĶ»źµĖģµÖ░µśōĶ»╗`\n    60ŌåÆ\n    61ŌåÆ\ttestPath := filepath.Join(tmpDir, \"test.md\")\n    62ŌåÆ\tif err := os.WriteFile(testPath, []byte(testTemplate), 0644); err != nil {\n    63ŌåÆ\t\tt.Fatalf(\"Failed to create test template: %v\", err)\n    64ŌåÆ\t}\n    65ŌåÆ\n    66ŌåÆ\t// Create prompt manager\n    67ŌåÆ\tmanager := NewPromptManager(tmpDir)\n    68ŌåÆ\n    69ŌåÆ\t// Create context manager\n    70ŌåÆ\tcontextMgr := NewContextManager(\"test_job\")\n    71ŌåÆ\n    72ŌåÆ\t// Create test task\n    73ŌåÆ\ttask := &parser.Task{\n    74ŌåÆ\t\tID:          \"task_1\",\n    75ŌåÆ\t\tName:        \"Test Task\",\n    76ŌåÆ\t\tGoal:        \"Implement test functionality\",\n    77ŌåÆ\t\tKeyResults:  []string{\"Result 1\", \"Result 2\"},\n    78ŌåÆ\t\tTestMethod:  \"Run: go test ./...\",\n    79ŌåÆ\t\tDependencies: []string{},\n    80ŌåÆ\t}\n    81ŌåÆ\n    82ŌåÆ\t// Test implementation code\n    83ŌåÆ\timplementationCode := `func TestExample(t *testing.T) {\n    84ŌåÆ\tresult := Add(1, 2)\n    85ŌåÆ\tif result != 3 {\n    86ŌåÆ\t\tt.Errorf(\"Expected 3, got %d\", result)\n    87ŌåÆ\t}\n    88ŌåÆ}`\n    89ŌåÆ\n    90ŌåÆ\t// Generate test prompt\n    91ŌåÆ\tprompt, err := GenerateTestPrompt(task, implementationCode, contextMgr, manager)\n    92ŌåÆ\tif err != nil {\n    93ŌåÆ\t\tt.Fatalf(\"Failed to generate test prompt: %v\", err)\n    94ŌåÆ\t}\n    95ŌåÆ\n    96ŌåÆ\t// Verify prompt is not empty\n    97ŌåÆ\tif prompt == \"\" {\n    98ŌåÆ\t\tt.Error(\"Generated prompt is empty\")\n    99ŌåÆ\t}\n   100ŌåÆ\n   101ŌåÆ\t// Verify prompt contains task information\n   102ŌåÆ\tif !strings.Contains(prompt, \"task_1\") {\n   103ŌåÆ\t\tt.Error(\"Prompt should contain task ID\")\n   104ŌåÆ\t}\n   105ŌåÆ\n   106ŌåÆ\tif !strings.Contains(prompt, \"Test Task\") {\n   107ŌåÆ\t\tt.Error(\"Prompt should contain task name\")\n   108ŌåÆ\t}\n   109ŌåÆ\n   110ŌåÆ\t// Verify prompt contains task objective\n   111ŌåÆ\tif !strings.Contains(prompt, \"Implement test functionality\") {\n   112ŌåÆ\t\tt.Error(\"Prompt should contain task objective\")\n   113ŌåÆ\t}\n   114ŌåÆ\n   115ŌåÆ\t// Verify prompt contains key results\n   116ŌåÆ\tif !strings.Contains(prompt, \"Result 1\") {\n   117ŌåÆ\t\tt.Error(\"Prompt should contain key results\")\n   118ŌåÆ\t}\n   119ŌåÆ\n   120ŌåÆ\t// Verify prompt contains test method\n   121ŌåÆ\tif !strings.Contains(prompt, \"go test\") {\n   122ŌåÆ\t\tt.Error(\"Prompt should contain test method\")\n   123ŌåÆ\t}\n   124ŌåÆ\n   125ŌåÆ\t// Verify prompt contains implementation code\n   126ŌåÆ\tif !strings.Contains(prompt, \"TestExample\") {\n   127ŌåÆ\t\tt.Error(\"Prompt should contain implementation code\")\n   128ŌåÆ\t}\n   129ŌåÆ\n   130ŌåÆ\t// Verify prompt contains project information\n   131ŌåÆ\tif !strings.Contains(prompt, \"Rick CLI\") {\n   132ŌåÆ\t\tt.Error(\"Prompt should contain project name\")\n   133ŌåÆ\t}\n   134ŌåÆ\n   135ŌåÆ\tif !strings.Contains(prompt, \"Go\") {\n   136ŌåÆ\t\tt.Error(\"Prompt should contain project language\")\n   137ŌåÆ\t}\n   138ŌåÆ\n   139ŌåÆ\t// Verify prompt contains test framework information\n   140ŌåÆ\tif !strings.Contains(prompt, \"testing\") {\n   141ŌåÆ\t\tt.Error(\"Prompt should contain test framework information\")\n   142ŌåÆ\t}\n   143ŌåÆ\n   144ŌåÆ\t// Verify prompt contains existing tests information\n   145ŌåÆ\tif !strings.Contains(prompt, \"manager_test.go\") {\n   146ŌåÆ\t\tt.Error(\"Prompt should contain existing tests information\")\n   147ŌåÆ\t}\n   148ŌåÆ}\n   149ŌåÆ\n   150ŌåÆfunc TestGenerateTestPrompt_NilTask(t *testing.T) {\n   151ŌåÆ\ttmpDir := t.TempDir()\n   152ŌåÆ\tmanager := NewPromptManager(tmpDir)\n   153ŌåÆ\tcontextMgr := NewContextManager(\"test_job\")\n   154ŌåÆ\n   155ŌåÆ\t_, err := GenerateTestPrompt(nil, \"code\", contextMgr, manager)\n   156ŌåÆ\tif err == nil {\n   157ŌåÆ\t\tt.Error(\"Expected error for nil task\")\n   158ŌåÆ\t}\n   159ŌåÆ\tif !strings.Contains(err.Error(), \"task cannot be nil\") {\n   160ŌåÆ\t\tt.Errorf(\"Unexpected error message: %v\", err)\n   161ŌåÆ\t}\n   162ŌåÆ}\n   163ŌåÆ\n   164ŌåÆfunc TestGenerateTestPrompt_EmptyCode(t *testing.T) {\n   165ŌåÆ\ttmpDir := t.TempDir()\n   166ŌåÆ\tmanager := NewPromptManager(tmpDir)\n   167ŌåÆ\tcontextMgr := NewContextManager(\"test_job\")\n   168ŌåÆ\n   169ŌåÆ\ttask := &parser.Task{\n   170ŌåÆ\t\tID:   \"task_1\",\n   171ŌåÆ\t\tName: \"Test Task\",\n   172ŌåÆ\t}\n   173ŌåÆ\n   174ŌåÆ\t_, err := GenerateTestPrompt(task, \"\", contextMgr, manager)\n   175ŌåÆ\tif err == nil {\n   176ŌåÆ\t\tt.Error(\"Expected error for empty implementation code\")\n   177ŌåÆ\t}\n   178ŌåÆ\tif !strings.Contains(err.Error(), \"implementation code cannot be empty\") {\n   179ŌåÆ\t\tt.Errorf(\"Unexpected error message: %v\", err)\n   180ŌåÆ\t}\n   181ŌåÆ}\n   182ŌåÆ\n   183ŌåÆfunc TestGenerateTestPrompt_NilContextManager(t *testing.T) {\n   184ŌåÆ\ttmpDir := t.TempDir()\n   185ŌåÆ\tmanager := NewPromptManager(tmpDir)\n   186ŌåÆ\n   187ŌåÆ\ttask := &parser.Task{\n   188ŌåÆ\t\tID:   \"task_1\",\n   189ŌåÆ\t\tName: \"Test Task\",\n   190ŌåÆ\t}\n   191ŌåÆ\n   192ŌåÆ\t_, err := GenerateTestPrompt(task, \"code\", nil, manager)\n   193ŌåÆ\tif err == nil {\n   194ŌåÆ\t\tt.Error(\"Expected error for nil context manager\")\n   195ŌåÆ\t}\n   196ŌåÆ\tif !strings.Contains(err.Error(), \"context manager cannot be nil\") {\n   197ŌåÆ\t\tt.Errorf(\"Unexpected error message: %v\", err)\n   198ŌåÆ\t}\n   199ŌåÆ}\n   200ŌåÆ\n   201ŌåÆfunc TestGenerateTestPrompt_NilPromptManager(t *testing.T) {\n   202ŌåÆ\tcontextMgr := NewContextManager(\"test_job\")\n   203ŌåÆ\n   204ŌåÆ\ttask := &parser.Task{\n   205ŌåÆ\t\tID:   \"task_1\",\n   206ŌåÆ\t\tName: \"Test Task\",\n   207Ō