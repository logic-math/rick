x functionality\",\n   261ŌåÆ\t}\n   262ŌåÆ\n   263ŌåÆ\t// Complex implementation code with multiple functions\n   264ŌåÆ\tcomplexCode := `package example\n   265ŌåÆ\n   266ŌåÆimport \"testing\"\n   267ŌåÆ\n   268ŌåÆfunc TestAdd(t *testing.T) {\n   269ŌåÆ\tcases := []struct {\n   270ŌåÆ\t\ta, b, want int\n   271ŌåÆ\t}{\n   272ŌåÆ\t\t{1, 2, 3},\n   273ŌåÆ\t\t{0, 0, 0},\n   274ŌåÆ\t\t{-1, 1, 0},\n   275ŌåÆ\t}\n   276ŌåÆ\tfor _, c := range cases {\n   277ŌåÆ\t\tif got := Add(c.a, c.b); got != c.want {\n   278ŌåÆ\t\t\tt.Errorf(\"Add(%d, %d) = %d, want %d\", c.a, c.b, got, c.want)\n   279ŌåÆ\t\t}\n   280ŌåÆ\t}\n   281ŌåÆ}\n   282ŌåÆ\n   283ŌåÆfunc TestMultiply(t *testing.T) {\n   284ŌåÆ\tresult := Multiply(3, 4)\n   285ŌåÆ\tif result != 12 {\n   286ŌåÆ\t\tt.Errorf(\"Expected 12, got %d\", result)\n   287ŌåÆ\t}\n   288ŌåÆ}`\n   289ŌåÆ\n   290ŌåÆ\tprompt, err := GenerateTestPrompt(task, complexCode, contextMgr, manager)\n   291ŌåÆ\tif err != nil {\n   292ŌåÆ\t\tt.Fatalf(\"Failed to generate test prompt: %v\", err)\n   293ŌåÆ\t}\n   294ŌåÆ\n   295ŌåÆ\t// Verify complex code is preserved in prompt\n   296ŌåÆ\tif !strings.Contains(prompt, \"TestAdd\") {\n   297ŌåÆ\t\tt.Error(\"Prompt should contain TestAdd function\")\n   298ŌåÆ\t}\n   299ŌåÆ\n   300ŌåÆ\tif !strings.Contains(prompt, \"TestMultiply\") {\n   301ŌåÆ\t\tt.Error(\"Prompt should contain TestMultiply function\")\n   302ŌåÆ\t}\n   303ŌåÆ\n   304ŌåÆ\tif !strings.Contains(prompt, \"table-driven test\") || !strings.Contains(prompt, \"cases\") {\n   305ŌåÆ\t\t// Code structure should be preserved\n   306ŌåÆ\t\tif !strings.Contains(prompt, \"cases :=\") {\n   307ŌåÆ\t\t\tt.Error(\"Prompt should preserve code structure\")\n   308ŌåÆ\t\t}\n   309ŌåÆ\t}\n   310ŌåÆ}\n   311ŌåÆ\n   312ŌåÆfunc TestGenerateTestPrompt_WithMultipleKeyResults(t *testing.T) {\n   313ŌåÆ\ttmpDir := t.TempDir()\n   314ŌåÆ\n   315ŌåÆ\ttestTemplate := `# Test Prompt\n   316ŌåÆ\n   317ŌåÆTask: {{task_id}}\n   318ŌåÆObjective: {{task_objective}}\n   319ŌåÆKey Results: {{key_results}}\n   320ŌåÆTest Methods: {{test_methods}}`\n   321ŌåÆ\n   322ŌåÆ\ttestPath := filepath.Join(tmpDir, \"test.md\")\n   323ŌåÆ\tif err := os.WriteFile(testPath, []byte(testTemplate), 0644); err != nil {\n   324ŌåÆ\t\tt.Fatalf(\"Failed to create test template: %v\", err)\n   325ŌåÆ\t}\n   326ŌåÆ\n   327ŌåÆ\tmanager := NewPromptManager(tmpDir)\n   328ŌåÆ\tcontextMgr := NewContextManager(\"test_job\")\n   329ŌåÆ\n   330ŌåÆ\ttask := &parser.Task{\n   331ŌåÆ\t\tID:   \"task_1\",\n   332ŌåÆ\t\tName: \"Test Task\",\n   333ŌåÆ\t\tGoal: \"Implement comprehensive testing\",\n   334ŌåÆ\t\tKeyResults: []string{\n   335ŌåÆ\t\t\t\"All functions have unit tests\",\n   336ŌåÆ\t\t\t\"Test coverage >= 80%\",\n   337ŌåÆ\t\t\t\"Edge cases are covered\",\n   338ŌåÆ\t\t\t\"Performance tests pass\",\n   339ŌåÆ\t\t},\n   340ŌåÆ\t\tTestMethod: \"go test -cover ./internal/prompt\",\n   341ŌåÆ\t}\n   342ŌåÆ\n   343ŌåÆ\tprompt, err := GenerateTestPrompt(task, \"func TestExample(t *testing.T) {}\", contextMgr, manager)\n   344ŌåÆ\tif err != nil {\n   345ŌåÆ\t\tt.Fatalf(\"Failed to generate test prompt: %v\", err)\n   346ŌåÆ\t}\n   347ŌåÆ\n   348ŌåÆ\t// Verify all key results are included\n   349ŌåÆ\tfor i, kr := range task.KeyResults {\n   350ŌåÆ\t\tif !strings.Contains(prompt, kr) {\n   351ŌåÆ\t\t\tt.Errorf(\"Prompt should contain key result %d: %s\", i+1, kr)\n   352ŌåÆ\t\t}\n   353ŌåÆ\t}\n   354ŌåÆ\n   355ŌåÆ\t// Verify test method is included\n   356ŌåÆ\tif !strings.Contains(prompt, \"go test -cover\") {\n   357ŌåÆ\t\tt.Error(\"Prompt should contain test method\")\n   358ŌåÆ\t}\n   359ŌåÆ}\n   360ŌåÆ\n   361ŌåÆfunc TestGenerateTestPrompt_PromptStructure(t *testing.T) {\n   362ŌåÆ\ttmpDir := t.TempDir()\n   363ŌåÆ\n   364ŌåÆ\t// Create test.md template with all sections\n   365ŌåÆ\ttestTemplate := `# Rick ķĪ╣ńø«µĄŗĶ»ĢĶäÜµ£¼ńö¤µłÉµÅÉńż║Ķ»Ź\n   366ŌåÆ\n   367ŌåÆ## õ╗╗ÕŖĪõ┐Īµü»\n   368ŌåÆ\n   369ŌåÆTask ID: {{task_id}}\n   370ŌåÆTask Name: {{task_name}}\n   371ŌåÆ\n   372ŌåÆ## Õ«×ńÄ░õ╗ŻńĀü\n   373ŌåÆ\n   374ŌåÆ{{implementation_code}}\n   375ŌåÆ\n   376ŌåÆ## ķĪ╣ńø«õ┐Īµü»\n   377ŌåÆ\n   378ŌåÆName: {{project_name}}\n   379ŌåÆType: {{project_type}}\n   380ŌåÆLanguage: {{project_language}}\n   381ŌåÆ\n   382ŌåÆ## µĄŗĶ»ĢµĪåµ×Č\n   383ŌåÆ\n   384ŌåÆ{{test_framework}}\n   385ŌåÆ\n   386ŌåÆ## ńÄ░µ£ēµĄŗĶ»Ģ\n   387ŌåÆ\n   388ŌåÆ{{existing_tests}}`\n   389ŌåÆ\n   390ŌåÆ\ttestPath := filepath.Join(tmpDir, \"test.md\")\n   391ŌåÆ\tif err := os.WriteFile(testPath, []byte(testTemplate), 0644); err != nil {\n   392ŌåÆ\t\tt.Fatalf(\"Failed to create test template: %v\", err)\n   393ŌåÆ\t}\n   394ŌåÆ\n   395ŌåÆ\tmanager := NewPromptManager(tmpDir)\n   396ŌåÆ\tcontextMgr := NewContextManager(\"test_job\")\n   397ŌåÆ\n   398ŌåÆ\ttask := &parser.Task{\n   399ŌåÆ\t\tID:   \"task_1\",\n   400ŌåÆ\t\tName: \"Test Task\",\n   401ŌåÆ\t}\n   402ŌåÆ\n   403ŌåÆ\tprompt, err := GenerateTestPrompt(task, \"code\", contextMgr, manager)\n   404ŌåÆ\tif err != nil {\n   405ŌåÆ\t\tt.Fatalf(\"Failed to generate test prompt: %v\", err)\n   406ŌåÆ\t}\n   407ŌåÆ\n   408ŌåÆ\t// Verify prompt has expected sections\n   409ŌåÆ\tif !strings.Contains(prompt, \"## õ╗╗ÕŖĪõ┐Īµü»\") {\n   410ŌåÆ\t\tt.Error(\"Prompt should contain task information section\")\n   411ŌåÆ\t}\n   412ŌåÆ\n   413ŌåÆ\tif !strings.Contains(prompt, \"## Õ«×ńÄ░õ╗ŻńĀü\") {\n   414ŌåÆ\t\tt.Error(\"Prompt should contain implementation code section\")\n   415ŌåÆ\t}\n   416ŌåÆ\n   417ŌåÆ\tif !strings.Contains(prompt, \"## ķĪ╣ńø«õ┐Īµü»\") {\n   418ŌåÆ\t\tt.Error(\"Prompt should contain project information section\")\n   419ŌåÆ\t}\n   420ŌåÆ\n   421ŌåÆ\tif !strings.Contains(prompt, \"## µĄŗĶ»ĢµĪåµ×Č\") {\n   422ŌåÆ\t\tt.Error(\"Prompt should contain test framework section\")\n   423ŌåÆ\t}\n   424ŌåÆ\n   425ŌåÆ\tif !strings.Contains(prompt, \"## ńÄ░µ£ēµĄŗĶ»Ģ\") {\n   426ŌåÆ\t\tt.Error(\"Prompt should contain existing tests section\")\n   427ŌåÆ\t}\n   428ŌåÆ}\n   429ŌåÆ\n   430ŌåÆfunc TestFormatTestFramework(t *testing.T) {\n   431ŌåÆ\tframework := formatTestFramework()\n   432ŌåÆ\n   433ŌåÆ\t// Verify framework information is present\n   434ŌåÆ\tif !strings.Contains(framework, \"testing\") {\n   435ŌåÆ\t\tt.Error(\"Framework should mention testing package\")\n   436ŌåÆ\t}\n   437ŌåÆ\n   438ŌåÆ\tif !strings.Contains(framework, \"testing.T\") {\n   439ŌåÆ\t\tt.Error(\"Framework should mention testing.T\")\n   440ŌåÆ\t}\n   441ŌåÆ\n   442ŌåÆ\tif !strings.Contains(framework, \"*_test.go\") {\n   443ŌåÆ\t\tt.Error(\"Framework should mention test file naming convention\")\n   444ŌåÆ\t}\n   445ŌåÆ\n   446ŌåÆ\tif !strings.Contains(framework, \"go test\") {\n   447ŌåÆ\t\tt.Error(\"Framework should mention go test command\")\n   448ŌåÆ\t}\n   449ŌåÆ\n   450ŌåÆ\tif !strings.Contains(framework, \"t.Errorf\") {\n   451ŌåÆ\t\tt.Error(\"Framework should mention error reporting\")\n   452ŌåÆ\t}\n   453ŌåÆ}\n   454ŌåÆ\n   455ŌåÆfunc TestFormatExistingTests(t *testing.T) {\n   456ŌåÆ\ttests := formatExistingTests()\n   457ŌåÆ\n   458ŌåÆ\t// Verify existing tests information is present\n   459ŌåÆ\tif !strings.Contains(tests, \"manager_test.go\") {\n   460ŌåÆ\t\tt.Error(\"Should mention manager_test.go\")\n   461ŌåÆ\t}\n   462ŌåÆ\n   463ŌåÆ\tif !strings.Contains(tests, \"builder_test.go\") {\n   464ŌåÆ\t\tt.Error(\"Should mention builder_test.go\")\n   465ŌåÆ\t}\n   466ŌåÆ\n   467ŌåÆ\tif !strings.Contains(tests, \"context_test.go\") {\n   468ŌåÆ\t\tt.Error(\"Should mention context_test.go\")\n   469ŌåÆ\t}\n   470ŌåÆ\n   471ŌåÆ\tif !strings.Contains(tests, \"plan_prompt_test.go\") {\n   472ŌåÆ\t\tt.Error(\"Should mention plan_prompt_test.go\")\n   473ŌåÆ\t}\n   474ŌåÆ\n   475ŌåÆ\tif !strings.Contains(tests, \"doing_prompt_test.go\") {\n   476ŌåÆ\t\tt.Error(\"Should mention doing_prompt_test.go\")\n   477ŌåÆ\t}\n   478ŌåÆ\n   479ŌåÆ\tif !strings.Contains(tests, \"ĶĪ©ķ®▒ÕŖ©µĄŗĶ»Ģ\") {\n   480ŌåÆ\t\tt.Error(\"Should mention table-driven tests\")\n   481ŌåÆ\t}\n   482ŌåÆ\n   483ŌåÆ\tif !strings.Contains(tests, \"Arrange-Act-Assert\") {\n   484ŌåÆ\t\tt.Error(\"Should mention AAA pattern\")\n   485ŌåÆ\t}\n   486ŌåÆ}\n   487ŌåÆ\n   488ŌåÆfunc TestGenerateTestPrompt_VariableReplacement(t *testing.T) {\n   489ŌåÆ\ttmpDir := t.TempDir()\n   490ŌåÆ\n   491ŌåÆ\t// Create test.md template with all variables\n   492ŌåÆ\ttestTemplate := `# Test Prompt\n   493ŌåÆ\n   494ŌåÆTask: {{task_id}} - {{task_name}}\n   495ŌåÆObjective: {{task_objective}}\n   496ŌåÆResults: {{key_results}}\n   497ŌåÆMethods: {{test_methods}}\n   498ŌåÆCode: {{implementation_code}}\n   499ŌåÆProject: {{project_name}} ({{project_type}}, {{project_language}})\n   500ŌåÆFramework: {{test_framework}}\n   501ŌåÆTests: {{existing_tests}}`\n   502ŌåÆ\n   503ŌåÆ\ttestPath := filepath.Join(tmpDir, \"test.md\")\n   504ŌåÆ\tif err := os.WriteFile(testPath, []byte(testTemplate), 0644); err != nil {\n   505ŌåÆ\t\tt.Fatalf(\"Failed to create test template: %v\", err)\n   506ŌåÆ\t}\n   507ŌåÆ\n   508ŌåÆ\tmanager := NewPromptManager(tmpDir)\n   509ŌåÆ\tcontextMgr := NewContextManager(\"test_job\")\n   510ŌåÆ\n   511ŌåÆ\ttask := &parser.Task{\n   512ŌåÆ\t\tID:         \"test_task_123\",\n   513ŌåÆ\t\tName:       \"My Test Task\",\n   514ŌåÆ\t\tGoal:       \"Test the system\",\n   515ŌåÆ\t\tKeyResults: []string{\"KR1\", \"KR2\"},\n   516ŌåÆ\t\tTestMethod: \"go test\",\n   517ŌåÆ\t}\n   518ŌåÆ\n   519ŌåÆ\tcode := \"func Test() {}\"\n   520ŌåÆ\n   521ŌåÆ\tprompt, err := GenerateTestPrompt(task, code, contextMgr, manager)\n   522ŌåÆ\tif err != nil {\n   523ŌåÆ\t\tt.Fatalf(\"Failed to generate test prompt: %v\", err)\n   524ŌåÆ\t}\n   525ŌåÆ\n   526ŌåÆ\t// Verify all variables are replaced\n   527ŌåÆ\tif strings.Contains(prompt, \"{{\") {\n   528ŌåÆ\t\tt.Error(\"Prompt should not contain unreplaced variables\")\n   529ŌåÆ\t}\n   530ŌåÆ\n   531ŌåÆ\t// Verify specific replacements\n   532ŌåÆ\tif !strings.Contains(prompt, \"test_task_123\") {\n   533ŌåÆ\t\tt.Error(\"Task ID should be replaced\")\n   534ŌåÆ\t}\n   535ŌåÆ\n   