Æ\t}\n    48ŌåÆ\ttask.KeyResults = keyResults\n    49ŌåÆ\n    50ŌåÆ\t// Parse test method\n    51ŌåÆ\ttestMethod, err := ParseTestMethod(content)\n    52ŌåÆ\tif err != nil {\n    53ŌåÆ\t\treturn nil, fmt.Errorf(\"failed to parse test method: %w\", err)\n    54ŌåÆ\t}\n    55ŌåÆ\ttask.TestMethod = testMethod\n    56ŌåÆ\n    57ŌåÆ\treturn task, nil\n    58ŌåÆ}\n    59ŌåÆ\n    60ŌåÆ// ParseDependencies extracts dependencies from \"# õŠØĶĄ¢Õģ│ń│╗\" section\n    61ŌåÆfunc ParseDependencies(content string) ([]string, error) {\n    62ŌåÆ\theading := extractSectionContent(content, \"# õŠØĶĄ¢Õģ│ń│╗\")\n    63ŌåÆ\tif heading == \"\" {\n    64ŌåÆ\t\treturn []string{}, nil\n    65ŌåÆ\t}\n    66ŌåÆ\n    67ŌåÆ\t// Split by comma and trim whitespace\n    68ŌåÆ\tparts := strings.Split(heading, \",\")\n    69ŌåÆ\tvar deps []string\n    70ŌåÆ\tfor _, part := range parts {\n    71ŌåÆ\t\ttrimmed := strings.TrimSpace(part)\n    72ŌåÆ\t\tif trimmed != \"\" {\n    73ŌåÆ\t\t\tdeps = append(deps, trimmed)\n    74ŌåÆ\t\t}\n    75ŌåÆ\t}\n    76ŌåÆ\treturn deps, nil\n    77ŌåÆ}\n    78ŌåÆ\n    79ŌåÆ// ParseTaskName extracts task name from \"# õ╗╗ÕŖĪÕÉŹń¦░\" section\n    80ŌåÆfunc ParseTaskName(content string) (string, error) {\n    81ŌåÆ\theading := extractSectionContent(content, \"# õ╗╗ÕŖĪÕÉŹń¦░\")\n    82ŌåÆ\tif heading == \"\" {\n    83ŌåÆ\t\treturn \"\", fmt.Errorf(\"missing '# õ╗╗ÕŖĪÕÉŹń¦░' section\")\n    84ŌåÆ\t}\n    85ŌåÆ\treturn strings.TrimSpace(heading), nil\n    86ŌåÆ}\n    87ŌåÆ\n    88ŌåÆ// ParseGoal extracts goal from \"# õ╗╗ÕŖĪńø«µĀć\" section\n    89ŌåÆfunc ParseGoal(content string) (string, error) {\n    90ŌåÆ\theading := extractSectionContent(content, \"# õ╗╗ÕŖĪńø«µĀć\")\n    91ŌåÆ\tif heading == \"\" {\n    92ŌåÆ\t\treturn \"\", fmt.Errorf(\"missing '# õ╗╗ÕŖĪńø«µĀć' section\")\n    93ŌåÆ\t}\n    94ŌåÆ\treturn strings.TrimSpace(heading), nil\n    95ŌåÆ}\n    96ŌåÆ\n    97ŌåÆ// ParseKeyResults extracts key results from \"# Õģ│ķö«ń╗ōµ×£\" section\n    98ŌåÆfunc ParseKeyResults