  46→\t\t\tif GetVerbose() {\n    47→\t\t\t\tfmt.Printf(\"[INFO] Executing job: %s\\n\", jobID)\n    48→\t\t\t}\n    49→\n    50→\t\t\t// Execute doing workflow\n    51→\t\t\tif err := executeDoingWorkflow(jobID); err != nil {\n    52→\t\t\t\treturn err\n    53→\t\t\t}\n    54→\n    55→\t\t\tfmt.Printf(\"Job %s execution completed!\\n\", jobID)\n    56→\t\t\treturn nil\n    57→\t\t},\n    58→\t}\n    59→\n    60→\tdoingCmd.Flags().StringVar(&jobID, \"job\", \"\", \"Job ID to execute\")\n    61→\n    62→\treturn doingCmd\n    63→}\n    64→\n    65→// executeDoingWorkflow executes the complete doing workflow\n    66→func executeDoingWorkflow(jobID string) error {\n    67→\t// Step 1: Load configuration and workspace\n    68→\tcfg, err := config.LoadConfig()\n    69→\tif err != nil {\n    70→\t\treturn fmt.Errorf(\"failed to load config: %w\", err)\n    71→\t}\n    72→\n    73→\t_, err = workspace.New()\n    74→\tif err != nil {\n    75→\t\treturn fmt.Errorf(\"failed to create workspace: %w\", err)\n    76→\t}\n    77→\n    78→\trickDir, err := workspace.GetRickDir()\n    79→\tif err != nil {\n    80→\t\treturn fmt.Errorf(\"failed to get rick directory: %w\", err)\n    81→\t}\n    82→\n    83→\tif GetVerbose() {\n    84→\t\tfmt.Printf(\"[INFO] Using workspace: %s\\n\", rickDir)\n    85→\t}\n    86→\n    87→\t// Step 2: Validate job directory structure\n    88→\tjobDir := filepath.Join(rickDir, \"jobs\", jobID)\n    89→\tplanDir := filepath.Join(jobDir, \"plan\")\n    90→\tdoingDir := filepath.Join(jobDir, \"doing\")\n    91→\n    92→\tif _, err := os.Stat(jobDir); os.IsNotExist(err) {\n    93→\t\treturn fmt.Errorf(\"job directory not found: %s\", jobDir)\n    94→\t}\n    95→\n    96→\tif _, err := os.Stat(planDir); os.IsNotExist(err) {\n    97→\t\treturn fmt.Errorf(\"plan directory not found: %s\", planDir)\n    98→\t}\n    99→\n   100→\t// Create doing directory if it doesn't exist\n   101→\tif err := os.MkdirAll(doingDir, 0755); err != nil {\n   102→\t\treturn fmt.Er