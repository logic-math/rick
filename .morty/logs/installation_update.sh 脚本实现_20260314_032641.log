hen\n   205ŌåÆ        # Get latest version from GitHub API\n   206ŌåÆ        print_debug \"Fetching latest version from GitHub...\"\n   207ŌåÆ        release_version=$(curl -s https://api.github.com/repos/anthropics/rick/releases/latest | grep '\"tag_name\"' | head -1 | sed 's/.*\"v\\([^\"]*\\)\".*/\\1/')\n   208ŌåÆ\n   209ŌåÆ        if [[ -z \"$release_version\" ]]; then\n   210ŌåÆ            print_error \"Failed to fetch latest version from GitHub\"\n   211ŌåÆ            return 1\n   212ŌåÆ        fi\n   213ŌåÆ    fi\n   214ŌåÆ\n   215ŌåÆ    local download_url=\"https://github.com/anthropics/rick/releases/download/v${release_version}/rick-${os}-${arch}\"\n   216ŌåÆ    local binary_path=\"$bin_dir/rick\"\n   217ŌåÆ\n   218ŌåÆ    print_debug \"Download URL: $download_url\"\n   219ŌåÆ\n   220ŌåÆ    # Create binary directory\n   221ŌåÆ    if ! mkdir -p \"$bin_dir\"; then\n   222ŌåÆ        print_error \"Failed to create binary directory: $bin_dir\"\n   223ŌåÆ        return 1\n   224ŌåÆ    fi\n   225ŌåÆ\n   226ŌåÆ    # Download binary\n   227ŌåÆ    print_debug \"Downloading binary...\"\n   228ŌåÆ    if ! curl -fsSL -o \"$binary_path\" \"$download_url\"; then\n   229ŌåÆ        print_error \"Failed to download binary from: $download_url\"\n   230ŌåÆ        return 1\n   231ŌåÆ    fi\n   232ŌåÆ\n   233ŌåÆ    # Make binary executable\n   234ŌåÆ    if ! chmod +x \"$binary_path\"; then\n   235ŌåÆ        print_error \"Failed to make binary executable\"\n   236ŌåÆ        return 1\n   237ŌåÆ    fi\n   238ŌåÆ\n   239ŌåÆ    print_success \"Binary downloaded and installed to: $binary_path\"\n   240ŌåÆ    return 0\n   241ŌåÆ}\n   242ŌåÆ\n   243ŌåÆcreate_symlink() {\n   244ŌåÆ    local install_dir=\"$1\"\n   245ŌåÆ    local command_name=\"$2\"\n   246ŌåÆ    local bin_dir=\"$install_dir/bin\"\n   247ŌåÆ    local binary_path=\"$bin_dir/rick\"\n   248ŌåÆ    local symlink_path=\"$HOME/.local/bin/$command_name\"\n   249ŌåÆ\n   250ŌåÆ    print_info \"Creating symbolic link...\"\n   251ŌåÆ\n