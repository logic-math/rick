\n    36Рєњ}\n    37Рєњ```\n    38Рєњ\n    39Рєњ### ExecutionConfig у╗ЊТъёСйЊ\n    40Рєњ```go\n    41Рєњtype ExecutionConfig struct {\n    42Рєњ    MaxRetries      int\n    43Рєњ    TimeoutSeconds  int\n    44Рєњ    LogFile         string\n    45Рєњ}\n    46Рєњ```\n    47Рєњ\n    48Рєњ### ExecutionResult у╗ЊТъёСйЊ\n    49Рєњ```go\n    50Рєњtype ExecutionResult struct {\n    51Рєњ    TaskID    string\n    52Рєњ    Status    string // pending, running, success, failed, retrying\n    53Рєњ    Attempts  int\n    54Рєњ    Error     string\n    55Рєњ    Output    string\n    56Рєњ}\n    57Рєњ```\n    58Рєњ\n    59Рєњ## Jobs\n    60Рєњ\n    61Рєњ---\n    62Рєњ\n    63Рєњ### Job 1: DAG Тъёт╗║тЎе\n    64Рєњ\n    65Рєњ#### уЏ«ТаЄ\n    66Рєњ\n    67Рєњт«ъуј░ DAG Тъёт╗║тіЪУЃй№╝їС╗ј Task тѕЌУАеТъёт╗║ТюЅтљЉТЌауј»тЏЙ\n    68Рєњ\n    69Рєњ#### тЅЇуй«ТЮАС╗Х\n    70Рєњ\n    71Рєњ- infrastructure:job_6 - жћЎУ»»т«џС╣Ѕу│╗у╗Ът«їТѕљ\n    72Рєњ\n    73Рєњ#### Tasks\n    74Рєњ\n    75Рєњ- [x] Task 1: тѕЏт╗║ internal/executor/dag.go№╝їт«ъуј░ DAG у╗ЊТъёСйЊ\n    76Рєњ- [x] Task 2: т«ъуј░ NewDAG(tasks) тЄйТЋ░№╝їтѕЏт╗║ DAG т«ъСЙІ\n    77Рєњ- [x] Task 3: т«ъуј░ AddTask(task) Тќ╣Т│Ћ№╝їтљЉ DAG Ти╗тіаС╗╗тіА\n    78Рєњ- [x] Task 4: т«ъуј░ AddDependency(from, to) Тќ╣Т│Ћ№╝їТи╗тіаСЙЮУхќтЁ│у│╗\n    79Рєњ- [x] Task 5: т«ъуј░ ValidateDAG() Тќ╣Т│Ћ№╝їжфїУ»Ђ DAG ТюЅТЋѕТђД\n    80Рєњ- [x] Task 6: т«ъуј░тЙфуј»СЙЮУхќТБђТхІжђ╗УЙЉ\n    81Рєњ- [x] Task 7: у╝ќтєЎтЇЋтЁЃТхІУ»Ћ№╝їУдєуЏќтљёуДЇ DAG жЁЇуй«\n    82Рєњ\n    83Рєњ#### жфїУ»ЂтЎе\n    84Рєњ\n    85Рєњ- NewDAG() УЃйТГБуА«тѕЏт╗║ DAG т«ъСЙІ\n    86Рєњ- AddTask() тњї AddDependency() УЃйТГБуА«Ти╗тіаУіѓуѓ╣тњїУЙ╣\n    87Рєњ- ValidateDAG() УЃйТБђТхІтѕ░тЙфуј»СЙЮУхќ\n    88Рєњ- тЙфуј»СЙЮУхќТБђТхІу╗ЎтЄ║ТИЁТЎ░уџёжћЎУ»»ТЈљуц║\n    89Рєњ- тЇЋтЁЃТхІУ»ЋУдєуЏќујЄ >= 80%\n    90Рєњ\n    91Рєњ#### У░ЃУ»ЋТЌЦт┐Ќ\n    92Рєњ\n    93РєњТЌа\n    94Рєњ\n    95Рєњ#### т«їТѕљуіХТђЂ\n    96Рєњ\n    97РєњРюЁ т«їТѕљ - 2026-03-14\n    98Рєњ\n    99Рєњ**т«ъуј░ТЉўУдЂ**:\n   100Рєњ- тѕЏт╗║ internal/executor/dag.go№╝їт«ъуј░т«їТЋ┤уџё DAG у╗ЊТъёСйЊ\n   101Рєњ- т«ъуј░ NewDAG()сђЂAddTask()сђЂAddDependency() уГЅТаИт┐ЃТќ╣Т│Ћ\n   102Рєњ- т«ъуј░тЙфуј»СЙЮУхќТБђТхІ№╝їСй┐уће DFS у«ЌТ│Ћ\n   103Рєњ- у╝ќтєЎ 21 СИфтЇЋтЁЃТхІУ»Ћ№╝їУдєуЏќујЄ 91.2%\n   104Рєњ- ТЅђТюЅжфїТћХТаЄтЄєТ╗АУХ│\n   105Рєњ\n   106Рєњ---\n   107Рєњ\n   108Рєњ### Job 2: ТІЊТЅЉТјњт║Јт«ъуј░\n   109Рєњ\n   110Рєњ#### уЏ«ТаЄ\n   111Рєњ\n   112Рєњт«ъуј░ Kahn у«ЌТ│ЋуџёТІЊТЅЉТјњт║Ј№╝їућЪТѕљС╗╗тіАТЅДУАїт║ЈтѕЌ\n   113Рєњ\n   114Рєњ#### тЅЇуй«ТЮАС╗Х\n   115Рєњ\n   116Рєњ- job_1 - DAG Тъёт╗║тЎет«їТѕљ\n   117Рєњ\n   118Рєњ#### Tasks\n   119Рєњ\n   120Рєњ- [ ] Task 1: тѕЏт╗║ internal/executor/topological.go№╝їт«ъуј░ТІЊТЅЉТјњт║Ј\n   121Рєњ- [ ] Task 2: т«ъуј░ TopologicalSort(dag) тЄйТЋ░№╝їСй┐уће Kahn у«ЌТ│Ћ\n   122Рєњ- [ ] Task 3: т«ъуј░тЁЦт║дУ«Ау«Ќжђ╗УЙЉ\n   123Рєњ- [ ] Task 4: т«ъуј░жўЪтѕЌтцёуљєжђ╗УЙЉ\n   124Рєњ- [ ] Task 5: т«ъуј░тЙфуј»СЙЮУхќТБђТхІ№╝ѕТјњт║Ју╗ЊТъюСИјС╗╗тіАТЋ░СИЇугд№╝Ѕ\n   125Рєњ- [ ] Task 6: у╝ќтєЎтЇЋтЁЃТхІУ»Ћ№╝їУдєуЏќтљёуДЇ DAG жЁЇуй«\n   126Рєњ\n   127Рєњ#### жфїУ»ЂтЎе\n   128Рєњ\n   129Рєњ- TopologicalSort() У┐ћтЏъТГБуА«уџёТјњт║Јт║ЈтѕЌ\n   130Рєњ- Тјњт║Ју╗ЊТъюТ╗АУХ│СЙЮУхќтЁ│у│╗\n   131Рєњ- УЃйТБђТхІтѕ░тЙфуј»СЙЮУхќт╣ХУ┐ћтЏъжћЎУ»»\n   132Рєњ- Тјњт║Ју╗ЊТъюТЋ░жЄЈуГЅС║јС╗╗тіАТђ╗ТЋ░\n   133Рєњ- тЇЋтЁЃТхІУ»ЋУдєуЏќујЄ >= 80%\n   134Рєњ\n   135Рєњ#### У░ЃУ»ЋТЌЦт┐Ќ\n   136Рєњ\n   137РєњТЌа\n   138Рєњ\n   139Рєњ#### т«їТѕљуіХТђЂ\n   140Рєњ\n   141РєњРЈ│ тЙЁт╝ђтДІ\n   142Рєњ\n   143Рєњ---\n   144Рєњ\n   145Рєњ### Job 3: Tasks.json ућЪТѕљтЎе\n   146Рєњ\n   147Рєњ#### уЏ«ТаЄ\n   148Рєњ\n   149Рєњт«ъуј░ tasks.json уџёућЪТѕљтњїтіаУйй№╝їТћ»ТїЂС╗╗тіАуіХТђЂу«Ауљє\n   150Рєњ\n   151Рєњ#### тЅЇуй«ТЮАС╗Х\n   152Рєњ\n   153Рєњ- job_2 - ТІЊТЅЉТјњт║Јт«ъуј░т«їТѕљ\n   154Рєњ\n   155Рєњ#### Tasks\n   156Рєњ\n   157Рєњ- [ ] Task 1: тѕЏт╗║ internal/executor/tasks_json.go№╝їт«ъуј░ tasks.json ТЊЇСйю\n   158Рєњ- [ ] Task 2: т«ъуј░ GenerateTasksJSON(dag, sortedTasks) тЄйТЋ░\n   159Рєњ- [ ] Task 3: т«ъуј░ LoadTasksJSON(filePath) т