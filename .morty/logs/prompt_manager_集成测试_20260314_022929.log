\t}\n\n\tt.Log(\"Prompts are consistent and properly formatted\")\n}\n\n// Helper function to get template directory\nfunc getTemplateDir() string {\n\t// Try to find the template directory\n\tcwd, _ := os.Getwd()\n\n\t// Check if we're in the prompt package directory\n\tif strings.HasSuffix(cwd, \"prompt\") {\n\t\treturn filepath.Join(cwd, \"templates\")\n\t}\n\n\t// Check if templates exist in standard location\n\tpossiblePaths := []string{\n\t\t\"internal/prompt/templates\",\n\t\t\"./internal/prompt/templates\",\n\t\t\"../prompt/templates\",\n\t}\n\n\tfor _, path := range possiblePaths {\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Default fallback\n\treturn \"internal/prompt/templates\"\n}\n","structuredPatch":[{"oldStart":144,"oldLines":7,"newStart":144,"newLines":7,"lines":["     t.Fatalf(\"Failed to load OKR content: %v\", err)","   }"," ","-  if cm.OKRInfo == nil || cm.OKRInfo.Content == \"\" {","+  if cm.OKRInfo == nil || (len(cm.OKRInfo.Objectives) == 0 && len(cm.OKRInfo.KeyResults) == 0) {","     t.Error(\"OKR not loaded correctly\")","   }"," "]}],"userModified":false,"replaceAll":true}},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_64ddb4f5-0ef","type":"message","content":[{"text":"Fix the SPECInfo.Content reference:","type":"text"}],"context_management":null},"parent_tool_use_id":null,"session_id":"9f10a8cb-f7d6-4a62-83ea-6152b634a15b","uuid":"b489c767-afe6-4a68-9928-4b6a773fbf69"},{"type":"assistant","message":{"role":"assistant","stop_sequence":null,"usage":{"output_tokens":0,"cache_creation_input_tokens":0,"input_tokens":0,"cache_read_input_tokens":0},"stop_reason":null,"model":"claude-haiku-4-5-20251001","id":"msg_64ddb4f5-0ef","type":"message","content":[{"input":{"replace_all":true,"file_path":"/Users/sunquan/ai_cod