[]string\n   134→\tlines := strings.Split(sectionContent, \"\\n\")\n   135→\tfor _, line := range lines {\n   136→\t\ttrimmed := strings.TrimSpace(line)\n   137→\t\t// Handle bullet points (- or *)\n   138→\t\tif strings.HasPrefix(trimmed, \"- \") {\n   139→\t\t\titems = append(items, strings.TrimPrefix(trimmed, \"- \"))\n   140→\t\t} else if strings.HasPrefix(trimmed, \"* \") {\n   141→\t\t\titems = append(items, strings.TrimPrefix(trimmed, \"* \"))\n   142→\t\t} else if len(trimmed) > 0 && trimmed[0] >= '0' && trimmed[0] <= '9' {\n   143→\t\t\t// Handle numbered lists (1. 2. etc)\n   144→\t\t\tparts := strings.SplitN(trimmed, \". \", 2)\n   145→\t\t\tif len(parts) == 2 {\n   146→\t\t\t\titems = append(items, parts[1])\n   147→\t\t\t}\n   148→\t\t}\n   149→\t}\n   150→\n   151→\tif len(items) == 0 {\n   152→\t\treturn \"\", nil\n   153→\t}\n   154→\treturn strings.Join(items, \"\\n\"), nil\n   155→}\n   156→\n   157→// extractSectionContent extracts content between two section headings\n   158→// It finds the section starting with the given heading and returns content until the next heading\n   159→func extractSectionContent(content string, sectionHeading string) string {\n   160→\tlines := strings.Split(content, \"\\n\")\n   161→\tvar result []string\n   162→\tfoundSection := false\n   163→\tvar currentLevel int\n   164→\n   165→\tfor _, line := range lines {\n   166→\t\ttrimmed := strings.TrimSpace(line)\n   167→\n   168→\t\t// Check if this is the section we're looking for\n   169→\t\tif trimmed == sectionHeading {\n   170→\t\t\tfoundSection = true\n   171→\t\t\t// Determine the heading level\n   172→\t\t\tcurrentLevel = strings.Count(strings.TrimPrefix(trimmed, \" \"), \"#\")\n   173→\t\t\tcontinue\n   174→\t\t}\n   175→\n   176→\t\t// If we found the section, collect lines until we hit another heading of the same or higher level\n   177→\t\tif foundSection {\n   178→\t\t\t// Check if we hit another heading\n   179→\t\t\tif strings.HasPrefix(trimmed, \"#\") {\n