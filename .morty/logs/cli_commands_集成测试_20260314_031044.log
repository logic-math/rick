(tmpDir, \".rick\")\n\tif _, err := os.Stat(rickDir); os.IsNotExist(err) {\n\t\tt.Errorf(\"expected .rick directory to exist, but it doesn't\")\n\t}\n\n\t// Verify subdirectories were created\n\texpectedDirs := []string{\"wiki\", \"skills\", \"jobs\"}\n\tfor _, dir := range expectedDirs {\n\t\tdirPath := filepath.Join(rickDir, dir)\n\t\tif _, err := os.Stat(dirPath); os.IsNotExist(err) {\n\t\t\tt.Errorf(\"expected %s directory to exist, but it doesn't\", dir)\n\t\t}\n\t}\n\n\t// Verify files were created\n\texpectedFiles := []string{\"OKR.md\", \"SPEC.md\", \"config.json\"}\n\tfor _, file := range expectedFiles {\n\t\tfilePath := filepath.Join(rickDir, file)\n\t\tif _, err := os.Stat(filePath); os.IsNotExist(err) {\n\t\t\tt.Errorf(\"expected %s file to exist, but it doesn't\", file)\n\t\t}\n\t}\n\n\t// Verify .git directory was created\n\tgitDir := filepath.Join(rickDir, \".git\")\n\tif _, err := os.Stat(gitDir); os.IsNotExist(err) {\n\t\tt.Errorf(\"expected .git directory to exist, but it doesn't\")\n\t}\n}\n\n// TestInitCommandWithDryRun tests the init command with --dry-run flag\nfunc TestInitCommandWithDryRun(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toldHome := os.Getenv(\"HOME\")\n\tos.Setenv(\"HOME\", tmpDir)\n\tdefer os.Setenv(\"HOME\", oldHome)\n\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.AddCommand(NewInitCmd())\n\n\t// Execute init with --dry-run\n\trootCmd.SetArgs([]string{\"--dry-run\", \"init\"})\n\tvar out bytes.Buffer\n\trootCmd.SetOut(&out)\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"init command with --dry-run failed: %v\", err)\n\t}\n\n\t// Verify .rick directory was NOT created\n\trickDir := filepath.Join(tmpDir, \".rick\")\n\tif _, err := os.Stat(rickDir); err == nil {\n\t\tt.Errorf(\"expected .rick directory to NOT exist with --dry-run, but it does\")\n\t}\n\n\t// Verify dry-run message was printed\n\toutput := out.String()\n\tif output == \"\" {\n\t\tt.Errorf(\"expected output from --dry-run, but got none\")\n\t}\n}\n\n// TestInitCommandWithVerbose tests the init command with --verbose flag\nfunc TestInitCommandWithVerbose(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toldHome := os.Getenv(\"HOME\")\n\tos.Setenv(\"HOME\", tmpDir)\n\tdefer os.Setenv(\"HOME\", oldHome)\n\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\trootCmd.AddCommand(NewInitCmd())\n\n\t// Execute init with --verbose\n\trootCmd.SetArgs([]string{\"--verbose\", \"init\"})\n\tvar out bytes.Buffer\n\trootCmd.SetOut(&out)\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"init command with --verbose failed: %v\", err)\n\t}\n\n\t// Verify verbose output was printed\n\toutput := out.String()\n\tif output == \"\" {\n\t\tt.Errorf(\"expected verbose output, but got none\")\n\t}\n}\n\n// TestPlanCommandExists tests that plan command exists and responds to --help\nfunc TestPlanCommandExists(t *testing.T) {\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\trootCmd.AddCommand(NewPlanCmd())\n\n\t// Execute plan --help\n\trootCmd.SetArgs([]string{\"plan\", \"--help\"})\n\tvar out bytes.Buffer\n\trootCmd.SetOut(&out)\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"plan --help failed: %v\", err)\n\t}\n\n\toutput := out.String()\n\tif output == \"\" {\n\t\tt.Errorf(\"expected plan help output, but got none\")\n\t}\n}\n\n// TestDoingCommandExists tests that doing command exists and responds to --help\nfunc TestDoingCommandExists(t *testing.T) {\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\trootCmd.AddCommand(NewDoingCmd())\n\n\t// Execute doing --help\n\trootCmd.SetArgs([]string{\"doing\", \"--help\"})\n\tvar out bytes.Buffer\n\trootCmd.SetOut(&out)\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"doing --help failed: %v\", err)\n\t}\n\n\toutput := out.String()\n\tif output == \"\" {\n\t\tt.Errorf(\"expected doing help output, but got none\")\n\t}\n}\n\n// TestLearningCommandExists tests that learning command exists and responds to --help\nfunc TestLearningCommandExists(t *testing.T) {\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\trootCmd.AddCommand(NewLearningCmd())\n\n\t// Execute learning --help\n\trootCmd.SetArgs([]string{\"learning\", \"--help\"})\n\tvar out bytes.Buffer\n\trootCmd.SetOut(&out)\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"learning --help failed: %v\", err)\n\t}\n\n\toutput := out.String()\n\tif output == \"\" {\n\t\tt.Errorf(\"expected learning help output, but got none\")\n\t}\n}\n\n// TestAllCommandsAvailable tests that all four core commands are available\nfunc TestAllCommandsAvailable(t *testing.T) {\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\n\t// Add all commands\n\trootCmd.AddCommand(NewInitCmd())\n\trootCmd.AddCommand(NewPlanCmd())\n\trootCmd.AddCommand(NewDoingCmd())\n\trootCmd.AddCommand(NewLearningCmd())\n\n\t// Verify all commands are registered\n\texpectedCommands := []string{\"init\", \"plan\", \"doing\", \"learning\"}\n\tfor _, cmdName := range expectedCommands {\n\t\tcmd, _, err := rootCmd.Find([]string{cmdName})\n\t\tif err != nil {\n\t\t\tt.Errorf(\"command '%s' not found: %v\", cmdName, err)\n\t\t}\n\t\tif cmd == nil {\n\t\t\tt.Errorf(\"command '%s' is nil\", cmdName)\n\t\t}\n\t}\n}\n\n// TestGlobalFlags tests that global flags are available\nfunc TestGlobalFlags(t *testing.T) {\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"Enable verbose output\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"Run in dry-run mode\")\n\trootCmd.AddCommand(NewInitCmd())\n\n\t// Check that flags are registered\n\tflags := rootCmd.PersistentFlags()\n\tif flags.Lookup(\"verbose\") == nil {\n\t\tt.Errorf(\"expected --verbose flag to be registered\")\n\t}\n\tif flags.Lookup(\"dry-run\") == nil {\n\t\tt.Errorf(\"expected --dry-run flag to be registered\")\n\t}\n}\n\n// TestCommandHelpOutput tests that all commands have help output\nfunc TestCommandHelpOutput(t *testing.T) {\n\tcommands := []struct {\n\t\tname string\n\t\tcmd  *cobra.Command\n\t}{\n\t\t{\"init\", NewInitCmd()},\n\t\t{\"plan\", NewPlanCmd()},\n\t\t{\"doing\", NewDoingCmd()},\n\t\t{\"learning\", NewLearningCmd()},\n\t}\n\n\tfor _, tc := range commands {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tif tc.cmd.Short == \"\" {\n\t\t\t\tt.Errorf(\"command '%s' has no Short description\", tc.name)\n\t\t\t}\n\t\t\tif tc.cmd.Long == \"\" {\n\t\t\t\tt.Errorf(\"command '%s' has no Long description\", tc.name)\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestCommandJobFlag tests that commands support --job flag\nfunc TestCommandJobFlag(t *testing.T) {\n\tcommands := []struct {\n\t\tname string\n\t\tcmd  *cobra.Command\n\t}{\n\t\t{\"doing\", NewDoingCmd()},\n\t\t{\"learning\", NewLearningCmd()},\n\t}\n\n\tfor _, tc := range commands {\n\t\tt.Run(tc.name, func(t *testing.T) {\n\t\t\tflags := tc.cmd.Flags()\n\t\t\tif flags.Lookup(\"job\") == nil {\n\t\t\t\tt.Errorf(\"command '%s' does not have --job flag\", tc.name)\n\t\t\t}\n\t\t})\n\t}\n}\n\n// TestInitCommandIdempotent tests that running init multiple times is safe\nfunc TestInitCommandIdempotent(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toldHome := os.Getenv(\"HOME\")\n\tos.Setenv(\"HOME\", tmpDir)\n\tdefer os.Setenv(\"HOME\", oldHome)\n\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\trootCmd.AddCommand(NewInitCmd())\n\n\t// Execute init twice\n\trootCmd.SetArgs([]string{\"init\"})\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"first init command failed: %v\", err)\n\t}\n\n\t// Run init again\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"second init command failed: %v\", err)\n\t}\n\n\t// Verify .rick directory still exists\n\trickDir := filepath.Join(tmpDir, \".rick\")\n\tif _, err := os.Stat(rickDir); os.IsNotExist(err) {\n\t\tt.Errorf(\"expected .rick directory to exist after second init\")\n\t}\n}\n\n// TestCLIVersionFlag tests --version flag in CLI context\nfunc TestCLIVersionFlag(t *testing.T) {\n\trootCmd := &cobra.Command{Use: \"rick\", Version: \"0.1.0\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\n\t// Execute with --version\n\trootCmd.SetArgs([]string{\"--version\"})\n\tvar out bytes.Buffer\n\trootCmd.SetOut(&out)\n\t// Version flag causes exit, so we expect an error\n\t_ = rootCmd.Execute()\n\n\t// Just verify the command doesn't crash\n}\n\n// TestCLIHelpFlag tests --help flag in CLI context\nfunc TestCLIHelpFlag(t *testing.T) {\n\trootCmd := &cobra.Command{Use: \"rick\"}\n\trootCmd.PersistentFlags().Bool(\"verbose\", false, \"\")\n\trootCmd.PersistentFlags().Bool(\"dry-run\", false, \"\")\n\trootCmd.AddCommand(NewInitCmd())\n\n\t// Execute with --help\n\trootCmd.SetArgs([]string{\"--help\"})\n\tvar out bytes.Buffer\n\trootCmd.SetOut(&out)\n\t// Help flag causes exit, so we expect an error\n\t_ = rootCmd.Execute()\n\n\t// Just verify the command doesn't crash\n}","new_string":"package cmd\n\nimport (\n\t\"bytes\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n)\n\n// TestCLIIntegrationInitCommandExecution tests the init command execution\nfunc TestCLIIntegrationInitCommandExecution(t *testing.T) {\n\t// Create a temporary directory for testing\n\ttmpDir := t.TempDir()\n\toldHome := os.Getenv(\"HOME\")\n\tos.Setenv(\"HOME\", tmpDir)\n\tdefer os.Setenv(\"HOME\", oldHome)\n\n\t// Create root command with init\n\trootCmd := NewRootCmd(\"0.1.0\")\n\n\t// Execute init command\n\trootCmd.SetArgs([]string{\"init\"})\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"init command failed: %v\", err)\n\t}\n\n\t// Verify .rick directory was created\n\trickDir := filepath.Join(tmpDir, \".rick\")\n\tif _, err := os.Stat(rickDir); os.IsNotExist(err) {\n\t\tt.Errorf(\"expected .rick directory to exist, but it doesn't\")\n\t}\n\n\t// Verify subdirectories were created\n\texpectedDirs := []string{\"wiki\", \"skills\", \"jobs\"}\n\tfor _, dir := range expectedDirs {\n\t\tdirPath := filepath.Join(rickDir, dir)\n\t\tif _, err := os.Stat(dirPath); os.IsNotExist(err) {\n\t\t\tt.Errorf(\"expected %s directory to exist, but it doesn't\", dir)\n\t\t}\n\t}\n\n\t// Verify files were created\n\texpectedFiles := []string{\"OKR.md\", \"SPEC.md\", \"config.json\"}\n\tfor _, file := range expectedFiles {\n\t\tfilePath := filepath.Join(rickDir, file)\n\t\tif _, err := os.Stat(filePath); os.IsNotExist(err) {\n\t\t\tt.Errorf(\"expected %s file to exist, but it doesn't\", file)\n\t\t}\n\t}\n\n\t// Verify .git directory was created\n\tgitDir := filepath.Join(rickDir, \".git\")\n\tif _, err := os.Stat(gitDir); os.IsNotExist(err) {\n\t\tt.Errorf(\"expected .git directory to exist, but it doesn't\")\n\t}\n}\n\n// TestCLIIntegrationPlanCommandExists tests that plan command exists and responds to --help\nfunc TestCLIIntegrationPlanCommandExists(t *testing.T) {\n\trootCmd := NewRootCmd(\"0.1.0\")\n\n\t// Execute plan --help\n\trootCmd.SetArgs([]string{\"plan\", \"--help\"})\n\tvar out bytes.Buffer\n\trootCmd.SetOut(&out)\n\tif err := rootCmd.Execute(); err != nil {\n\t\tt.Fatalf(\"plan --help failed: %v\", err)\n\t}\n\n\toutput := out.String()\n\tif output == \"\" {\n\t\tt.Errorf(\"expected plan help output, but got none\")\n\t}\n}\n\n// Test