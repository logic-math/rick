→        echo \"  Got: $result\"\n    29→        ((FAILED++))\n    30→    fi\n    31→}\n    32→\n    33→echo \"======================================\"\n    34→echo \"Rick CLI Integration Tests\"\n    35→echo \"======================================\"\n    36→echo\n    37→\n    38→# Task 1: CLI Framework and --version\n    39→echo -e \"${YELLOW}Task 1: CLI Framework and --version${NC}\"\n    40→test_case \"CLI version output\" \"./rick --version\" \"rick version 0.1.0\"\n    41→test_case \"CLI help output\" \"./rick --help\" \"Usage:\"\n    42→test_case \"CLI help shows commands\" \"./rick --help\" \"Commands:\"\n    43→echo\n    44→\n    45→# Task 2: Workspace Initialization\n    46→echo -e \"${YELLOW}Task 2: Workspace Initialization${NC}\"\n    47→# Create a temporary directory for testing\n    48→TEST_DIR=$(mktemp -d)\n    49→export HOME=$TEST_DIR\n    50→test_case \"Init command exists\" \"./rick init --help\" \"init\"\n    51→test_case \"Init command creates workspace\" \"./rick init && test -d $HOME/.rick && echo success\" \"success\"\n    52→test_case \"Workspace has OKR.md\" \"test -f $HOME/.rick/OKR.md && echo success\" \"success\"\n    53→test_case \"Workspace has SPEC.md\" \"test -f $HOME/.rick/SPEC.md && echo success\" \"success\"\n    54→test_case \"Workspace has wiki directory\" \"test -d $HOME/.rick/wiki && echo success\" \"success\"\n    55→test_case \"Workspace has skills directory\" \"test -d $HOME/.rick/skills && echo success\" \"success\"\n    56→echo\n    57→\n    58→# Task 3: Configuration System\n    59→echo -e \"${YELLOW}Task 3: Configuration System${NC}\"\n    60→# The config system should load/save from ~/.rick/config.json\n    61→test_case \"Config file created\" \"test -f $HOME/.rick/config.json && echo success\" \"success\"\n    62→if [ -f \"$HOME/.rick/config.json\" ]; then\n    63→    test_case \"Config is valid JSON\" \"cat $HOME/.rick/config.json | grep -F '\\\"' && echo success\" \"success\"\n    64→fi\n    65→echo\n    66→\n    67→