t, \"# д»»еҠЎеҗҚз§°\")\n    82вҶ’\tif heading == \"\" {\n    83вҶ’\t\treturn \"\", fmt.Errorf(\"missing '# д»»еҠЎеҗҚз§°' section\")\n    84вҶ’\t}\n    85вҶ’\treturn strings.TrimSpace(heading), nil\n    86вҶ’}\n    87вҶ’\n    88вҶ’// ParseGoal extracts goal from \"# д»»еҠЎзӣ®ж Ү\" section\n    89вҶ’func ParseGoal(content string) (string, error) {\n    90вҶ’\theading := extractSectionContent(content, \"# д»»еҠЎзӣ®ж Ү\")\n    91вҶ’\tif heading == \"\" {\n    92вҶ’\t\treturn \"\", fmt.Errorf(\"missing '# д»»еҠЎзӣ®ж Ү' section\")\n    93вҶ’\t}\n    94вҶ’\treturn strings.TrimSpace(heading), nil\n    95вҶ’}\n    96вҶ’\n    97вҶ’// ParseKeyResults extracts key results from \"# е…ій”®з»“жһң\" section\n    98вҶ’func ParseKeyResults(content string) ([]string, error) {\n    99вҶ’\tsectionContent := extractSectionContent(content, \"# е…ій”®з»“жһң\")\n   100вҶ’\tif sectionContent == \"\" {\n   101вҶ’\t\treturn []string{}, nil\n   102вҶ’\t}\n   103вҶ’\n   104вҶ’\t// Extract list items by parsing lines starting with \"- \" or \"* \" or numbered lists\n   105вҶ’\tvar items []string\n   106вҶ’\tlines := strings.Split(sectionContent, \"\\n\")\n   107вҶ’\tfor _, line := range lines {\n   108вҶ’\t\ttrimmed := strings.TrimSpace(line)\n   109вҶ’\t\t// Handle bullet points (- or *)\n   110вҶ’\t\tif strings.HasPrefix(trimmed, \"- \") {\n   111вҶ’\t\t\titems = append(items, strings.TrimPrefix(trimmed, \"- \"))\n   112вҶ’\t\t} else if strings.HasPrefix(trimmed, \"* \") {\n   113вҶ’\t\t\titems = append(items, strings.TrimPrefix(trimmed, \"* \"))\n   114вҶ’\t\t} else if len(trimmed) > 0 && trimmed[0] >= '0' && trimmed[0] <= '9' {\n   115вҶ’\t\t\t// Handle numbered lists (1. 2. etc)\n   116вҶ’\t\t\tparts := strings.SplitN(trimmed, \". \", 2)\n   117вҶ’\t\t\tif len(parts) == 2 {\n   118вҶ’\t\t\t\titems = append(items, parts[1])\n   119вҶ’\t\t\t}\n   120вҶ’\t\t}\n   121вҶ’\t}\n   122вҶ’\treturn items, nil\n   123вҶ’}\n   124вҶ’\n   125вҶ’// ParseTestMethod extracts test method from \"# жөӢиҜ•ж–№жі