nfig.json format\"\n((TESTS_TOTAL++))\nif jq empty \"${HOME}/.rick/config.json\" 2>/dev/null; then\n    log_pass \"3.1: config.json is valid JSON\"\nelse\n    log_fail \"3.1: config.json is not valid JSON\"\nfi\n\nlog_test \"3.2: Verify required config fields\"\n((TESTS_TOTAL++))\nREQUIRED_FIELDS=\"model max_retries log_level\"\nMISSING_FIELDS=\"\"\nfor field in $REQUIRED_FIELDS; do\n    if ! jq -e \".$field\" \"${HOME}/.rick/config.json\" > /dev/null 2>&1; then\n        MISSING_FIELDS=\"$MISSING_FIELDS $field\"\n    fi\ndone\nif [ -z \"$MISSING_FIELDS\" ]; then\n    log_pass \"3.2: All required config fields present\"\nelse\n    log_fail \"3.2: Missing config fields:$MISSING_FIELDS\"\nfi\n\nlog_test \"3.3: Verify environment variables\"\n((TESTS_TOTAL++))\nif [ -n \"$HOME\" ]; then\n    log_pass \"3.3: HOME environment variable is set\"\nelse\n    log_fail \"3.3: HOME environment variable not set\"\nfi\n\n# Task 4: Run complete E2E test suite\necho \"\" | tee -a \"$REPORT_FILE\"\necho \"=== TASK 4: Run Complete E2E Test Suite ===\" | tee -a \"$REPORT_FILE\"\n\nlog_test \"4.1: Test rick init command\"\n((TESTS_TOTAL++))\nTEST_INIT_DIR=\"/tmp/rick_init_test_$$\"\nmkdir -p \"$TEST_INIT_DIR\"\ncd \"$TEST_INIT_DIR\"\nif $RICK_BIN init > /dev/null 2>&1 && [ -d \".rick\" ]; then\n    log_pass \"4.1: rick init command works correctly\"\nelse\n    log_fail \"4.1: rick init command failed\"\nfi\nrm -rf \"$TEST_INIT_DIR\"\n\nlog_test \"4.2: Test rick doing --help\"\n((TESTS_TOTAL++))\nif $RICK_BIN doing --help 2>&1 | grep -q \"Usage\"; then\n    log_pass \"4.2: rick doing --help works\"\nelse\n    log_fail \"4.2: rick doing --help failed\"\nfi\n\nlog_test \"4.3: Test rick learning --help\"\n((TESTS_TOTAL++))\nif $RICK_BIN learning --help 2>&1 | grep -q \"Usage\"; then\n    log_pass \"4.3: rick learning --help works\"\nelse\n    log_fail \"4.3: rick learning --help failed\"\nfi\n\n# Task 5: Verify all CLI commands available\necho \"\" | tee -a \"$REPORT_FILE\"\necho \"=== TASK